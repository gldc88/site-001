---
const BRAND = "MONARCH PRIVATE CHAUFFEUR";
const TAGLINE = "Arrive in silence.";
const BOOKING_EMAIL = "dispatch@monarch.chauffeur";

const NAV = [
  { label: "Service", href: "#service" },
  { label: "Fleet", href: "#fleet" },
  { label: "Reserve", href: "#reserve" },
];

const SERVICE = [
  { title: "Airport Meet & Greet", line: "Live tracking + meet-and-greet. Kerbside precision." },
  { title: "Private City Transfer", line: "Door-to-door, scheduled to the minute." },
  { title: "Long-Haul Executive", line: "Whisper-quiet cabin. Steady pace. Fully private." },
];

const FLEET = [
  { name: "Shadow Class", meta: "Sedan • privacy glass • whisper-quiet" },
  { name: "Obsidian Class", meta: "Long wheelbase • rear suite • low profile" },
  { name: "Nightfall Class", meta: "VIP van • lounge seating • discreet boarding" },
];

const CITIES = [
  { city: "Amsterdam", tz: "Europe/Amsterdam" },
  { city: "London", tz: "Europe/London" },
  { city: "Paris", tz: "Europe/Paris" },
  { city: "Zurich", tz: "Europe/Zurich" },
  { city: "Dubai", tz: "Asia/Dubai" },
  { city: "New York", tz: "America/New_York" },
];

const toISODate = (d: Date) => {
  const yyyy = d.getFullYear();
  const mm = String(d.getMonth() + 1).padStart(2, "0");
  const dd = String(d.getDate()).padStart(2, "0");
  return `${yyyy}-${mm}-${dd}`;
};

const defaultDate = toISODate(new Date());

const VISUAL_MAIN_IMG = "https://images.unsplash.com/photo-1618843479313-40f8afb4b4d8?auto=format&fit=crop&w=1600&q=80"; 
const VISUAL_FLEET_IMG = "https://images.unsplash.com/photo-1617788138017-80ad40651399?auto=format&fit=crop&w=1600&q=80";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{BRAND} — Private Chauffeur</title>
    <meta name="description" content="Private chauffeur dispatch for discreet travel. Timed arrivals, quiet cabins, and precision routing." />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,600&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <style>
      :root{
        --bg0: #05060a;
        --bg1: #0a0c12;

        --ink: rgba(245, 245, 248, .92);
        --ink2: rgba(245, 245, 248, .70);
        --ink3: rgba(245, 245, 248, .46);

        --champagne: #d7c4a2;
        --platinum: #bfc7d3;
        --ember: #ff6b2d;

        --line: rgba(215, 196, 162, .22);
        --line2: rgba(191, 199, 211, .14);
        --glass: rgba(255,255,255,.03);
        --shadow: rgba(0,0,0,.62);

        --serif: "Fraunces", serif;
        --sans: "Inter", system-ui, sans-serif;
        --mono: "JetBrains Mono", monospace;

        --max: 1260px;
        --pad: clamp(18px, 4vw, 56px);
        --r: 18px;
      }

      *{ box-sizing:border-box; }
      html,body{ height:100%; scroll-behavior:smooth; }

      body{
        margin:0;
        color:var(--ink);
        font-family:var(--sans);
        letter-spacing:.01em;
        background:
          radial-gradient(1200px 900px at 14% 8%, rgba(215,196,162,.12), transparent 55%),
          radial-gradient(1100px 800px at 88% 20%, rgba(191,199,211,.10), transparent 55%),
          radial-gradient(900px 700px at 55% 92%, rgba(255,107,45,.06), transparent 60%),
          linear-gradient(180deg, var(--bg0), var(--bg1));
        overflow-x:hidden;
      }

      /* Fine noise */
      body::before{
        content:"";
        position:fixed; inset:0;
        background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
        pointer-events:none;
        mix-blend-mode:overlay;
        z-index:0;
      }

      a{ color:inherit; text-decoration:none; }
      button{ font-family:inherit; }

      .wrap{
        position:relative;
        z-index:1;
        max-width:var(--max);
        margin:0 auto;
        padding: 22px var(--pad) 120px;
      }

      /* Top rail + nav */
      .top{
        display:flex;
        align-items:flex-start;
        justify-content:space-between;
        gap:22px;
        padding: 10px 0 22px;
        border-bottom:1px solid var(--line2);
      }

      .brand{ display:flex; flex-direction:column; gap:6px; }
      .brand .name{
        font-family:var(--serif); font-weight:600; letter-spacing:.08em;
        text-transform:uppercase; font-size: 14px; color: rgba(215,196,162,.92);
      }
      .brand .meta{
        font-family:var(--mono); font-size:11px; letter-spacing:.22em;
        text-transform:uppercase; color: rgba(245,245,248,.40);
      }

      .nav{ display:flex; gap:18px; align-items:center; padding-top: 4px; }
      .nav a{
        font-family:var(--mono); font-size:11px; letter-spacing:.18em;
        text-transform:uppercase; color: rgba(245,245,248,.56);
        position:relative; padding: 8px 10px; border-radius: 999px;
        transition: background .25s ease, color .25s ease, border-color .25s ease;
        border:1px solid transparent;
      }
      .nav a:hover{
        color: rgba(215,196,162,.95); background: rgba(255,255,255,.02);
        border-color: rgba(215,196,162,.18);
      }

      /* SYSTEM EXIT BUTTON */
      .sys-exit{
        display:flex; align-items:center; gap: 8px;
        padding: 8px 14px; border-radius: 999px;
        border: 1px solid rgba(255,255,255,.12);
        background: rgba(5,6,11,.85); backdrop-filter: blur(8px);
        font-family: var(--mono); font-size: 10px; letter-spacing: .12em;
        text-transform: uppercase; color: rgba(245,245,248,.6);
        transition: all .2s ease;
      }
      .sys-exit:hover{
        border-color: var(--champagne); color: var(--champagne);
        box-shadow: 0 0 20px rgba(215,196,162,.15);
      }

      /* Hero: asymmetrical */
      .hero{
        padding: 38px 0 10px;
        display:grid; grid-template-columns: 1.05fr .95fr;
        gap: clamp(18px, 3vw, 42px); align-items:stretch;
      }

      .hero-left{
        position:relative; border-radius: var(--r);
        border: 1px solid rgba(255,255,255,.06);
        background: linear-gradient(180deg, rgba(255,255,255,.03), rgba(0,0,0,.18));
        overflow:hidden; box-shadow: 0 28px 80px rgba(0,0,0,.38);
      }
      .hero-left::after{
        content:""; position:absolute; inset:-2px;
        background:
          radial-gradient(800px 460px at 18% 24%, rgba(215,196,162,.16), transparent 55%),
          radial-gradient(700px 460px at 85% 30%, rgba(191,199,211,.12), transparent 55%),
          linear-gradient(120deg, transparent 0 42%, rgba(255,255,255,.02) 50%, transparent 58% 100%);
        pointer-events:none; opacity:.85;
      }

      .hero-pad{
        position:relative; padding: clamp(22px, 3vw, 40px);
        z-index:1; min-height: 540px; display:flex; flex-direction:column;
        justify-content:space-between; gap: 26px;
      }

      .kicker{ display:flex; justify-content:space-between; gap:18px; align-items:flex-start; }
      .k-left{ display:flex; flex-direction:column; gap: 10px; }
      .tagline{
        font-family:var(--mono); font-size:11px; letter-spacing:.24em;
        text-transform:uppercase; color: rgba(245,245,248,.52);
      }
      .h1{
        margin:0; font-family:var(--serif); font-weight:600;
        font-size: clamp(40px, 5.2vw, 74px); line-height:1.02; letter-spacing:.02em;
      }
      .h1 .accent{ color: rgba(215,196,162,.98); }

      .lede{
        margin: 18px 0 0; max-width: 58ch; color: var(--ink2);
        line-height: 1.75; font-size: 14px;
        border-left: 1px solid rgba(215,196,162,.22); padding-left: 16px;
      }

      .hero-actions{ display:flex; align-items:center; gap: 14px; flex-wrap:wrap; margin-top: 16px; }

      .btn{
        appearance:none; border:1px solid rgba(255,255,255,.10);
        background: rgba(0,0,0,.18); color: rgba(245,245,248,.90);
        padding: 12px 16px; border-radius: 999px;
        font-family: var(--mono); font-size: 11px; letter-spacing: .18em;
        text-transform: uppercase; transition: transform .18s ease, border-color .22s ease, background .22s ease, color .22s ease;
        cursor:pointer; display:inline-flex; gap:10px; align-items:center;
      }
      .btn:hover{
        transform: translateY(-1px); border-color: rgba(215,196,162,.30);
        background: rgba(255,255,255,.03); color: rgba(215,196,162,.92);
      }
      .btn.primary{
        border-color: rgba(215,196,162,.34);
        background: radial-gradient(700px 260px at 20% 40%, rgba(215,196,162,.18), rgba(0,0,0,.22));
      }
      .btn.primary:hover{
        border-color: rgba(215,196,162,.58);
        box-shadow: 0 18px 60px rgba(215,196,162,.10);
      }

      /* Arrival window timeline board */
      .board{ display:grid; grid-template-columns: 1.05fr .95fr; gap: 16px; align-items:stretch; padding-top: 6px; }

      .panel{
        border-radius: 14px; border: 1px solid rgba(255,255,255,.07);
        background: rgba(0,0,0,.20); box-shadow: 0 18px 50px rgba(0,0,0,.22); overflow:hidden;
      }
      .panel .ph{
        padding: 14px 14px 10px; display:flex; align-items:flex-end;
        justify-content:space-between; gap:12px;
        border-bottom: 1px solid rgba(255,255,255,.06);
      }
      .ph .t{
        font-family: var(--mono); font-size: 10px; letter-spacing: .22em;
        text-transform: uppercase; color: rgba(245,245,248,.58);
      }
      .ph .v{
        font-family: var(--serif); font-weight: 600; color: rgba(215,196,162,.92);
        font-size: 16px; letter-spacing: .02em; text-align:right;
      }

      .timeline{ padding: 12px 12px 14px; }
      .tl-grid{ display:grid; grid-template-columns: repeat(12, 1fr); gap: 6px; align-items:stretch; }
      .slot{
        height: 34px; border-radius: 10px; border: 1px solid rgba(255,255,255,.07);
        background: rgba(255,255,255,.02); display:flex; align-items:center;
        justify-content:center; font-family: var(--mono); font-size: 10px;
        letter-spacing:.10em; color: rgba(245,245,248,.55); cursor:pointer;
        user-select:none; transition: transform .14s ease, border-color .22s ease, background .22s ease, color .22s ease;
        position:relative; overflow:hidden;
      }
      .slot:hover{
        transform: translateY(-1px); border-color: rgba(215,196,162,.22);
        color: rgba(215,196,162,.86); background: rgba(215,196,162,.05);
      }
      .slot[data-state="busy"]{
        cursor:not-allowed; opacity:.42; background: rgba(0,0,0,.18);
      }
      .slot[data-active="true"]{
        border-color: rgba(215,196,162,.60);
        background: radial-gradient(220px 120px at 20% 40%, rgba(215,196,162,.20), rgba(0,0,0,.20));
        color: rgba(245,245,248,.92); box-shadow: 0 16px 60px rgba(215,196,162,.12);
      }

      .tl-foot{
        display:flex; justify-content:space-between; gap: 16px; margin-top: 12px;
        color: rgba(245,245,248,.52); font-size: 12px; line-height: 1.6;
      }
      .tl-foot .mini{
        font-family: var(--mono); font-size: 10px; letter-spacing:.18em;
        text-transform:uppercase; color: rgba(245,245,248,.42);
      }

      /* Hero-right: visual stack */
      .hero-right{
        display:grid; grid-template-rows: 1.1fr .9fr; gap: 14px; min-height: 540px;
      }

      .visual{
        border-radius: var(--r); border: 1px solid rgba(255,255,255,.07);
        background: linear-gradient(180deg, rgba(255,255,255,.03), rgba(0,0,0,.26));
        overflow:hidden; position:relative; box-shadow: 0 26px 80px rgba(0,0,0,.35);
      }
      .visual::before{
        content:""; position:absolute; inset:-2px;
        background:
          radial-gradient(700px 420px at 12% 18%, rgba(215,196,162,.16), transparent 58%),
          radial-gradient(640px 420px at 88% 26%, rgba(191,199,211,.12), transparent 58%),
          linear-gradient(135deg, rgba(255,255,255,.03), transparent 55%);
        opacity:.92; pointer-events:none;
      }
      .visual img {
        width: 100%; height: 100%; object-fit: cover;
        filter: saturate(0.8) contrast(1.1); transform: scale(1.05);
        transition: transform 1s ease;
      }
      .visual:hover img { transform: scale(1); }

      .viz-top{
        position:absolute; top: 16px; left: 16px; right: 16px;
        display:flex; justify-content:space-between; gap: 14px; z-index:2;
      }
      .chip{
        border:1px solid rgba(255,255,255,.08); background: rgba(0,0,0,.18);
        border-radius: 999px; padding: 9px 12px; font-family: var(--mono);
        font-size: 10px; letter-spacing: .18em; text-transform: uppercase;
        color: rgba(245,245,248,.60); display:inline-flex; gap: 10px; align-items:center;
      }
      .dot{
        width: 8px; height: 8px; border-radius: 999px;
        background: rgba(215,196,162,.88); box-shadow: 0 0 18px rgba(215,196,162,.18);
      }

      .sub-visual{
        border-radius: var(--r); border: 1px solid rgba(255,255,255,.07);
        background: rgba(0,0,0,.22); overflow:hidden; position:relative;
      }
      .sub-visual img {
        width: 100%; height: 100%; object-fit: cover;
        filter: grayscale(0.5) contrast(1.1);
      }

      /* Sections */
      .section{ margin-top: 86px; }
      .head{
        display:flex; justify-content:space-between; align-items:flex-end; gap: 14px;
        padding-bottom: 16px; border-bottom: 1px solid rgba(255,255,255,.06);
      }
      .head h2{
        margin:0; font-family: var(--serif); font-weight: 600;
        letter-spacing: .02em; font-size: 32px;
      }
      .head .note{
        font-family: var(--mono); font-size: 10px; letter-spacing: .22em;
        text-transform: uppercase; color: rgba(245,245,248,.46); text-align:right;
      }

      .cards{
        margin-top: 18px; display:grid; grid-template-columns: repeat(3, 1fr); gap: 10px;
      }
      .card{
        border-radius: 16px; border: 1px solid rgba(255,255,255,.06);
        background: rgba(0,0,0,.18); padding: 18px 16px; position:relative;
        overflow:hidden; transition: transform .16s ease, border-color .22s ease;
      }
      .card:hover{ transform: translateY(-1px); border-color: rgba(215,196,162,.22); }
      .card .ct{
        font-family: var(--mono); font-size: 10px; letter-spacing: .22em;
        text-transform: uppercase; color: rgba(215,196,162,.80);
      }
      .card .cl{
        margin-top: 10px; color: rgba(245,245,248,.62); line-height: 1.7; font-size: 13px;
      }

      /* Reserve strip */
      .reserve{
        margin-top: 22px; display:grid; grid-template-columns: 1.1fr .9fr; gap: 14px; align-items:stretch;
      }
      .reserve-left{
        border-radius: 18px; border: 1px solid rgba(255,255,255,.07);
        background: linear-gradient(180deg, rgba(255,255,255,.03), rgba(0,0,0,.22));
        padding: 18px; overflow:hidden; position:relative;
      }
      .reserve-left::before{
        content:""; position:absolute; inset:-1px;
        background:
          radial-gradient(900px 380px at 10% 20%, rgba(255,107,45,.08), transparent 60%),
          radial-gradient(900px 380px at 92% 50%, rgba(191,199,211,.10), transparent 60%);
        opacity:.85; pointer-events:none;
      }
      .reserve-in{ position:relative; display:flex; flex-direction:column; gap: 12px; z-index:1; }

      .reserve-title{
        font-family: var(--serif); font-weight: 600; letter-spacing:.02em; font-size: 22px; margin:0;
      }
      .reserve-copy{
        color: rgba(245,245,248,.62); line-height: 1.7; font-size: 13px; max-width: 62ch; margin:0;
      }
      .reserve-right{
        border-radius: 18px; border: 1px solid rgba(255,255,255,.07);
        background: rgba(0,0,0,.18); padding: 18px; display:flex; flex-direction:column;
        justify-content:space-between; gap: 12px;
      }
      .metric{
        display:flex; justify-content:space-between; gap: 12px; padding: 10px 0;
        border-bottom: 1px solid rgba(255,255,255,.06);
      }
      .metric:last-child{ border-bottom: none; }
      .metric .k{
        font-family: var(--mono); font-size: 10px; letter-spacing: .22em;
        text-transform: uppercase; color: rgba(245,245,248,.44);
      }
      .metric .v{
        font-family: var(--serif); font-weight: 600; letter-spacing:.02em; color: rgba(215,196,162,.90);
      }

      /* Dialog */
      dialog{
        border: 1px solid rgba(255,255,255,.08); border-radius: 18px;
        background:
          radial-gradient(900px 520px at 18% 10%, rgba(215,196,162,.12), transparent 55%),
          radial-gradient(900px 520px at 88% 20%, rgba(191,199,211,.10), transparent 55%),
          linear-gradient(180deg, rgba(10,12,18,.92), rgba(5,6,10,.96));
        color: var(--ink); width: min(980px, calc(100vw - 28px));
        box-shadow: 0 40px 140px rgba(0,0,0,.65); padding: 0;
      }
      dialog::backdrop{ background: rgba(0,0,0,.65); backdrop-filter: blur(6px); }

      .dlg{ padding: 18px; }
      .dlg-top{
        display:flex; justify-content:space-between; gap: 14px; align-items:flex-start;
        border-bottom: 1px solid rgba(255,255,255,.06); padding-bottom: 12px;
      }
      .dlg-title{ margin:0; font-family: var(--serif); font-weight: 600; font-size: 22px; letter-spacing: .02em; }
      .dlg-sub{ margin-top: 6px; color: rgba(245,245,248,.60); font-size: 12px; line-height: 1.6; max-width: 70ch; }
      .x{
        appearance:none; border: 1px solid rgba(255,255,255,.10); background: rgba(0,0,0,.18);
        color: rgba(245,245,248,.82); border-radius: 999px; width: 40px; height: 40px;
        cursor:pointer; transition: transform .16s ease, border-color .22s ease;
      }
      .x:hover{ transform: translateY(-1px); border-color: rgba(215,196,162,.24); color: rgba(215,196,162,.90); }

      .form{ margin-top: 14px; display:grid; grid-template-columns: 1fr 1fr; gap: 12px; }
      .field{
        border: 1px solid rgba(255,255,255,.07); border-radius: 14px;
        background: rgba(0,0,0,.18); padding: 12px;
      }
      .field.wide{ grid-column: 1 / -1; }
      label{
        display:flex; justify-content:space-between; gap: 12px; align-items:baseline;
        font-family: var(--mono); font-size: 10px; letter-spacing: .22em;
        text-transform: uppercase; color: rgba(245,245,248,.48);
      }
      .hint{ margin-top: 8px; color: rgba(245,245,248,.56); font-size: 12px; line-height: 1.5; }
      input, select, textarea{
        width:100%; margin-top: 10px; border: 1px solid rgba(255,255,255,.10);
        background: rgba(0,0,0,.24); border-radius: 12px; padding: 12px 12px;
        color: rgba(245,245,248,.92); outline:none; font-size: 13px;
        transition: border-color .22s ease, background .22s ease;
      }
      textarea{ min-height: 96px; resize: vertical; }
      input:focus, select:focus, textarea:focus{
        border-color: rgba(215,196,162,.35);
        box-shadow: 0 0 0 3px rgba(201,110,83,.12);
      }

      .inline{ display:grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin-top: 10px; }
      .flight{ display:flex; flex-direction:column; gap: 10px; margin-top: 10px; }
      .row{ display:flex; gap: 10px; align-items:center; flex-wrap:wrap; }

      .toggle{
        display:inline-flex; gap: 10px; align-items:center; border: 1px solid rgba(255,255,255,.10);
        background: rgba(0,0,0,.20); padding: 10px 12px; border-radius: 999px;
        cursor:pointer; user-select:none; transition: border-color .22s ease, background .22s ease;
      }
      .toggle:hover{ border-color: rgba(215,196,162,.22); background: rgba(255,255,255,.03); }
      .pill{
        width: 38px; height: 22px; border-radius: 999px; border: 1px solid rgba(255,255,255,.12);
        background: rgba(255,255,255,.04); position:relative;
      }
      .pill::after{
        content:""; width: 18px; height: 18px; border-radius: 999px;
        background: rgba(245,245,248,.78); position:absolute; top: 50%; left: 2px;
        transform: translateY(-50%); transition: left .20s ease, background .20s ease;
      }
      .toggle[data-on="true"] .pill{ border-color: rgba(215,196,162,.28); background: rgba(215,196,162,.10); }
      .toggle[data-on="true"] .pill::after{ left: 18px; background: rgba(215,196,162,.95); }
      .toggle .t{ font-family: var(--mono); font-size: 10px; letter-spacing: .18em; text-transform: uppercase; color: rgba(245,245,248,.66); }

      .delay{
        flex: 1 1 240px; border: 1px solid rgba(255,255,255,.10); background: rgba(0,0,0,.20);
        border-radius: 14px; padding: 10px 12px;
      }
      .delay .top{ padding: 0; border: 0; display:flex; justify-content:space-between; align-items:baseline; gap: 12px; }
      .delay .k{ font-family: var(--mono); font-size: 10px; letter-spacing: .22em; text-transform: uppercase; color: rgba(245,245,248,.48); }
      .delay .val{ font-family: var(--serif); font-weight: 600; color: rgba(215,196,162,.90); }
      .range{ width:100%; margin-top: 10px; }

      .out{ margin-top: 12px; border: 1px solid rgba(255,255,255,.07); background: rgba(0,0,0,.18); border-radius: 14px; padding: 12px; }
      .out .mini{ font-family: var(--mono); font-size: 10px; letter-spacing: .22em; text-transform: uppercase; color: rgba(245,245,248,.42); }
      .out .big{ margin-top: 8px; font-family: var(--serif); font-weight: 600; font-size: 18px; letter-spacing: .02em; color: rgba(215,196,162,.92); }
      .out .txt{ margin-top: 6px; color: rgba(245,245,248,.62); font-size: 12px; line-height: 1.6; }

      .dlg-actions{
        margin-top: 14px; display:flex; gap: 10px; flex-wrap:wrap; justify-content:flex-end;
        border-top: 1px solid rgba(255,255,255,.06); padding-top: 12px;
      }

      .footer{
        margin-top: 90px; padding-top: 18px; border-top: 1px solid rgba(255,255,255,.06);
        color: rgba(245,245,248,.34); font-family: var(--mono); font-size: 10px;
        letter-spacing: .20em; text-transform: uppercase; display:flex; justify-content:space-between;
        gap: 14px; flex-wrap:wrap;
      }

      @media (max-width: 980px){
        .hero{ grid-template-columns: 1fr; }
        .hero-right{ min-height: unset; grid-template-rows: 360px 260px; }
        .board{ grid-template-columns: 1fr; }
        .cards{ grid-template-columns: 1fr; }
        .reserve{ grid-template-columns: 1fr; }
        .form{ grid-template-columns: 1fr; }
        .inline{ grid-template-columns: 1fr; }
      }
    </style>
  </head>

  <body data-booking-email={BOOKING_EMAIL}>
    <div class="wrap">
      <header class="top">
        <div class="brand">
          <div class="name">{BRAND}</div>
          <div class="meta">DISCREET DISPATCH • QUIET CABIN • TIMED ARRIVAL</div>
        </div>

        <nav class="nav" aria-label="Primary">
          {NAV.map((n) => <a href={n.href}>{n.label}</a>)}
          <button class="btn primary" type="button" id="openReserveTop">Reserve</button>
        </nav>
      </header>
      
      <a href="/" class="sys-exit"><i>[</i> EXIT <i>]</i></a>

      <main>
        <section class="hero" aria-label="Hero">
          <article class="hero-left">
            <div class="hero-pad">
              <div>
                <div class="kicker">
                  <div class="k-left">
                    <div class="tagline">{TAGLINE}</div>
                    <h1 class="h1">
                      Private transfer,<br />
                      engineered <span class="accent">like a suit.</span>
                    </h1>
                  </div>

                  <div style="text-align:right; padding-top: 8px;">
                    <div class="tagline">Dispatch status</div>
                    <div style="margin-top:8px; font-family:var(--serif); font-weight:600; color:rgba(215,196,162,.92); font-size:22px;">
                      Ready
                    </div>
                    <div style="margin-top:6px; font-family:var(--mono); font-size:10px; letter-spacing:.22em; text-transform:uppercase; color:rgba(245,245,248,.40);">
                      Arrival windows active
                    </div>
                  </div>
                </div>

                <p class="lede">
                  Not a taxi. A private dispatch system—quiet cabin, measured pacing, and a chauffeur brief prepared before departure.
                </p>

                <div class="hero-actions" aria-label="Hero actions">
                  <button class="btn primary" type="button" id="openReserveHero">Open reservation</button>
                  <a class="btn" href="#service">See service map</a>
                  <a class="btn" href="#fleet">Fleet classes</a>
                </div>
              </div>

              <div class="board" aria-label="Arrival window board">
                <div class="panel">
                  <div class="ph">
                    <div class="t">Arrival windows</div>
                    <div class="v" id="windowValue">Select a window</div>
                  </div>
                  <div class="timeline">
                    <div class="tl-grid" id="timelineGrid" aria-label="Window selection">
                      </div>
                    <div class="tl-foot">
                      <div>
                        <div class="mini">Guidance</div>
                        Choose a dispatch window. We route for a calm arrival—never rushed, never late.
                      </div>
                      <div style="text-align:right;">
                        <div class="mini">Auto</div>
                        <span id="nextWindow">Calculating</span>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="panel">
                  <div class="ph">
                    <div class="t">Hold details</div>
                    <div class="v" id="holdValue">No hold</div>
                  </div>
                  <div class="timeline">
                    <div style="display:grid; gap:10px;">
                      <div style="display:flex; justify-content:space-between; gap:12px; align-items:center;">
                        <div style="font-family:var(--mono); font-size:10px; letter-spacing:.22em; text-transform:uppercase; color:rgba(245,245,248,.42);">
                          City time
                        </div>
                        <div style="font-family:var(--serif); font-weight:600; color:rgba(215,196,162,.90);" id="cityTime">--:--</div>
                      </div>

                      <div style="display:flex; justify-content:space-between; gap:12px; align-items:center;">
                        <div style="font-family:var(--mono); font-size:10px; letter-spacing:.22em; text-transform:uppercase; color:rgba(245,245,248,.42);">
                          Selected window
                        </div>
                        <div style="font-family:var(--serif); font-weight:600; color:rgba(245,245,248,.86);" id="selectedWindowMini">None</div>
                      </div>

                      <div style="display:flex; gap:10px; flex-wrap:wrap; padding-top:6px;">
                        <button class="btn" type="button" id="createHoldBtn">Create calendar hold</button>
                        <button class="btn primary" type="button" id="briefBtn">Generate chauffeur brief</button>
                      </div>

                      <div style="color:rgba(245,245,248,.56); font-size:12px; line-height:1.6; padding-top:2px;">
                        A hold is a calendar file (.ics). The brief is a clean dispatch card you can copy, print, or forward.
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </article>

          <aside class="hero-right" aria-label="Visuals">
            <div class="visual" aria-label="Primary visual">
              <div class="viz-top">
                <div class="chip"><span class="dot" aria-hidden="true"></span> <span id="chipCity">Amsterdam</span></div>
                <div class="chip">Cabin: Quiet</div>
              </div>

              <img src={VISUAL_MAIN_IMG} alt="Luxury vehicle detail dark" />
            </div>

            <div class="sub-visual" aria-label="Secondary visual">
               <img src={VISUAL_FLEET_IMG} alt="Abstract car curves" />
            </div>
          </aside>
        </section>

        <section class="section" id="service" aria-label="Service">
          <div class="head">
            <h2>Service map</h2>
            <div class="note">Low touch • high control</div>
          </div>

          <div class="cards">
            {SERVICE.map((s) => (
              <article class="card">
                <div class="ct">{s.title}</div>
                <div class="cl">{s.line}</div>
              </article>
            ))}
          </div>
        </section>

        <section class="section" id="fleet" aria-label="Fleet">
          <div class="head">
            <h2>Fleet classes</h2>
            <div class="note">Coachbuilt feel • unbranded</div>
          </div>

          <div class="cards">
            {FLEET.map((f) => (
              <article class="card">
                <div class="ct">{f.name}</div>
                <div class="cl">{f.meta}</div>
              </article>
            ))}
          </div>
        </section>

        <section class="section" id="reserve" aria-label="Reserve">
          <div class="head">
            <h2>Reserve</h2>
            <div class="note">Calendar hold + chauffeur brief</div>
          </div>

          <div class="reserve">
            <div class="reserve-left">
              <div class="reserve-in">
                <h3 class="reserve-title">A reservation is a dispatch instruction.</h3>
                <p class="reserve-copy">
                  Choose a window. We generate a calendar hold and a chauffeur brief. Your mail client opens with a complete instruction set addressed to {BOOKING_EMAIL}.
                </p>

                <div style="display:flex; gap:10px; flex-wrap:wrap;">
                  <button class="btn primary" type="button" id="openReserveBottom">Open reservation</button>
                  <button class="btn" type="button" id="quickHold">Quick hold from selected window</button>
                </div>

                <div style="margin-top:6px; color:rgba(245,245,248,.54); font-size:12px; line-height:1.6;">
                  If no window is selected, Quick hold picks the next clean window automatically.
                </div>
              </div>
            </div>

            <div class="reserve-right">
              <div class="metric">
                <div class="k">Mode</div>
                <div class="v">Private</div>
              </div>
              <div class="metric">
                <div class="k">Exposure</div>
                <div class="v">Low</div>
              </div>
              <div class="metric">
                <div class="k">Lead time</div>
                <div class="v">30–90 min</div>
              </div>
              <div class="metric">
                <div class="k">Mail</div>
                <div class="v">{BOOKING_EMAIL}</div>
              </div>
            </div>
          </div>
        </section>
      </main>

      <footer class="footer" aria-label="Footer">
        <div>DISPATCH-LED</div>
        <div>QUIET CABIN STANDARD</div>
        <div>CALENDAR HOLD READY</div>
      </footer>
    </div>

    <dialog id="reserveDlg" aria-label="Reservation dialog">
      <div class="dlg">
        <div class="dlg-top">
          <div>
            <h3 class="dlg-title">Reservation</h3>
            <div class="dlg-sub">
              This flow creates (1) a calendar hold (.ics) and (2) an email draft to dispatch. Flight sync is a planning aid—final monitoring is handled by dispatch.
            </div>
          </div>
          <button class="x" type="button" id="closeReserve" aria-label="Close dialog">✕</button>
        </div>

        <form class="form" id="reserveForm">
          <div class="field">
            <label>
              City
              <span style="color:rgba(215,196,162,.70);">Local time aware</span>
            </label>
            <select id="city" name="city">
              {CITIES.map((c) => <option value={c.tz}>{c.city}</option>)}
            </select>
            <div class="hint">Sets the local time reference for the hold and brief.</div>
          </div>

          <div class="field">
            <label>
              Service
              <span style="color:rgba(245,245,248,.40);">Type</span>
            </label>
            <select id="serviceType" name="serviceType">
              <option value="Airport Meet & Greet">Airport Meet & Greet</option>
              <option value="Private City Transfer">Private City Transfer</option>
              <option value="Long-Haul Executive">Long-Haul Executive</option>
            </select>
            <div class="hint">Adds service-specific notes to the chauffeur brief.</div>
          </div>

          <div class="field">
            <label>Date</label>
            <input id="date" name="date" type="date" value={defaultDate} />
            <div class="hint">Used for availability and the calendar hold.</div>
          </div>

          <div class="field">
            <label>Dispatch window</label>
            <select id="window" name="window">
              <option value="">Select from timeline</option>
              <option value="06:00-06:30">06:00–06:30</option>
              <option value="08:00-08:30">08:00–08:30</option>
              <option value="10:00-10:30">10:00–10:30</option>
              <option value="12:00-12:30">12:00–12:30</option>
              <option value="14:00-14:30">14:00–14:30</option>
              <option value="16:00-16:30">16:00–16:30</option>
              <option value="18:00-18:30">18:00–18:30</option>
              <option value="20:00-20:30">20:00–20:30</option>
              <option value="22:00-22:30">22:00–22:30</option>
            </select>
            <div class="hint">Selecting a slot in the timeline fills this field.</div>
          </div>

          <div class="field wide">
            <label>Route</label>
            <div class="inline">
              <div>
                <input id="pickup" name="pickup" type="text" autocomplete="street-address" />
                <div class="hint">Pickup address / terminal / gate.</div>
              </div>
              <div>
                <input id="dropoff" name="dropoff" type="text" autocomplete="street-address" />
                <div class="hint">Destination address.</div>
              </div>
              <div>
                <select id="fleet" name="fleet">
                  <option value="Shadow Class">Shadow Class</option>
                  <option value="Obsidian Class">Obsidian Class</option>
                  <option value="Nightfall Class">Nightfall Class</option>
                </select>
                <div class="hint">Choose a cabin layout preference.</div>
              </div>
            </div>
          </div>

          <div class="field wide">
            <label>Passenger</label>
            <div class="inline">
              <div>
                <input id="name" name="name" type="text" autocomplete="name" />
                <div class="hint">Name shown on the dispatch card.</div>
              </div>
              <div>
                <input id="phone" name="phone" type="text" autocomplete="tel" />
                <div class="hint">Contact used by dispatch for updates.</div>
              </div>
              <div>
                <select id="bags" name="bags">
                  <option value="1–2">1–2</option>
                  <option value="3–4">3–4</option>
                  <option value="5+">5+</option>
                </select>
                <div class="hint">Helps cabin prep and luggage handling.</div>
              </div>
            </div>
          </div>

          <div class="field wide">
            <label>Flight sync (optional)</label>
            <div class="flight">
              <div class="row">
                <div class="toggle" id="flightToggle" data-on="false" role="switch" aria-checked="false" tabindex="0">
                  <div class="pill" aria-hidden="true"></div>
                  <div class="t">Enable flight sync</div>
                </div>

                <div style="flex: 1 1 260px;">
                  <input id="flight" name="flight" type="text" />
                  <div class="hint">Flight number for planning context and meet guidance.</div>
                </div>

                <div class="delay" aria-label="Delay simulation">
                  <div class="top">
                    <div class="k">Delay simulation</div>
                    <div class="val"><span id="delayVal">+0</span> min</div>
                  </div>
                  <input class="range" id="delay" name="delay" type="range" min="-45" max="180" value="0" />
                </div>
              </div>

              <div class="out" aria-label="Guidance output">
                <div class="mini">Auto guidance</div>
                <div class="big" id="guidePrimary">Select a window to compute guidance.</div>
                <div class="txt" id="guideSecondary">
                  Flight sync refines meet timing. Holds are fixed unless regenerated.
                </div>
              </div>
            </div>
          </div>

          <div class="field wide">
            <label>Notes</label>
            <textarea id="notes" name="notes"></textarea>
            <div class="hint">Quiet preferences, child seat, terminal/gate notes, security notes, pacing.</div>
          </div>
        </form>

        <div class="dlg-actions">
          <button class="btn" type="button" id="makeICS">Download hold (.ics)</button>
          <button class="btn" type="button" id="makeBrief">Open chauffeur brief</button>
          <button class="btn primary" type="button" id="sendMail">Open dispatch email</button>
        </div>
      </div>
    </dialog>

    <dialog id="briefDlg" aria-label="Chauffeur brief dialog">
      <div class="dlg">
        <div class="dlg-top">
          <div>
            <h3 class="dlg-title">Chauffeur brief</h3>
            <div class="dlg-sub">A clean dispatch card. Copy, print, or forward with your calendar hold.</div>
          </div>
          <button class="x" type="button" id="closeBrief" aria-label="Close brief">✕</button>
        </div>

        <div style="margin-top:14px; display:grid; grid-template-columns: 1.1fr .9fr; gap: 12px;">
          <div class="field wide" style="grid-column:auto;">
            <label>Brief</label>
            <div id="briefCard" style="
              margin-top: 10px;
              border-radius: 16px;
              border: 1px solid rgba(255,255,255,.08);
              background:
                radial-gradient(900px 420px at 18% 20%, rgba(215,196,162,.14), transparent 60%),
                radial-gradient(900px 420px at 88% 30%, rgba(191,199,211,.10), transparent 60%),
                rgba(0,0,0,.20);
              padding: 16px;
              box-shadow: 0 24px 90px rgba(0,0,0,.45);
            ">
              <div style="display:flex; justify-content:space-between; gap: 12px; align-items:flex-start;">
                <div>
                  <div style="font-family:var(--mono); font-size:10px; letter-spacing:.22em; text-transform:uppercase; color:rgba(245,245,248,.48);">
                    Dispatch
                  </div>
                  <div style="margin-top:8px; font-family:var(--serif); font-weight:600; font-size:20px; letter-spacing:.02em; color:rgba(215,196,162,.92);" id="briefTitle">
                    MONARCH • HOLD
                  </div>
                </div>
                <div style="text-align:right;">
                  <div style="font-family:var(--mono); font-size:10px; letter-spacing:.22em; text-transform:uppercase; color:rgba(245,245,248,.48);">
                    Window
                  </div>
                  <div style="margin-top:8px; font-family:var(--serif); font-weight:600; font-size:18px; color:rgba(245,245,248,.86);" id="briefWindow">
                    --
                  </div>
                </div>
              </div>

              <div style="margin-top: 12px; border-top: 1px solid rgba(255,255,255,.06); padding-top: 12px; display:grid; gap: 10px;">
                <div style="display:flex; justify-content:space-between; gap: 12px;">
                  <div style="font-family:var(--mono); font-size:10px; letter-spacing:.22em; text-transform:uppercase; color:rgba(245,245,248,.42);">
                    Passenger
                  </div>
                  <div style="font-family:var(--serif); font-weight:600; color:rgba(215,196,162,.90);" id="briefName">--</div>
                </div>
                <div style="display:flex; justify-content:space-between; gap: 12px;">
                  <div style="font-family:var(--mono); font-size:10px; letter-spacing:.22em; text-transform:uppercase; color:rgba(245,245,248,.42);">
                    Route
                  </div>
                  <div style="text-align:right; color:rgba(245,245,248,.70); max-width: 54ch;" id="briefRoute">--</div>
                </div>
                <div style="display:flex; justify-content:space-between; gap: 12px;">
                  <div style="font-family:var(--mono); font-size:10px; letter-spacing:.22em; text-transform:uppercase; color:rgba(245,245,248,.42);">
                    Service
                  </div>
                  <div style="color:rgba(245,245,248,.70);" id="briefService">--</div>
                </div>
                <div style="display:flex; justify-content:space-between; gap: 12px;">
                  <div style="font-family:var(--mono); font-size:10px; letter-spacing:.22em; text-transform:uppercase; color:rgba(245,245,248,.42);">
                    Fleet
                  </div>
                  <div style="color:rgba(245,245,248,.70);" id="briefFleet">--</div>
                </div>
                <div style="display:flex; justify-content:space-between; gap: 12px;">
                  <div style="font-family:var(--mono); font-size:10px; letter-spacing:.22em; text-transform:uppercase; color:rgba(245,245,248,.42);">
                    Flight
                  </div>
                  <div style="color:rgba(245,245,248,.70);" id="briefFlight">--</div>
                </div>
              </div>

              <div style="margin-top:12px; border-top: 1px solid rgba(255,255,255,.06); padding-top: 12px;">
                <div style="font-family:var(--mono); font-size:10px; letter-spacing:.22em; text-transform:uppercase; color:rgba(245,245,248,.42);">
                  Notes
                </div>
                <div style="margin-top:8px; color:rgba(245,245,248,.62); line-height:1.6; font-size:12px;" id="briefNotes">
                  --
                </div>
              </div>
            </div>
          </div>

          <div class="field wide" style="grid-column:auto;">
            <label>Actions</label>
            <div style="margin-top:10px; display:flex; flex-direction:column; gap:10px;">
              <button class="btn primary" type="button" id="copyBrief">Copy brief text</button>
              <button class="btn" type="button" id="printBrief">Print</button>
              <button class="btn" type="button" id="downloadBrief">Download brief (.txt)</button>
            </div>

            <div class="hint" style="margin-top:12px;">
              Printing creates a clean PDF in your browser. Download exports a text brief for dispatch systems.
            </div>
          </div>
        </div>
      </div>
    </dialog>

    <script type="module">
      // @ts-check
      /* (JS remains unchanged) */
    </script>
  </body>
</html>

---
const BRAND = "AETHER CRYSTALWORKS";

const NAV = [
  { label: "Collection", href: "#collection" },
  { label: "Craft", href: "#craft" },
  { label: "Specs", href: "#specs" },
];

const PIECES = [
  {
    name: "Glacial Monolith",
    meta: "SERIES 04 / DEEP-CUT FACETS",
    line: "A weighty optical block with a slow, blue refraction—made to hold light like ice holds winter."
  },
  {
    name: "Prism Alpha",
    meta: "SERIES 09 / SPECTRAL EDGE",
    line: "Knife-clean geometry tuned for dispersion. A small object that throws a full spectrum on command."
  },
  {
    name: "Ice Stone",
    meta: "SERIES 12 / HAND FINISH",
    line: "Near-invisible internal structure. Built for pure transmission, quiet highlights, and crisp shadows."
  },
];

const CRAFT = [
  { k: "Annealing", v: "Thermally stabilized to remove stress and preserve alignment over time." },
  { k: "Cold-cut facets", v: "Measured geometry first—spark is a byproduct of precision, not decoration." },
  { k: "Hand polish", v: "Edges refined until they disappear, leaving only the line of light." },
];

const SPECS = [
  { k: "MATERIAL", v: "OPTICAL K9 GLASS" },
  { k: "CLARITY", v: "VVS1 STANDARD" },
  { k: "CUT", v: "BRILLIANT FACET" },
  { k: "ORIGIN", v: "LAB-GROWN" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{BRAND} — Optical Glass</title>
    <meta
      name="description"
      content="AETHER CRYSTALWORKS crafts lab-grown optical crystal objects: annealed, cold-cut, and hand-polished for controlled refraction."
    />

    <style>
      :root{
        /* Dark, deep base */
        --bg0: #050608;
        --bg1: #0b0d14;

        --ink: #f0f4f8;
        --ink-dim: #94a3b8;

        /* Refined Ice Palette (Subtle & Cold) */
        --ice-highlight: rgba(220, 245, 255, 0.6);
        --ice-mid: rgba(125, 211, 252, 0.3);
        --ice-shadow: rgba(14, 165, 233, 0.15);

        --glass-border: rgba(255,255,255,0.1);
        --glass-bg: rgba(255,255,255,0.02);

        --font-serif: "Times New Roman", serif;
        --font-sans: system-ui, sans-serif;

        --max: 1200px;
        --pad: clamp(20px, 4vw, 56px);

        /* Pointer vars */
        --mx: 50%;
        --my: 50%;
      }

      *{ box-sizing: border-box; }
      html,body{ height: 100%; margin: 0; scroll-behavior: smooth; }

      body{
        background: radial-gradient(circle at 50% 0%, #171e2e 0%, var(--bg0) 80%);
        color: var(--ink);
        font-family: var(--font-sans);
        overflow-x: hidden;
      }

      /* Ambient Light */
      body::before {
        content: ""; position: fixed; inset: 0;
        background: radial-gradient(800px circle at var(--mx) var(--my), rgba(56, 189, 248, 0.08), transparent 40%);
        pointer-events: none; z-index: 0; opacity: 0.5;
      }

      /* Back Button */
      .back-nav {
        position: fixed; top: 24px; left: 24px; z-index: 100;
        display: flex; align-items: center; justify-content: center;
        width: 40px; height: 40px;
        border: 1px solid var(--glass-border); border-radius: 50%;
        color: var(--ink-dim); background: rgba(0,0,0,0.4);
        backdrop-filter: blur(8px); transition: all 0.3s;
      }
      .back-nav:hover { border-color: var(--ice-mid); color: #fff; box-shadow: 0 0 15px var(--ice-shadow); }
      .back-nav svg { width: 16px; height: 16px; fill: currentColor; }

      .wrap {
        max-width: var(--max); margin: 0 auto; padding: 0 var(--pad) 100px;
        position: relative; z-index: 2;
      }

      /* HEADER */
      header {
        display: flex; justify-content: space-between; align-items: flex-end;
        padding: 40px 0; border-bottom: 1px solid var(--glass-border);
        margin-bottom: 60px;
      }
      .brand { text-transform: uppercase; letter-spacing: 0.15em; font-size: 14px; font-weight: 600; color: #fff; text-shadow: 0 0 15px var(--ice-shadow); }
      nav { display: flex; gap: 30px; }
      nav a { font-size: 11px; text-transform: uppercase; letter-spacing: 0.2em; color: var(--ink-dim); transition: color 0.3s; text-decoration: none; }
      nav a:hover { color: var(--ice-highlight); }

      /* HERO */
      .hero {
        display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center; min-height: 65vh;
      }

      .crystal-stage {
        grid-column: 1;
        position: relative; height: 600px; display: flex; align-items: center; justify-content: center;
        perspective: 1200px;
        margin-top: -80px;
      }
      .hero-text { grid-column: 2; text-align: right; }

      h1 {
        font-family: var(--font-serif); font-size: clamp(48px, 6vw, 80px);
        font-weight: 300; line-height: 1; margin: 0 0 24px;
        background: linear-gradient(135deg, #ffffff 30%, #94a3b8 100%);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      }
      .lead {
        font-size: 16px; color: var(--ink-dim); line-height: 1.6; max-width: 40ch;
        border-right: 1px solid var(--ice-mid); padding-right: 20px; margin-left: auto;
      }

      /* HERO CRYSTAL (Quartz) */
      .crystal-assembly {
        position: relative; width: 200px; height: 400px;
        transform-style: preserve-3d;
        animation: breath 8s ease-in-out infinite alternate;
      }
      .pillar {
        position: absolute; bottom: 50px; left: 50%; transform-origin: bottom center;
        clip-path: polygon(50% 0%, 100% 15%, 100% 100%, 0% 100%, 0% 15%);
        background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, rgba(200,240,255,0.02) 50%, rgba(255,255,255,0.05) 100%);
        border-left: 1px solid rgba(255,255,255,0.15); border-right: 1px solid rgba(255,255,255,0.05); border-top: 1px solid rgba(255,255,255,0.3);
        backdrop-filter: blur(6px); box-shadow: inset 0 10px 30px rgba(125, 211, 252, 0.05);
      }
      .pillar::after {
        content: ""; position: absolute; inset: 10px; clip-path: inherit; pointer-events: none; opacity: 0.3;
        background: linear-gradient(to bottom, rgba(255,255,255,0.1), transparent);
      }
      .p-main { width: 120px; height: 320px; transform: translateX(-50%) translateZ(20px); z-index: 10; }
      .p-left { width: 70px; height: 200px; transform: translateX(-130%) rotateZ(-12deg) rotateY(20deg) translateZ(-10px); z-index: 5; opacity: 0.9; }
      .p-right { width: 80px; height: 240px; transform: translateX(40%) rotateZ(8deg) rotateY(-20deg) translateZ(10px); z-index: 8; opacity: 0.95; }
      .p-back { width: 100px; height: 280px; transform: translateX(-50%) translateZ(-40px) rotateY(180deg); opacity: 0.6; filter: blur(2px); }

      .glint-wrapper { position: absolute; inset: -100%; transform-style: preserve-3d; pointer-events: none; }
      .glint {
        position: absolute; width: 100%; height: 100%;
        background: radial-gradient(circle at var(--mx) var(--my), rgba(255, 255, 255, 0.5) 0%, rgba(125, 211, 252, 0.1) 15%, transparent 40%);
        mix-blend-mode: overlay; transform: translateZ(60px); opacity: 0.4; filter: blur(10px);
      }
      @keyframes breath { 0% { transform: rotateY(-5deg) translateY(0px); } 100% { transform: rotateY(5deg) translateY(-15px); } }

      /* RAW STACK */
      .raw-stack-stage {
        height: 400px; width: 100%;
        background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(0,0,0,0.3));
        border: 1px solid var(--glass-border); border-radius: 16px;
        position: relative; overflow: hidden;
        display: flex; align-items: center; justify-content: center;
        perspective: 1000px;
        box-shadow: inset 0 0 100px rgba(0,0,0,0.8);
      }

      .raw-stack {
        position: relative; width: 160px; height: 240px;
        transform-style: preserve-3d;
        transform: rotateY(-30deg) rotateX(10deg);
        transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
      }

      .raw-stack-stage:hover .raw-stack { transform: rotateY(-15deg) rotateX(5deg) scale(1.05); }

      .pane {
        position: absolute; inset: 0;
        border-radius: 4px;
        background: linear-gradient(120deg, rgba(255,255,255,0.03), rgba(200,240,255,0.01));
        border: 1px solid rgba(255,255,255,0.15);
        box-shadow: inset 0 0 20px rgba(125, 211, 252, 0.05), 0 10px 30px rgba(0,0,0,0.5);
        backdrop-filter: blur(2px);
        transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1), border-color 0.3s;
      }
      .pane::after {
        content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
        background: linear-gradient(180deg, transparent 30%, rgba(255,255,255,0.1) 45%, transparent 60%);
        background-size: 100% 200%; animation: scan 4s ease-in-out infinite; opacity: 0.3; pointer-events: none;
      }
      .pane:nth-child(1) { transform: translateZ(0px); }
      .pane:nth-child(2) { transform: translateZ(-30px) translateX(10px); opacity: 0.9; }
      .pane:nth-child(3) { transform: translateZ(-60px) translateX(20px); opacity: 0.8; }
      .pane:nth-child(4) { transform: translateZ(-90px) translateX(30px); opacity: 0.7; }
      .pane:nth-child(5) { transform: translateZ(-120px) translateX(40px); opacity: 0.6; }

      .raw-stack-stage:hover .pane:nth-child(1) { border-color: rgba(255,255,255,0.4); }
      .raw-stack-stage:hover .pane:nth-child(2) { transform: translateZ(-50px) translateX(20px); }
      .raw-stack-stage:hover .pane:nth-child(3) { transform: translateZ(-100px) translateX(40px); }
      .raw-stack-stage:hover .pane:nth-child(4) { transform: translateZ(-150px) translateX(60px); }
      .raw-stack-stage:hover .pane:nth-child(5) { transform: translateZ(-200px) translateX(80px); }

      @keyframes scan { 0% { background-position: 0% 0%; } 100% { background-position: 0% 200%; } }

      /* COLLECTION */
      .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; margin-top: 100px; }
      .card {
        background: var(--glass-bg); border: 1px solid var(--glass-border); padding: 30px;
        transition: all 0.4s ease; cursor: pointer; position: relative; overflow: hidden;
      }
      .card:hover {
        border-color: var(--ice-mid); box-shadow: 0 10px 40px -10px rgba(56, 189, 248, 0.1); transform: translateY(-4px);
      }
      .meta { font-size: 10px; letter-spacing: 0.2em; color: var(--ice-mid); margin-bottom: 10px; display: block; text-transform: uppercase; }
      .name { font-family: var(--font-serif); font-size: 24px; margin: 0 0 10px; color: #fff; }
      .desc { font-size: 13px; color: var(--ink-dim); line-height: 1.5; }

      /* OPTICAL RULER */
      .specs-container {
        margin-top: 120px;
        position: relative;
        padding-top: 40px;
      }

      .optical-bar {
        position: relative;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        background: rgba(255, 255, 255, 0.015);
        border: 1px solid var(--glass-border);
        backdrop-filter: blur(10px);
        overflow: hidden;
      }

      .optical-bar::before {
        content: ""; position: absolute; top: 0; left: 0; right: 0; height: 1px;
        background: linear-gradient(90deg, transparent, var(--ice-highlight), transparent);
        opacity: 0.7;
      }

      .optical-bar::after {
        content: ""; position: absolute; inset: 0;
        background: linear-gradient(120deg, transparent 40%, rgba(255,255,255,0.05) 50%, transparent 60%);
        transform: translateX(-100%);
        animation: sheen 6s infinite ease-in-out;
        pointer-events: none;
      }

      .spec-cell {
        position: relative;
        padding: 30px 20px;
        text-align: center;
        border-right: 1px solid rgba(255,255,255,0.05);
        transition: background 0.3s;
      }
      .spec-cell:last-child { border-right: none; }
      .spec-cell:hover { background: rgba(255,255,255,0.03); }

      .spec-cell::after {
        content: ""; position: absolute; right: 0; top: 20%; bottom: 20%; width: 1px;
        background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.1), transparent);
      }

      .spec-k {
        display: block; font-size: 10px; letter-spacing: 0.25em; color: var(--ice-mid);
        margin-bottom: 12px; text-transform: uppercase; font-family: var(--font-sans);
      }
      .spec-v {
        display: block; font-size: 16px; color: #fff; font-family: var(--font-serif);
        letter-spacing: 0.05em; text-shadow: 0 0 15px rgba(255,255,255,0.2);
      }

      @keyframes sheen {
        0%, 30% { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
      }

      /* FOOTER */
      footer { text-align: center; padding: 60px 0; color: var(--ink-dim); font-size: 12px; margin-top: 60px; border-top: 1px solid var(--glass-border);}

      /* MOBILE RESET */
      @media(max-width: 768px) {
        .hero { grid-template-columns: 1fr; text-align: center; }
        .crystal-stage { grid-column: auto; margin-top: 0; height: 400px; }
        .hero-text { grid-column: auto; text-align: center; }
        .lead { margin: 0 auto; border-right: none; border-top: 1px solid var(--ice-mid); padding-top: 20px; padding-right: 0; }

        .optical-bar { grid-template-columns: 1fr 1fr; }
        .spec-cell:nth-child(2) { border-right: none; }
        .spec-cell { border-bottom: 1px solid rgba(255,255,255,0.05); }
      }
    </style>
  </head>

  <body>
    <a href="/" class="back-nav" aria-label="Return to Index">
      <svg viewBox="0 0 24 24"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
    </a>

    <div class="wrap">
      <header>
        <div class="brand">{BRAND}</div>
        <nav>
          {NAV.map(n => <a href={n.href}>{n.label}</a>)}
        </nav>
      </header>

      <main>
        <section class="hero">

          <div class="crystal-stage">
            <div class="crystal-assembly">
              <div class="pillar p-back"></div>
              <div class="pillar p-left"></div>
              <div class="pillar p-right"></div>
              <div class="pillar p-main"></div>
              <div class="glint-wrapper">
                <div class="glint"></div>
              </div>
            </div>
          </div>

          <div class="hero-text">
            <h1>Crystal,<br>Disciplined.</h1>
            <div class="lead">
              Lab-grown optical glass, cut and polished to behave like a lens.
              Minimal ornament. Maximum refraction. Built to look quiet—until it catches light.
            </div>
          </div>

        </section>

        <section id="collection" class="grid">
          {PIECES.map(p => (
            <div class="card">
              <span class="meta">{p.meta}</span>
              <h3 class="name">{p.name}</h3>
              <p class="desc">{p.line}</p>
            </div>
          ))}
        </section>

        <section id="specs" class="specs-container" aria-label="Optical ruler">
          <div class="optical-bar">
            {SPECS.map(s => (
              <div class="spec-cell">
                <span class="spec-k">{s.k}</span>
                <span class="spec-v">{s.v}</span>
              </div>
            ))}
          </div>
        </section>

        <section id="craft" style="margin-top: 100px; display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center;">

          <div class="raw-stack-stage">
            <div class="raw-stack">
              <div class="pane"></div>
              <div class="pane"></div>
              <div class="pane"></div>
              <div class="pane"></div>
              <div class="pane"></div>
            </div>
          </div>

          <div>
            <span style="color: var(--ice-mid); letter-spacing: 0.2em; font-size: 11px; text-transform: uppercase;">Craft</span>
            <h2 style="font-family: var(--font-serif); font-weight: 300; font-size: 32px; margin: 10px 0 20px; color: #fff;">
              Cut with restraint.
            </h2>
            <p style="color: var(--ink-dim); font-size: 13px; margin: 0 0 18px; line-height: 1.6;">
              Every piece starts as clean stock, then earns its character through geometry, heat discipline, and a final human finish.
            </p>
            <div style="display: flex; flex-direction: column; gap: 15px;">
              {CRAFT.map(c => (
                <div>
                  <strong style="color: var(--ink); font-size: 14px;">{c.k}</strong>
                  <p style="color: var(--ink-dim); font-size: 13px; margin: 0;">{c.v}</p>
                </div>
              ))}
            </div>
          </div>
        </section>
      </main>

      <footer>
        &copy; 2024 {BRAND}. Optical crystal objects, made in cold light.
      </footer>
    </div>

    <script>
      // Enhanced mouse tracking for subtle parallax on the crystal
      let targetX = 50, targetY = 50;
      let currentX = 50, currentY = 50;

      document.addEventListener('mousemove', (e) => {
        targetX = (e.clientX / window.innerWidth) * 100;
        targetY = (e.clientY / window.innerHeight) * 100;
      });

      function animate() {
        currentX += (targetX - currentX) * 0.08;
        currentY += (targetY - currentY) * 0.08;

        document.documentElement.style.setProperty('--mx', `${currentX}%`);
        document.documentElement.style.setProperty('--my', `${currentY}%`);
        requestAnimationFrame(animate);
      }
      animate();
    </script>
  </body>
</html>

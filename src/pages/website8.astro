const TAGLINE = "An independent bookstore. Curated shelves. Quiet reading room.";

const NAV = [
  { label: "Staff Picks", href: "#collection" },
  { label: "Catalog", href: "#catalog" },
  { label: "Events", href: "#events" },
  { label: "Services", href: "#services" },
  { label: "Visit", href: "#visit" },
  { label: "Contact", href: "#contact" },
];

/* IMAGERY */
const IMG = {

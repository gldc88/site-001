---
const BRAND = "OVERSEAS LINE";

const NAV = [
  { label: "Crossings", href: "#voyages" },
  { label: "The Ship", href: "#details" },
  { label: "Onboard", href: "#facilities" },
  { label: "Concierge", href: "/contact" },
];

const VOYAGES = [
  { name: "New York to Southampton", meta: "14 NIGHTS / APRIL" },
  { name: "Riviera Circuit", meta: "12 NIGHTS / JULY" },
  { name: "Pacific Drift", meta: "18 NIGHTS / JANUARY" },
];

const DETAILS = [
  { title: "FLEET", line: "All suite ships. Dedicated butler." },
  { title: "DINING", line: "Chef led menus, always included." },
  { title: "WELLNESS", line: "Thermal deck, recovery first." },
  { title: "ACCESS", line: "Private pier, quiet embark." },
];

const FACILITIES = [
  { title: "THERMAL DECK", line: "Sauna, steam, cold plunge." },
  { title: "PRIVATE SPA SUITES", line: "Booked, never busy." },
  { title: "SILENCE LOUNGE", line: "Low light, horizon views." },
  { title: "CHEF SALONS", line: "Chef counter, cellar access." },
  { title: "HORIZON DECK", line: "Sheltered seating, salt air." },
  { title: "SUITE BUTLER", line: "Unseen, on call, exact." },
  { title: "SHORE CONCIERGE", line: "Plans made, lines skipped." },
  { title: "PRIVATE TRANSFER", line: "Pier to suite handling." },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{BRAND} | Private Overseas Voyages</title>
    <meta name="description" content="Private overseas crossings with an all suite ship, concierge embarkation, and quiet, recovery first onboard life." />

    <style>
      :root{
        /* DEEPER VOID PALETTE */
        --bg0:#020305;
        --bg1:#080a10;

        /* SHARPER GOLD & INK */
        --ink: #F0F2F5;
        --ink-dim: rgba(240, 242, 245, 0.75);

        --line: rgba(255,255,255,0.08);
        --line-gold: rgba(214, 184, 135, 0.30);

        --gold: #D6B887;
        --gold-glow: rgba(214, 184, 135, 0.15);

        --shadow: rgba(0,0,0,0.9);

        --radius: 4px;
        --max: 1320px;
        --pad: clamp(24px, 5vw, 60px);
        --gap: clamp(30px, 3vw, 50px);

        --serif: "Times New Roman", Times, serif;
        --sans: "Helvetica Neue", Helvetica, Arial, sans-serif;
        --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      }

      *{ box-sizing:border-box; }
      html,body{ height:100%; scroll-behavior:smooth; }

      body{
        margin:0;
        color:var(--ink);
        font-family:var(--sans);
        background-color: var(--bg0);
        background-image:
          radial-gradient(circle at 50% 0%, rgba(214, 184, 135, 0.08), transparent 40%),
          linear-gradient(180deg, var(--bg0) 0%, var(--bg1) 100%);
        overflow-x:hidden;
      }

      /* Luxury Noise Texture */
      body::before{
        content:"";
        position:fixed; inset:0;
        background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.7' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
        pointer-events:none;
        opacity:0.6;
        z-index:0;
      }

      a{ color:inherit; text-decoration:none; }
      .wrap{ position:relative; z-index:1; max-width:var(--max); margin:0 auto; padding: 0 var(--pad) 140px; }

      /* NAVIGATION - High Status */
      .topbar{
        position:sticky; top:0;
        display:flex; align-items:center; justify-content:space-between; gap:20px;
        padding: 30px 0;
        margin-bottom: 40px;
        z-index:10;
        mix-blend-mode: difference;
      }

      .brand{ display:flex; align-items: center; gap: 16px; }
      
      /* BACK LINK ADDED HERE */
      .back-link{
        width: 32px; height: 32px;
        display: flex; align-items: center; justify-content: center;
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 50%;
        color: rgba(255,255,255,0.6);
        transition: all 0.3s ease;
      }
      .back-link:hover{
        border-color: var(--gold);
        color: var(--gold);
        transform: scale(1.1);
      }
      .back-link svg{ width: 14px; height: 14px; fill: currentColor; }

      .brand .name{
        display: flex; flex-direction: column; gap: 2px;
        font-family: var(--serif);
        font-size: 18px;
        letter-spacing: 0.05em;
        color: var(--gold);
        font-weight: 400;
        text-transform: uppercase;
      }

      .nav{ display:flex; gap:32px; align-items:center; }
      .nav a{
        font-family: var(--sans);
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.6);
        transition: color 0.3s;
        position: relative;
      }
      .nav a:hover{ color: var(--gold); }
      .nav a::after{
        content:""; position:absolute; bottom:-6px; left:0; right:100%; height:1px;
        background: var(--gold); transition: right 0.3s;
      }
      .nav a:hover::after{ right:0; }

      /* HERO SECTION */
      .hero{ padding: 60px 0 100px; }

      .heroGrid{
        display:grid;
        grid-template-columns: 1fr 1.4fr;
        gap: 80px;
        align-items: center;
      }

      .h1{
        font-family: var(--serif);
        font-weight: 400;
        font-size: clamp(48px, 6vw, 82px);
        line-height: 1.05;
        color: #fff;
        margin: 0;
      }
      .h1 span{ color: var(--gold); }

      .lead{
        margin-top: 32px;
        font-family: var(--sans);
        font-size: 16px;
        line-height: 1.8;
        letter-spacing: 0.02em;
        color: var(--ink-dim);
        max-width: 440px;
        border-left: 1px solid var(--line-gold);
        padding-left: 24px;
      }

      .actions{ margin-top: 48px; display:flex; gap:24px; }

      .btn{
        padding: 18px 32px;
        font-family: var(--sans);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        border: 1px solid var(--line);
        color: #fff;
        transition: all 0.3s ease;
        background: transparent;
      }
      .btn.primary{
        border-color: var(--gold);
        color: var(--gold);
      }
      .btn.primary:hover{
        background: var(--gold);
        color: #000;
        box-shadow: 0 0 40px rgba(214, 184, 135, 0.4);
      }
      .btn.secondary:hover{ border-color: #fff; }

      /* 50K VISUAL PANEL */
      .visual{
        position: relative;
        height: 600px;
        border-right: 1px solid var(--line-gold);
        border-bottom: 1px solid var(--line-gold);
        background: linear-gradient(135deg, rgba(255,255,255,0.02), rgba(0,0,0,0.3));
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .shipSvg{
        width: 80%;
        height: 80%;
        max-width: 500px;
        max-height: 500px;
      }

      .hud{
        position: absolute;
        top: 30px; right: 30px;
        text-align: right;
      }
      .hud-label{
        font-family: var(--sans);
        font-size: 11px;
        letter-spacing: 0.25em;
        color: var(--gold);
        font-weight: 700;
        text-transform: uppercase;
        opacity: 0.8;
      }
      .hud-val{
        font-family: var(--serif);
        font-size: 24px;
        color: #fff;
        margin-top: 4px;
      }

      /* SECTIONS */
      section{ margin-top: 140px; }

      .sectionHead{
        margin-bottom: 40px;
        border-bottom: 1px solid var(--line);
        padding-bottom: 20px;
        display:flex; justify-content:space-between; align-items:flex-end;
      }
      .sectionHead h2{
        font-family: var(--serif);
        font-size: 32px;
        font-weight: 400;
        color: #fff;
        margin:0;
      }
      .sectionHead .tag{
        font-family: var(--sans);
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--gold);
      }

      /* CARDS */
      .grid{
        display:grid; grid-template-columns: repeat(3, 1fr); gap: 2px;
        background: var(--line-gold);
        border: 1px solid var(--line-gold);
      }

      .card{
        background: var(--bg0);
        padding: 40px 32px;
        transition: background 0.4s ease;
        position: relative;
      }
      .card:hover{ background: #0d0f14; }

      .kicker{
        font-family: var(--sans);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 16px;
        opacity: 0.9;
      }
      .title{
        font-family: var(--serif);
        font-size: 26px;
        color: #fff;
        margin-bottom: 8px;
        font-weight: 400;
      }
      .desc{
        font-family: var(--sans);
        font-size: 14px;
        color: rgba(255,255,255,0.5);
        letter-spacing: 0.05em;
      }

      /* DETAILS GRID */
      .detailGrid{
        display:grid; grid-template-columns: repeat(4, 1fr);
        border-top: 1px solid var(--line);
        margin-top: 60px;
      }
      .detailItem{
        padding: 40px 20px;
        border-right: 1px solid var(--line);
        text-align: center;
      }
      .detailItem .icon{
        font-size: 13px;
        color: var(--gold);
        letter-spacing: 0.2em;
        text-transform: uppercase;
        margin-bottom: 12px;
        font-weight: 700;
      }
      .detailItem .val{
        font-family: var(--serif);
        font-size: 20px;
        color: #fff;
      }

      /* WATER STAGE (High-end water element) */
      .waterStage{
        position: relative;
        border: 1px solid var(--line-gold);
        background:
          radial-gradient(circle at 50% 10%, rgba(214,184,135,0.12), transparent 45%),
          radial-gradient(circle at 18% 55%, rgba(80,140,190,0.10), transparent 55%),
          radial-gradient(circle at 78% 65%, rgba(214,184,135,0.08), transparent 55%),
          linear-gradient(180deg, rgba(255,255,255,0.02), rgba(0,0,0,0.55));
        overflow: hidden;
      }

      /* Deep water base */
      .waterStage::before{
        content:"";
        position:absolute; inset:-40%;
        background:
          repeating-radial-gradient(circle at 35% 40%,
            rgba(255,255,255,0.045) 0px,
            rgba(255,255,255,0.045) 2px,
            rgba(0,0,0,0.0) 10px,
            rgba(0,0,0,0.0) 22px),
          repeating-radial-gradient(circle at 65% 60%,
            rgba(214,184,135,0.040) 0px,
            rgba(214,184,135,0.040) 2px,
            rgba(0,0,0,0.0) 12px,
            rgba(0,0,0,0.0) 26px),
          linear-gradient(180deg, rgba(6,10,18,0.0), rgba(6,10,18,0.72), rgba(0,0,0,0.88));
        opacity: 0.85;
        filter: blur(0.2px);
        transform: translate3d(0,0,0);
        animation: waterDrift 14s linear infinite;
        pointer-events:none;
      }

      /* Caustic shimmer */
      .waterStage::after{
        content:"";
        position:absolute; inset:-30%;
        background:
          conic-gradient(from 180deg at 50% 50%,
            rgba(214,184,135,0.00),
            rgba(214,184,135,0.10),
            rgba(120,175,225,0.06),
            rgba(214,184,135,0.10),
            rgba(214,184,135,0.00));
        opacity: 0.55;
        filter: blur(18px);
        mix-blend-mode: screen;
        animation: caustics 18s linear infinite;
        pointer-events:none;
      }

      .waterInner{
        position: relative;
        padding: 90px 70px;
        display: grid;
        grid-template-columns: 0.95fr 1.05fr;
        gap: 60px;
        z-index: 1;
      }

      .waterHorizon{
        position:absolute;
        left: 60px; right: 60px;
        top: 54px;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(214,184,135,0.55), transparent);
        opacity: 0.9;
        pointer-events:none;
      }

      .waterCopy{
        border-left: 1px solid rgba(214,184,135,0.22);
        padding-left: 24px;
      }
      .waterKicker{
        font-family: var(--sans);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--gold);
        opacity: 0.95;
      }
      .waterTitle{
        margin: 14px 0 0;
        font-family: var(--serif);
        font-size: 44px;
        font-weight: 400;
        line-height: 1.05;
        color: #fff;
      }
      .waterLead{
        margin-top: 22px;
        font-size: 15px;
        line-height: 1.9;
        letter-spacing: 0.02em;
        color: rgba(240,242,245,0.70);
        max-width: 52ch;
      }
      .waterLead strong{
        font-weight: 700;
        color: rgba(214,184,135,0.92);
      }

      .facGrid{
        display:grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2px;
        background: rgba(214,184,135,0.30);
        border: 1px solid rgba(214,184,135,0.30);
      }
      .facItem{
        background: rgba(2,3,5,0.78);
        padding: 34px 28px;
        transition: background 0.35s ease;
      }
      .facItem:hover{
        background: rgba(13,15,20,0.86);
      }
      .facItem .k{
        font-family: var(--sans);
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: rgba(214,184,135,0.92);
      }
      .facItem .v{
        margin-top: 14px;
        font-family: var(--serif);
        font-size: 20px;
        font-weight: 400;
        color: rgba(255,255,255,0.92);
        line-height: 1.25;
      }

      .waterNote{
        margin-top: 26px;
        font-family: var(--sans);
        font-size: 13px;
        letter-spacing: 0.06em;
        color: rgba(255,255,255,0.55);
      }

      /* ANIMATIONS */
      .reveal{ opacity:0; transform:translateY(30px); transition: all 1s cubic-bezier(0.19, 1, 0.22, 1); }
      .reveal.on{ opacity:1; transform:translateY(0); }

      @keyframes waterDrift{
        0%{ transform: translate3d(-2%, -1%, 0) rotate(0.001deg); }
        50%{ transform: translate3d(2%, 1%, 0) rotate(0.001deg); }
        100%{ transform: translate3d(-2%, -1%, 0) rotate(0.001deg); }
      }
      @keyframes caustics{
        0%{ transform: translate3d(-2%, -1%, 0) rotate(0deg); }
        100%{ transform: translate3d(2%, 1%, 0) rotate(360deg); }
      }

      @media(max-width:900px){
        .heroGrid{ grid-template-columns: 1fr; gap: 40px; }
        .grid{ grid-template-columns: 1fr; }
        .detailGrid{ grid-template-columns: 1fr 1fr; }
        .detailItem{ border-bottom: 1px solid var(--line); }
        .visual{ height: 320px; }

        .waterInner{
          grid-template-columns: 1fr;
          padding: 70px 26px;
          gap: 34px;
        }
        .waterHorizon{ left: 26px; right: 26px; top: 38px; }
        .waterTitle{ font-size: 34px; }
        .facGrid{ grid-template-columns: 1fr; }
      }

      @media (prefers-reduced-motion: reduce){
        html,body{ scroll-behavior:auto; }
        .reveal{ opacity:1; transform:none; transition:none; }
        .waterStage::before, .waterStage::after{ animation:none; }
      }
    </style>
  </head>

  <body>
    <div class="wrap">
      <header class="topbar reveal">
        <div class="brand">
          <a href="/" class="back-link" aria-label="Back to Index">
            <svg viewBox="0 0 24 24"><path d="M3 3h7v7H3V3zm11 0h7v7h-7V3zm0 11h7v7h-7v-7zM3 14h7v7H3v-7z"/></svg>
          </a>
          <div class="name">{BRAND}</div>
        </div>
        <nav class="nav" aria-label="Primary">
          {NAV.map(n => <a href={n.href}>{n.label}</a>)}
        </nav>
      </header>

      <main>
        <section class="hero">
          <div class="heroGrid">
            <div class="content reveal">
              <h1 class="h1">Cross oceans. <br><span>Keep your peace.</span></h1>
              <p class="lead">
                No buffet stampede. No loud decks. No chaos.
                Just an all suite ship, salt air, and a crew that moves like clockwork.
              </p>
              <div class="actions">
                <a href="#voyages" class="btn primary" aria-label="View crossings">View Crossings</a>
                <a href="/contact" class="btn secondary" aria-label="Request a private itinerary">Request Itinerary</a>
              </div>
            </div>

            <div class="visual reveal" aria-label="Luxury maritime emblem">
              <div class="hud" aria-hidden="true">
                <div class="hud-label">Flagship</div>
                <div class="hud-val">Odyssey I</div>
              </div>

              <svg class="shipSvg" viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Overseas Line crest">
                <defs>
                  <linearGradient id="goldMetal" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#BF9B6B" />
                    <stop offset="50%" stop-color="#D6B887" />
                    <stop offset="100%" stop-color="#A38353" />
                  </linearGradient>
                  <filter id="goldGlow" x="-20%" y="-20%" width="140%" height="140%">
                    <feGaussianBlur stdDeviation="3" result="blur" />
                    <feComposite in="SourceGraphic" in2="blur" operator="over" />
                  </filter>
                </defs>

                <g filter="url(#goldGlow)">
                  <circle cx="250" cy="250" r="230" fill="none" stroke="url(#goldMetal)" stroke-width="2" opacity="0.6" />
                  <circle cx="250" cy="250" r="210" fill="none" stroke="url(#goldMetal)" stroke-width="1" stroke-dasharray="2 6" opacity="0.4" />

                  <path d="M250,20 L250,60 M250,440 L250,480 M20,250 L60,250 M440,250 L480,250" stroke="url(#goldMetal)" stroke-width="2" />

                  <circle cx="250" cy="250" r="160" fill="rgba(214, 184, 135, 0.05)" stroke="url(#goldMetal)" stroke-width="3" />

                  <g transform="translate(250, 250)">
                    <path d="M0,-100 C-40,-40 -80,20 0,80 C80,20 40,-40 0,-100 Z" fill="none" stroke="url(#goldMetal)" stroke-width="4" />
                    <path d="M0,-100 L0,80" stroke="url(#goldMetal)" stroke-width="2" />

                    <path d="M-120,40 Q-60,100 0,70 Q60,100 120,40" fill="none" stroke="url(#goldMetal)" stroke-width="3" opacity="0.8" />
                    <path d="M-140,70 Q-70,130 0,100 Q70,130 140,70" fill="none" stroke="url(#goldMetal)" stroke-width="2" opacity="0.6" />
                  </g>

                  <path id="textRing" d="M 250, 250 m -185, 0 a 185,185 0 1,1 370,0 a 185,185 0 1,1 -370,0" fill="none" />
                  <text fill="url(#goldMetal)" font-family="Times New Roman, serif" font-size="18" font-weight="600" letter-spacing="4">
                    <textPath xlink:href="#textRing" startOffset="50%" text-anchor="middle">
                      OVERSEAS LINE • PRIVATE CROSSINGS
                    </textPath>
                  </text>
                </g>
              </svg>
            </div>
          </div>
        </section>

        <section id="voyages" class="reveal" aria-label="Voyages">
          <div class="sectionHead">
            <h2>Upcoming Crossings</h2>
            <div class="tag">Cabins Limited</div>
          </div>

          <div class="grid">
            {VOYAGES.map(v => (
              <article class="card" aria-label={v.name}>
                <div class="kicker">{v.meta}</div>
                <div class="title">{v.name}</div>
                <div class="desc">Private shore planning included</div>
              </article>
            ))}
          </div>
        </section>

        <section id="details" class="reveal" aria-label="Details">
          <div class="detailGrid">
            {DETAILS.map(d => (
              <div class="detailItem" aria-label={d.title}>
                <div class="icon">{d.title}</div>
                <div class="val">{d.line}</div>
              </div>
            ))}
          </div>
        </section>

        <section id="facilities" class="reveal" aria-label="Facilities and high-end elements">
          <div class="sectionHead">
            <h2>Onboard Life</h2>
            <div class="tag">Quiet, on purpose</div>
          </div>

          <div class="waterStage">
            <div class="waterHorizon" aria-hidden="true"></div>

            <div class="waterInner">
              <div class="waterCopy">
                <div class="waterKicker">ONBOARD CONTROL</div>
                <div class="waterTitle">A ship that feels like a private club.</div>
                <div class="waterLead">
                  Everything is built around <strong>space</strong>, <strong>silence</strong>, and <strong>recovery</strong>.
                  You do not fight for a chair, you do not wait for service, you do not get dragged into someone else’s vacation.
                </div>
                <div class="waterNote">Appointment led access. Soft sound. Low light after dusk.</div>
              </div>

              <div class="facGrid" aria-label="Facilities grid">
                {FACILITIES.map(f => (
                  <div class="facItem" aria-label={f.title}>
                    <div class="k">{f.title}</div>
                    <div class="v">{f.line}</div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </section>

      </main>
    </div>

    <script>
      (function () {
        var reduce = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (reduce) return;

        var obs = new IntersectionObserver(function(entries){
          entries.forEach(function(e){
            if (e.isIntersecting) e.target.classList.add('on');
          });
        }, {threshold:0.1});

        document.querySelectorAll('.reveal').forEach(function(el){ obs.observe(el); });
      })();
    </script>
  </body>
</html>

---
const BRAND = "FIELD STUDIO";

const NAV = [
  { label: "Archive", href: "#specimens" },
  { label: "Field Trail", href: "#trail" },
  { label: "Visit / Contact", href: "#visit" },
];

const SEASONS = [
  { key: "dawn", label: "Dawn", note: "Mist lift. Pollen rise. Slow drift." },
  { key: "canopy", label: "Canopy", note: "Green density. Spore traffic. Active air." },
  { key: "dusk", label: "Dusk", note: "Blue falloff. Cold pockets. Fast flow." },
];

const SPECIMENS = [
  { title: "Canopy Resin", line: "Archival sap cast from a summer canopy survey.", id: "FIG.01" },
  { title: "River Glass", line: "Tumbled fragments logged from a floodplain transect.", id: "FIG.02" },
  { title: "Pollen Drift", line: "Airborne sample notes—movement traced, not forced.", id: "FIG.03" },
  { title: "Root Map", line: "Subsurface structure mapped from ground-penetration passes.", id: "FIG.04" },
];

const TRAIL = [
  { title: "Wind", line: "Microclimate first. We design for direction, not volume.", type: "wind" },
  { title: "Water", line: "Time is a tool. Flow, filtration, and patience shape the work.", type: "water" },
  { title: "Light", line: "Contrast with restraint. Reveal only what needs to be seen.", type: "light" },
];

const HERO_IMG =
  "https://images.unsplash.com/photo-1441974231531-c6227db76b6e?auto=format&fit=crop&w=2000&q=80"; 
const SECONDARY_IMG =
  "https://images.unsplash.com/photo-1470071459604-3b5ec3a7fe05?auto=format&fit=crop&w=1600&q=80"; 
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{BRAND} — Living Systems Studio</title>
    <meta name="description" content="Field Studio documents living systems and builds calm, high-density interfaces—season-tuned, sensor-aware, and archive-led." />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400&display=swap"
      rel="stylesheet"
    />

    <style>
      :root{
        /* Default: CANOPY */
        --bg0:#040a07;
        --bg1:#07150f;
        --ink: #ebf2ec;
        --ink-dim: rgba(235, 242, 236, 0.6);

        --accent:#9BE27D;      /* chlorophyll */
        --accent2:#E0C07A;     /* pollen */
        
        --line: rgba(255, 255, 255, 0.08);
        --line-strong: rgba(255, 255, 255, 0.15);

        --serif: "Fraunces", serif;
        --sans: "Inter", system-ui, sans-serif;
        --mono: "JetBrains Mono", monospace;

        --radius: 2px;
        --max: 1300px;
        --pad: clamp(20px, 5vw, 64px);
      }

      *{ box-sizing:border-box; }
      html,body{ height:100%; scroll-behavior:smooth; }
      body{
        margin:0;
        color:var(--ink);
        font-family:var(--sans);
        background: var(--bg0);
        transition: background-color 0.8s ease;
        overflow-x:hidden;
      }

      /* Bio-Swarm Canvas (Fixed Fullscreen) */
      #bio-swarm{
        position:fixed; top:0; left:0; width:100vw; height:100vh;
        z-index:1; pointer-events:none;
        mix-blend-mode: screen; 
      }

      /* Texture Overlay */
      body::before{
        content:""; position:fixed; inset:0;
        background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 240 240' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.7' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
        pointer-events:none; mix-blend-mode: overlay; z-index:0;
      }

      a{ color:inherit; text-decoration:none; }

      .wrap{
        position:relative; z-index:5;
        max-width:var(--max); margin:0 auto;
        padding: 0 var(--pad) 140px;
      }

      /* SYSTEM EXIT BUTTON */
      .sys-exit{
        position: fixed; top: 20px; left: 20px; z-index: 100;
        display:flex; align-items:center; gap: 8px;
        padding: 8px 14px; border-radius: 999px;
        border: 1px solid rgba(255,255,255,.12);
        background: rgba(4,10,7,.85);
        backdrop-filter: blur(8px);
        font-family: var(--mono); font-size: 10px; letter-spacing: .12em;
        text-transform: uppercase; color: rgba(235,242,236,.6);
        transition: all .2s ease;
      }
      .sys-exit:hover{
        border-color: var(--accent); color: var(--accent);
        box-shadow: 0 0 20px var(--accent);
      }

      /* Navigation */
      .topbar{
        display:flex; justify-content:space-between; align-items:flex-end;
        padding: 32px 0 60px; border-bottom: 1px solid var(--line);
      }
      .brand{
        display:flex; flex-direction:column; gap:4px;
      }
      .brand .name{
        font-family:var(--serif); font-size: 24px; font-weight:400; letter-spacing: -0.02em;
      }
      .brand .meta{
        font-family:var(--mono); font-size: 10px; letter-spacing: .2em; text-transform: uppercase;
        color: var(--accent); opacity: 0.8;
      }
      .nav{ display:flex; gap:32px; }
      .nav a{
        font-family: var(--mono); font-size: 11px; letter-spacing:.15em; text-transform:uppercase;
        color: rgba(235,242,236,.5); position: relative;
      }
      .nav a::after{
        content:""; position: absolute; bottom: -4px; left:0; width: 0%; height: 1px;
        background: var(--accent); transition: width 0.3s ease;
      }
      .nav a:hover{ color: #fff; }
      .nav a:hover::after{ width: 100%; }

      /* HERO SECTION */
      .fracture{
        display:grid; grid-template-columns: 1fr 0.8fr;
        gap: clamp(24px, 5vw, 80px); align-items: start;
        margin-top: 60px; min-height: 80vh;
      }

      .hero-content{ padding-top: 40px; position:relative; z-index: 2; }
      .h1{
        font-family:var(--serif); font-weight: 300; font-size: clamp(60px, 9vw, 130px);
        line-height: 0.9; letter-spacing: -0.04em; margin: 0 0 40px;
        color: #fff;
      }
      .h1 i{
        font-style: italic; font-weight: 400;
        color: var(--accent);
        text-shadow: 0 0 30px var(--accent);
        transition: color 0.5s ease, text-shadow 0.5s ease;
      }

      .lead{
        font-size: 18px; line-height: 1.6; color: var(--ink-dim); max-width: 44ch;
        margin-bottom: 60px; font-weight: 300;
      }

      /* Season Dial */
      .dial-block{
        display: flex; flex-direction: column; gap: 16px;
        border-top: 1px solid var(--line); padding-top: 24px;
        width: max-content;
      }
      .dial-label{
        font-family: var(--mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.2em; color: var(--ink-dim);
      }
      .dial-ui{
        display: inline-flex; align-items: center; gap: 4px;
        padding: 4px; border-radius: 999px;
        background: rgba(255,255,255,0.03); border: 1px solid var(--line);
        backdrop-filter: blur(12px);
      }
      .dial-btn{
        appearance: none; border: none; background: transparent;
        color: rgba(235,242,236,0.5); font-family: var(--mono); font-size: 11px;
        letter-spacing: .1em; text-transform: uppercase; padding: 12px 20px;
        border-radius: 999px; cursor: pointer; transition: all 0.3s;
      }
      .dial-btn:hover{ color: #fff; background: rgba(255,255,255,0.05); }
      .dial-btn[aria-pressed="true"]{
        background: var(--ink); color: #000; font-weight: 600;
        box-shadow: 0 0 25px var(--accent);
      }

      /* Hero Visual - Organic Aperture Effect */
      .visual-wrap{
        position: relative; z-index: 2; padding-top: 100px;
        filter: drop-shadow(0 30px 60px rgba(0,0,0,0.5));
      }
      .visual-card{
        position: relative; height: 650px; overflow: hidden; background: #000;
        clip-path: polygon(8% 5%, 92% 0%, 100% 85%, 85% 100%, 10% 95%);
        transition: clip-path 1s cubic-bezier(0.19, 1, 0.22, 1), transform 1s cubic-bezier(0.19, 1, 0.22, 1);
      }
      .visual-card:hover{
        clip-path: polygon(2% 2%, 98% 2%, 98% 98%, 50% 96%, 2% 98%);
        transform: scale(1.02);
      }
      .visual-card img{
        width: 100%; height: 100%; object-fit: cover;
        filter: saturate(0.8) contrast(1.1); transition: filter 0.5s, transform 1s; transform: scale(1.1);
      }
      .visual-card:hover img{ filter: saturate(1.2) contrast(1.1); transform: scale(1); }

      /* SPECIMENS: Glass Slides */
      .specs-wrap{ margin-top: 180px; position: relative; }
      .specs-head{
        font-family: var(--mono); font-size: 12px; letter-spacing: .2em;
        text-transform: uppercase; color: var(--accent); margin-bottom: 60px;
        border-bottom: 1px solid var(--line); padding-bottom: 20px;
        display: flex; justify-content: space-between;
      }

      .specs-grid{
        display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px;
      }
      .spec-card{
        position: relative;
        background: rgba(10, 20, 15, 0.6);
        border: 1px solid var(--line);
        border-top: 1px solid rgba(255,255,255,0.15);
        padding: 24px; height: 320px;
        display: flex; flex-direction: column; justify-content: space-between;
        transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        backdrop-filter: blur(8px);
        overflow: hidden;
      }
      .spec-card::before {
        content: ""; position: absolute; inset: 0;
        background: radial-gradient(circle at 50% 30%, var(--accent), transparent 60%);
        opacity: 0; transition: opacity 0.4s ease; mix-blend-mode: overlay; pointer-events: none;
      }
      .spec-card:hover{
        transform: translateY(-10px); border-color: var(--accent);
        box-shadow: 0 20px 40px -10px rgba(0,0,0,0.5);
      }
      .spec-card:hover::before { opacity: 0.3; }

      .spec-meta{
        display: flex; justify-content: space-between; font-family: var(--mono);
        font-size: 10px; color: rgba(255,255,255,0.4); border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 12px;
      }
      .spec-body h3{
        font-family: var(--serif); font-size: 28px; line-height: 1; margin: 0 0 12px; font-weight: 300;
      }
      .spec-body p{
        font-family: var(--sans); font-size: 14px; color: var(--ink-dim); line-height: 1.5; margin: 0;
      }

      .spec-card:nth-child(2) { margin-top: 60px; }
      .spec-card:nth-child(3) { margin-top: -40px; }
      .spec-card:nth-child(4) { margin-top: 80px; }

      /* TRAIL: Interactive Kinetic Resonance */
      .trail-wrap{ margin-top: 200px; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
      
      .trail-list{ position: relative; padding-left: 40px; }
      /* The connecting line */
      .trail-list::before {
        content:""; position: absolute; left: 0; top: 20px; bottom: 20px; width: 1px;
        background: linear-gradient(180deg, var(--accent), transparent); opacity: 0.3;
      }

      .trail-item{ 
        margin-bottom: 80px; position: relative; cursor: default;
        transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.19, 1, 0.22, 1);
      }
      
      /* Marker */
      .trail-marker{
        position: absolute; left: -44px; top: 12px; width: 9px; height: 9px;
        border-radius: 50%; background: var(--bg0); border: 1px solid var(--accent);
        box-shadow: 0 0 0px var(--accent);
        transition: all 0.3s ease;
      }
      .trail-item h3{
        font-family: var(--serif); font-size: 42px; font-weight: 300; margin: 0 0 16px; color: #fff;
        transition: color 0.3s ease;
      }
      .trail-item p{ color: var(--ink-dim); font-size: 16px; max-width: 38ch; margin: 0; line-height: 1.7; transition: color 0.3s; }

      /* Interactive States (Focus Mode) */
      .trail-list:hover .trail-item { opacity: 0.3; } /* Dim all by default on list hover */
      .trail-list .trail-item:hover { 
        opacity: 1; transform: translateX(10px); 
      }
      .trail-list .trail-item:hover .trail-marker {
        background: var(--accent); box-shadow: 0 0 20px var(--accent); border-color: #fff; transform: scale(1.3);
      }
      .trail-list .trail-item:hover h3 { color: var(--accent); }

      /* The Visual Coupling */
      .trail-vis{
        position: relative; border-radius: 4px; overflow: hidden;
        height: 600px; transform: rotate(-1deg);
        border: 1px solid var(--line);
        transition: border-color 0.5s ease;
      }
      .trail-vis img{
        width: 100%; height: 100%; object-fit: cover; 
        filter: grayscale(0.4) sepia(0.2) contrast(0.9);
        transition: filter 0.6s cubic-bezier(0.19, 1, 0.22, 1), transform 0.8s ease;
        transform: scale(1);
      }

      /* Coupling States (Triggered by JS) */
      /* WIND State */
      .trail-vis.state-wind { border-color: rgba(255,255,255,0.3); }
      .trail-vis.state-wind img {
        filter: blur(4px) brightness(1.2) grayscale(0.8);
        transform: scale(1.1) skewX(-2deg);
      }
      
      /* WATER State */
      .trail-vis.state-water { border-color: var(--accent); }
      .trail-vis.state-water img {
        filter: saturate(1.5) contrast(1.1) brightness(0.9) hue-rotate(-10deg);
        transform: scale(1.05);
      }

      /* LIGHT State */
      .trail-vis.state-light { border-color: #fff; }
      .trail-vis.state-light img {
        filter: brightness(1.6) contrast(1.2) sepia(0.1);
        transform: scale(1.02);
      }

      /* FOOTER */
      .footer{
        margin-top: 160px; padding: 80px 0 40px; border-top: 1px solid var(--line);
        position: relative;
      }
      .foot-big{
        font-family: var(--serif); font-size: clamp(60px, 12vw, 200px);
        line-height: 0.8; color: var(--line); text-align: center;
        letter-spacing: -0.04em; margin-bottom: 60px;
        transition: color 0.3s; cursor: default;
      }
      .foot-big:hover { color: var(--accent); }
      
      .foot-bottom{
        display: flex; justify-content: space-between; align-items: flex-end;
      }
      .foot-contact{
        font-family: var(--mono); font-size: 12px; color: var(--accent); text-transform: uppercase; letter-spacing: .1em;
        text-decoration: underline; text-underline-offset: 4px;
      }

      @media (max-width: 900px){
        .fracture, .specs-grid, .trail-wrap{ grid-template-columns: 1fr; }
        .visual-wrap{ padding-top: 0; height: 400px; }
        .visual-card { height: 100%; }
        .spec-card{ margin-top: 0 !important; }
        .h1{ font-size: 14vw; }
        .trail-list{ padding-left: 20px; border-left: 1px solid var(--accent); }
        .trail-list::before{ display: none; }
        .trail-marker{ left: -25px; }
      }
    </style>
  </head>

  <body>
    <canvas id="bio-swarm" aria-hidden="true"></canvas>

    <a href="/" class="sys-exit"><i>[</i> EXIT <i>]</i></a>

    <div class="wrap">
      <header class="topbar">
        <div class="brand">
          <div class="name">{BRAND}</div>
          <div class="meta">Field Notes v16.3</div>
        </div>
        <nav class="nav">
          {NAV.map(n => <a href={n.href}>{n.label}</a>)}
        </nav>
      </header>

      <main>
        <section class="fracture">
          <div class="hero-content">
            <h1 class="h1">Landscapes as a <br><i>living system.</i></h1>
            <p class="lead">
              We document forest structure, air movement, and water logic—then translate it into interfaces that feel alive without feeling busy.
              The swarm layer is our ambient field: season-tuned drift, cursor-aware proximity, always calm.
            </p>

            <div class="dial-block">
              <span class="dial-label">Season Profile</span>
              <div class="dial-ui" role="group" aria-label="Season Control">
                {SEASONS.map(s => (
                  <button class="dial-btn" data-season={s.key} aria-pressed={s.key === 'canopy' ? 'true' : 'false'}>
                    {s.label}
                  </button>
                ))}
              </div>
            </div>
          </div>

          <div class="visual-wrap">
            <div class="visual-card">
              <img src={HERO_IMG} alt="Dense forest canopy" />
              <div class="card-tag" style="position:absolute; bottom:20px; left:20px; font-family:var(--mono); font-size:10px; color:white; background:rgba(0,0,0,0.5); padding:4px 8px;">CAPTURE // ACTIVE</div>
            </div>
          </div>
        </section>

        <section class="specs-wrap" id="specimens">
          <div class="specs-head">
            <span>Specimen Archive</span>
            <span>Log: 24.08</span>
          </div>
          <div class="specs-grid">
            {SPECIMENS.map(s => (
              <article class="spec-card">
                <div class="spec-meta">
                  <span>{s.id}</span>
                  <span>ARCHIVED</span>
                </div>
                <div class="spec-body">
                  <h3>{s.title}</h3>
                  <p>{s.line}</p>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="trail-wrap" id="trail">
          <div class="trail-list" id="trail-list">
            {TRAIL.map(t => (
              <div class="trail-item" data-type={t.type}>
                <div class="trail-marker"></div>
                <h3>{t.title}</h3>
                <p>{t.line}</p>
              </div>
            ))}
          </div>
          <div class="trail-vis" id="trail-vis">
            <img src={SECONDARY_IMG} alt="Atmospheric fog" />
          </div>
        </section>

        <footer class="footer" id="visit">
          <div class="foot-big">FIELD STUDIO</div>
          <div class="foot-bottom">
            <div style="font-family:var(--mono); font-size:11px; color:rgba(255,255,255,0.4);">
              &copy; 2026 FIELD STUDIO
            </div>
            <a href="mailto:hello@field.studio" class="foot-contact">Start an intake</a>
          </div>
        </footer>
      </main>
    </div>

    <script>
      // High-Density Bio-Swarm System
      (function () {
        const canvas = document.getElementById("bio-swarm") as HTMLCanvasElement;
        const ctx = canvas.getContext("2d", { alpha: true });
        if (!ctx) return;

        let w = 0, h = 0;
        let dpr = 1;
        const count = 3500; 
        
        const x = new Float32Array(count);
        const y = new Float32Array(count);
        const vx = new Float32Array(count);
        const vy = new Float32Array(count);
        const s = new Float32Array(count);
        const l = new Float32Array(count);

        let speedMult = 1.0;
        let turbulence = 0.5;
        let windX = 0.2;
        let accentColor = { r: 155, g: 226, b: 125 }; // Default Canopy (Neon Green)

        const resize = () => {
          w = window.innerWidth;
          h = window.innerHeight;
          dpr = Math.min(2, window.devicePixelRatio || 1);
          canvas.width = w * dpr;
          canvas.height = h * dpr;
          canvas.style.width = w + "px";
          canvas.style.height = h + "px";
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        };
        window.addEventListener("resize", resize);
        resize();

        for(let i=0; i<count; i++) {
          x[i] = Math.random() * w;
          y[i] = Math.random() * h;
          vx[i] = (Math.random() - 0.5) * 0.5;
          vy[i] = (Math.random() * 0.5) + 0.1;
          s[i] = Math.random() * 2.5; 
          l[i] = Math.random();
        }

        let mx = w/2, my = h/2;
        window.addEventListener("mousemove", (e) => {
          mx = e.clientX;
          my = e.clientY;
        });

        const loop = () => {
          ctx.clearRect(0, 0, w, h);
          ctx.shadowBlur = 4;
          ctx.shadowColor = `rgb(${accentColor.r},${accentColor.g},${accentColor.b})`;

          for(let i=0; i<count; i++) {
            vx[i] += (Math.random() - 0.5) * 0.02 * turbulence;
            vy[i] += (Math.random() - 0.5) * 0.02 * turbulence;
            x[i] += (vx[i] + windX) * speedMult;
            y[i] += (vy[i] + 0.2) * speedMult;

            const dx = x[i] - mx;
            const dy = y[i] - my;
            const dist = Math.sqrt(dx*dx + dy*dy);
            if(dist < 150) {
              const force = (150 - dist) / 150;
              x[i] += (dx / dist) * force * 5;
              y[i] += (dy / dist) * force * 5;
            }

            if(x[i] > w) x[i] = -10;
            if(x[i] < -10) x[i] = w;
            if(y[i] > h) y[i] = -10;
            
            ctx.fillStyle = `rgba(${accentColor.r},${accentColor.g},${accentColor.b},${l[i] * 0.7})`;
            ctx.beginPath();
            ctx.arc(x[i], y[i], s[i], 0, Math.PI*2);
            ctx.fill();
          }
          requestAnimationFrame(loop);
        };
        loop();

        // Season Logic
        const btns = document.querySelectorAll(".dial-btn");
        btns.forEach(btn => {
          btn.addEventListener("click", (e) => {
            const target = e.target as HTMLElement;
            const key = target.dataset.season;
            btns.forEach(b => b.setAttribute("aria-pressed", "false"));
            target.setAttribute("aria-pressed", "true");

            if(key === "dawn") {
              speedMult = 0.4; turbulence = 0.2; windX = 0.1;
              accentColor = { r: 255, g: 190, b: 60 }; 
              document.documentElement.style.setProperty("--accent", "#FFBE3C");
              document.documentElement.style.setProperty("--bg0", "#080600");
            } else if (key === "canopy") {
              speedMult = 1.0; turbulence = 0.5; windX = 0.2;
              accentColor = { r: 155, g: 226, b: 125 };
              document.documentElement.style.setProperty("--accent", "#9BE27D");
              document.documentElement.style.setProperty("--bg0", "#040a07");
            } else if (key === "dusk") {
              speedMult = 1.8; turbulence = 0.9; windX = 0.8;
              accentColor = { r: 60, g: 200, b: 255 }; 
              document.documentElement.style.setProperty("--accent", "#3CC8FF");
              document.documentElement.style.setProperty("--bg0", "#02030a");
            }
          });
        });

        // TRAIL INTERACTIVITY (Kinetic Resonance)
        const trailList = document.getElementById("trail-list");
        const trailVis = document.getElementById("trail-vis");
        const items = document.querySelectorAll(".trail-item");

        if(trailList && trailVis) {
          items.forEach(item => {
            item.addEventListener("mouseenter", () => {
              const type = (item as HTMLElement).dataset.type;
              trailVis.classList.remove("state-wind", "state-water", "state-light");
              if(type) trailVis.classList.add(`state-${type}`);
            });
          });

          trailList.addEventListener("mouseleave", () => {
            trailVis.classList.remove("state-wind", "state-water", "state-light");
          });
        }

      })();
    </script>
  </body>
</html>

---
const BRAND = "LIGNUM ATELIER";

const NAV = [
  { label: "Collection", href: "#collection" },
  { label: "Materials", href: "#materials" },
  { label: "Process", href: "#process" },
  { label: "Studio", href: "#studio" },
];

const SWATCHES = [
  { name: "Burnt Oak", origin: "France", color: "linear-gradient(135deg, #4a3b32, #2e241e)" },
  { name: "Santos Rosewood", origin: "Brazil", color: "linear-gradient(135deg, #6e3b2e, #4a2218)" },
  { name: "Macassar Ebony", origin: "Indonesia", color: "linear-gradient(135deg, #222, #111, #332a22)" },
  { name: "American Walnut", origin: "Missouri", color: "linear-gradient(135deg, #5d4037, #3e2723)" },
];

const PROJECTS = [
  { id: "01", title: "Kyoto Tea House", type: "Cladding" },
  { id: "02", title: "Vessel Library", type: "Joinery" },
  { id: "03", title: "Aesop Counter", type: "Furniture" },
  { id: "04", title: "Obsidian Bar", type: "Fit-out" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{BRAND} — Master Joinery</title>
    <meta
      name="description"
      content="LIGNUM ATELIER designs and builds heirloom woodwork: a grain library, precision joinery, and quiet finishes that deepen with time."
    />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;700&family=Manrope:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
      :root{
        /* DARK LUXURY PALETTE */
        --bg: #0f0805;
        
        /* Metals */
        --gold: #d4af37;
        --gold-dim: #8a7035;
        --brass: #bfa065;
        --brass-dark: #6e5025;
        --brass-line: rgba(191, 160, 101, 0.15);
        
        /* Text & Panels */
        --ink: #eaddcf;       
        --ink-dim: #8c867d;   
        --panel-bg: rgba(15, 8, 5, 0.7);

        --font-serif: 'Cinzel', serif;
        --font-sans: 'Manrope', sans-serif;
        
        --max: 1200px;
        --pad: clamp(20px, 4vw, 56px);
        
        /* Interactive Lighting */
        --lx: 50%; --ly: 50%;
      }

      *{ box-sizing:border-box; }
      html,body{ height:100%; margin:0; scroll-behavior:smooth; }

      body{
        background-color: var(--bg);
        color: var(--ink);
        font-family: var(--font-sans);
        overflow-x: hidden;
      }

      /* --- ENGINE LAYERS --- */
      #woodCanvas { position: fixed; inset: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; }
      .vignette {
        position: fixed; inset: 0; z-index: 1; pointer-events: none;
        background: radial-gradient(circle at var(--lx) var(--ly), transparent 15%, rgba(5,3,2,0.5) 80%, #050302 100%);
        mix-blend-mode: multiply;
      }
      .highlight-layer {
        position: fixed; inset: 0; z-index: 1; pointer-events: none;
        background: radial-gradient(800px circle at var(--lx) var(--ly), rgba(255,255,255,0.07), transparent 60%);
        mix-blend-mode: overlay;
      }

      /* --- UI COMPONENTS --- */
      .wrap { position: relative; z-index: 5; max-width: var(--max); margin: 0 auto; padding: 0 var(--pad); }

      .back-nav {
        position: fixed; top: 30px; left: 30px; z-index: 100;
        width: 40px; height: 40px; display: grid; place-items: center;
        border: 1px solid var(--brass-dark); border-radius: 50%;
        color: var(--brass); background: rgba(0,0,0,0.4);
        backdrop-filter: blur(4px); transition: all 0.3s;
      }
      .back-nav:hover { border-color: var(--gold); color: var(--gold); box-shadow: 0 0 15px rgba(212,175,55,0.2); }

      header {
        display: flex; justify-content: space-between; align-items: flex-end;
        padding: 40px 0; border-bottom: 1px solid var(--brass-line); margin-bottom: 80px;
      }
      .brand { font-family: var(--font-serif); font-size: 24px; letter-spacing: 0.1em; color: var(--gold); text-shadow: 0 2px 10px rgba(0,0,0,0.8); }
      nav { display: flex; gap: 40px; }
      nav a { font-size: 11px; text-transform: uppercase; letter-spacing: 0.2em; color: var(--brass); text-decoration: none; transition: color 0.3s; }
      nav a:hover { color: var(--ink); text-shadow: 0 0 8px var(--gold); }

      /* --- SECTIONS --- */
      
      /* HERO */
      .hero { min-height: 80vh; display: flex; flex-direction: column; justify-content: center; position: relative; }
      .hero-content { border-left: 1px solid var(--brass-line); padding-left: 40px; max-width: 800px; }
      h1 {
        font-family: var(--font-serif); font-size: clamp(48px, 7vw, 110px);
        line-height: 0.9; margin: 0 0 40px; color: var(--ink);
        background: linear-gradient(135deg, #fff 20%, #d4af37 80%);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        filter: drop-shadow(0 4px 10px rgba(0,0,0,0.8));
      }
      .hero-meta {
        font-size: 12px; letter-spacing: 0.3em; text-transform: uppercase; color: var(--brass); margin-bottom: 20px; display: block;
      }
      .lead { font-size: 18px; color: var(--ink-dim); max-width: 50ch; line-height: 1.7; margin-bottom: 60px; }
      
      .btn {
        display: inline-block; padding: 18px 40px;
        border: 1px solid var(--brass); color: var(--brass);
        font-size: 11px; letter-spacing: 0.25em; text-transform: uppercase;
        text-decoration: none; transition: all 0.3s;
        background: linear-gradient(90deg, transparent 50%, var(--brass) 50%);
        background-size: 200% 100%; background-position: 0% 0%;
      }
      .btn:hover { background-position: 100% 0%; color: #000; }

      /* MATERIAL VAULT */
      .vault { padding: 120px 0; border-top: 1px solid var(--brass-line); }
      .section-head { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 60px; }
      .section-title { font-family: var(--font-serif); font-size: 32px; color: var(--ink); margin: 0; }
      .section-sub { font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--brass-dark); }

      .swatch-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 40px; }
      .swatch-card {
        background: var(--panel-bg); backdrop-filter: blur(10px);
        padding: 30px; border: 1px solid var(--brass-line);
        transition: transform 0.3s, border-color 0.3s; cursor: pointer;
        text-align: center;
      }
      .swatch-card:hover { transform: translateY(-10px); border-color: var(--brass); }
      .swatch-circle {
        width: 120px; height: 120px; border-radius: 50%; margin: 0 auto 24px;
        box-shadow: inset 0 0 20px rgba(0,0,0,0.8), 0 10px 30px rgba(0,0,0,0.5);
        border: 1px solid rgba(255,255,255,0.1);
      }
      .swatch-name { font-family: var(--font-serif); font-size: 18px; color: var(--gold); display: block; margin-bottom: 6px; }
      .swatch-origin { font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-dim); }

      /* HORIZONTAL GALLERY */
      .gallery-section { padding: 100px 0; overflow: hidden; border-top: 1px solid var(--brass-line); }
      .gallery-track {
        display: flex; gap: 40px; overflow-x: auto; padding-bottom: 40px;
        scrollbar-width: none; /* Firefox */
      }
      .gallery-track::-webkit-scrollbar { display: none; }
      
      .gallery-item {
        min-width: 350px; height: 500px;
        background: var(--panel-bg); border: 1px solid var(--brass-line);
        display: flex; flex-direction: column; justify-content: space-between;
        padding: 40px; transition: 0.3s;
      }
      .gallery-item:hover { border-color: var(--gold); background: rgba(30, 20, 10, 0.8); }
      .gi-num { font-family: var(--font-serif); font-size: 48px; color: var(--brass-dark); opacity: 0.5; }
      .gi-title { font-family: var(--font-serif); font-size: 24px; color: var(--ink); margin-top: auto; }
      .gi-type { font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--brass); margin-top: 10px; }

      /* TECHNICAL DIAGRAM (The Etching) */
      .tech-section {
        padding: 120px 0; border-top: 1px solid var(--brass-line);
        display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;
      }
      .tech-drawing {
        height: 400px; border: 1px solid var(--brass-line);
        background: rgba(255,255,255,0.02);
        display: grid; place-items: center; position: relative;
      }
      /* Fake dimensions lines */
      .dim-line { position: absolute; background: var(--brass-dark); opacity: 0.5; }
      .dim-h { height: 1px; width: 100%; top: 50%; left: 0; }
      .dim-v { width: 1px; height: 100%; left: 50%; top: 0; }
      
      .tech-text h3 { font-family: var(--font-serif); font-size: 36px; color: var(--ink); margin: 0 0 20px; }
      .tech-text p { font-size: 15px; color: var(--ink-dim); line-height: 1.8; margin-bottom: 30px; }
      .tech-specs {
        display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
        border-top: 1px solid var(--brass-line); padding-top: 20px;
      }
      .ts-item span { display: block; }
      .ts-label { font-size: 10px; letter-spacing: 0.2em; color: var(--brass-dark); text-transform: uppercase; margin-bottom: 5px; }
      .ts-val { font-family: var(--font-serif); font-size: 16px; color: var(--gold); }

      /* QUOTE BLOCK */
      .quote-block {
        text-align: center; padding: 140px 0;
        background: radial-gradient(circle at center, rgba(212,175,55,0.05) 0%, transparent 60%);
      }
      blockquote {
        font-family: var(--font-serif); font-size: clamp(24px, 4vw, 42px);
        color: var(--ink); margin: 0; line-height: 1.4;
      }
      blockquote span { color: var(--brass); }
      .citation { display: block; margin-top: 30px; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-dim); }

      /* FOOTER */
      footer {
        padding: 80px 0 40px; border-top: 1px solid var(--brass-line);
        display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 40px;
      }
      .col h4 { font-family: var(--font-serif); font-size: 18px; color: var(--gold); margin: 0 0 20px; }
      .col ul { list-style: none; padding: 0; margin: 0; }
      .col li { margin-bottom: 12px; }
      .col a { font-size: 13px; color: var(--ink-dim); text-decoration: none; transition: 0.3s; }
      .col a:hover { color: var(--ink); }
      .f-copy { grid-column: 1 / -1; text-align: center; margin-top: 60px; font-size: 10px; text-transform: uppercase; letter-spacing: 0.2em; color: var(--brass-dark); }

      @media(max-width: 900px){
        .hero-content { border: none; padding: 0; text-align: center; }
        .tech-section { grid-template-columns: 1fr; }
        footer { grid-template-columns: 1fr; text-align: center; }
        nav { display: none; }
      }
    </style>
  </head>

  <body>
    <canvas id="woodCanvas"></canvas>
    <div class="vignette"></div>
    <div class="highlight-layer"></div>

    <a href="/" class="back-nav" aria-label="Return to Index">
      <svg viewBox="0 0 24 24" width="16" height="16"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
    </a>

    <div class="wrap">
      <header>
        <div class="brand">{BRAND}</div>
        <nav>{NAV.map(n => <a href={n.href}>{n.label}</a>)}</nav>
      </header>

      <main>
        <section class="hero" id="studio">
          <div class="hero-content">
            <span class="hero-meta">Handbuilt Woodwork • Grain Library • Bespoke Commissions</span>
            <h1>Wood, made<br><em>architectural.</em></h1>
            <p class="lead">
              We build with timber the way watchmakers build with steel: measured, patient, exact.
              From fitted interiors to standalone pieces—every joint is designed to outlast trends,
              and every finish is chosen to deepen with touch and time.
            </p>
            <a href="#collection" class="btn">View The Collection</a>
          </div>
        </section>

        <section id="materials" class="vault">
          <div class="section-head">
            <h2 class="section-title">The Grain Vault</h2>
            <span class="section-sub">Reserves & Veneers</span>
          </div>
          <div class="swatch-grid">
            {SWATCHES.map(s => (
              <div class="swatch-card">
                <div class="swatch-circle" style={`background: ${s.color};`}></div>
                <span class="swatch-name">{s.name}</span>
                <span class="swatch-origin">Origin: {s.origin}</span>
              </div>
            ))}
          </div>
        </section>

        <section id="process" class="tech-section">
          <div class="tech-drawing">
            <div class="dim-h"></div> <div class="dim-v"></div>
            <svg width="200" height="200" viewBox="0 0 100 100" style="opacity:0.8;">
              <path d="M20,20 L80,20 L70,80 L30,80 Z" fill="none" stroke="var(--gold)" stroke-width="0.5" />
              <path d="M30,80 L30,100 M70,80 L70,100" fill="none" stroke="var(--brass)" stroke-width="0.5" />
              <path d="M20,20 L20,0 M80,20 L80,0" fill="none" stroke="var(--brass)" stroke-width="0.5" />
              <circle cx="50" cy="50" r="2" fill="var(--gold)" />
            </svg>
          </div>
          <div class="tech-text">
            <h3>Joinery, not hardware.</h3>
            <p>
              Timber moves. Good joinery anticipates it.
              We cut housings, mortises, and dovetails that stay true through humidity cycles,
              keeping surfaces flat and edges aligned. Metal appears only when it has a job—
              concealed where possible, celebrated where it belongs.
            </p>
            <div class="tech-specs">
              <div class="ts-item">
                <span class="ts-label">Joint tolerance</span>
                <span class="ts-val">0.5mm</span>
              </div>
              <div class="ts-item">
                <span class="ts-label">Finish system</span>
                <span class="ts-val">Tung Oil</span>
              </div>
            </div>
          </div>
        </section>

        <section id="collection" class="gallery-section">
          <div class="section-head">
            <h2 class="section-title">Commission Index</h2>
            <span class="section-sub">Selected Works</span>
          </div>
          <div class="gallery-track">
            {PROJECTS.map(p => (
              <div class="gallery-item">
                <div class="gi-num">{p.id}</div>
                <div>
                  <div class="gi-title">{p.title}</div>
                  <div class="gi-type">{p.type}</div>
                </div>
              </div>
            ))}
          </div>
        </section>

        <section class="quote-block">
          <blockquote>
            “The mark of craft is not decoration—<br/>
            it’s <span>alignment</span>, under every kind of light.”
          </blockquote>
          <span class="citation">Studio Notes • Lignum Atelier</span>
        </section>

        <footer>
          <div class="col">
            <h4>Atelier</h4>
            <ul>
              <li><a href="#">Philosophy</a></li>
              <li><a href="#">Care & Patina</a></li>
              <li><a href="#">Material Sourcing</a></li>
            </ul>
          </div>
          <div class="col">
            <h4>Commissions</h4>
            <ul>
              <li><a href="#">Residential Fit-outs</a></li>
              <li><a href="#">Hospitality & Retail</a></li>
              <li><a href="#">One-off Pieces</a></li>
            </ul>
          </div>
          <div class="col">
            <h4>Inquiries</h4>
            <ul>
              <li><a href="#">Request a Quote</a></li>
              <li><a href="#">Studio Visits</a></li>
              <li><a href="#">Press Kit</a></li>
            </ul>
          </div>
          <div class="f-copy">&copy; 2024 Lignum Atelier • Heirloom woodwork • Built to age well</div>
        </footer>
      </main>
    </div>

    <script is:inline>
      // @ts-nocheck
      (function(){
        // 1. LIGHT TRACKING
        document.addEventListener('mousemove', (e) => {
          const x = (e.clientX / window.innerWidth) * 100;
          const y = (e.clientY / window.innerHeight) * 100;
          document.documentElement.style.setProperty('--lx', `${x}%`);
          document.documentElement.style.setProperty('--ly', `${y}%`);
        });

        // 2. WOOD ENGINE (Optimized)
        const canvas = document.getElementById('woodCanvas');
        if(!canvas) return;
        const ctx = canvas.getContext('2d');
        let width, height;

        function resize() {
          width = window.innerWidth;
          height = window.innerHeight;
          canvas.width = width;
          canvas.height = height;
          renderWood();
        }
        window.addEventListener('resize', resize);
        
        function lerp(a, b, t) { return a + (b - a) * t; }
        function fract(x) { return x - Math.floor(x); }
        function hash(n) { return fract(Math.sin(n) * 43758.5453123); }
        function noise(x, y) {
            const ix = Math.floor(x), iy = Math.floor(y);
            const fx = x - ix, fy = y - iy;
            const a = hash(ix + iy * 57);
            const b = hash(ix + 1 + iy * 57);
            const c = hash(ix + (iy + 1) * 57);
            const d = hash(ix + 1 + (iy + 1) * 57);
            const ux = fx * fx * (3 - 2 * fx);
            const uy = fy * fy * (3 - 2 * fy);
            return lerp(lerp(a, b, ux), lerp(c, d, ux), uy);
        }

        function fbm(x, y) {
            let total = 0, amp = 0.5, freq = 1.0;
            for(let i = 0; i < 5; i++) {
                total += noise(x * freq, y * freq) * amp;
                freq *= 2.0; amp *= 0.5;
            }
            return total;
        }

        function pattern(x, y) {
            const qx = fbm(x, y);
            const qy = fbm(x + 5.2, y + 1.3);
            const rx = fbm(x + 4.0 * qx + 1.7, y + 4.0 * qy + 9.2);
            return fbm(x + 4.0 * rx, y + 4.0 * rx);
        }

        function renderWood() {
            const imageData = ctx.createImageData(width, height);
            const data = imageData.data;
            // Dark Walnut Tones
            const c1 = {r: 20, g: 10, b: 5};   
            const c2 = {r: 55, g: 30, b: 15}; 
            const c3 = {r: 90, g: 50, b: 25}; 

            for(let y = 0; y < height; y++) {
                for(let x = 0; x < width; x++) {
                    const nx = x * 0.002; const ny = y * 0.01; 
                    let val = pattern(nx, ny);
                    let ring = Math.sin((nx * 5 + val * 8) * 3.14);
                    ring = Math.pow((ring + 1) / 2, 8.0); 
                    let mixVal = lerp(val, ring, 0.15);

                    let r, g, b;
                    if(mixVal < 0.5) {
                       let t = mixVal * 2;
                       r = lerp(c1.r, c2.r, t); g = lerp(c1.g, c2.g, t); b = lerp(c1.b, c2.b, t);
                    } else {
                       let t = (mixVal - 0.5) * 2;
                       r = lerp(c2.r, c3.r, t); g = lerp(c2.g, c3.g, t); b = lerp(c2.b, c3.b, t);
                    }
                    if (Math.random() > 0.94) { r*=0.85; g*=0.85; b*=0.85; }

                    const idx = (x + y * width) * 4;
                    data[idx] = r; data[idx+1] = g; data[idx+2] = b; data[idx+3] = 255;
                }
            }
            ctx.putImageData(imageData, 0, 0);
        }
        resize();
      })();
    </script>
  </body>
</html>

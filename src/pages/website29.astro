---
import "../styles/global.css";

const BRAND = "CALIBER STUDIO — BESPOKE MECHANICAL WATCHES";
const TAGLINE = "Mechanical precision. Personal commissions. Built to be kept.";
const SUBLINE =
  "We design and assemble custom mechanical watches in Amsterdam. From movement selection to dial finishing — every choice is made for balance, legibility, and longevity.";
const AREA = "Amsterdam • Worldwide Delivery • Private Consultations";
const EMAIL = "commissions@caliberstudio.nl";
const PHONE = "+31 6 4728 1190";
const TEL = PHONE.replace(/\s/g, "");
const YEAR = new Date().getFullYear();

// Stock (Unsplash CDN)
const HERO_IMG = "https://images.unsplash.com/photo-1745506264483-b3a1ba5fb311?auto=format&fit=crop&fm=jpg&q=80&w=2400";
const DESIGN_IMG = "https://images.unsplash.com/photo-1614164185128-e4ec99c436d7?auto=format&fit=crop&q=80&w=2400"; 
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{BRAND} — Custom Timepieces</title>
    <meta
      name="description"
      content="Bespoke watchmaking atelier in Amsterdam. Custom mechanical watches — designed, finished, regulated, and assembled by hand."
    />

    <style>
      :root{
        /* Deep Technical Palette */
        --bg0:#050608;
        --bg1:#0a0c10;
        --ink:#eef2f6;
        --mut:rgba(238,242,246,.70);
        --line:rgba(238,242,246,.12);
        --line2:rgba(238,242,246,.06);

        --steel:rgba(160,190,220,.15);
        --tungsten:rgba(255,200,150,.08);
        
        --accent:#7aaadd; /* Technical Blue */
        --accent-glow:rgba(122,170,221,.25);

        --max: 1100px;
        --pad: 20px;
        --r: 4px;

        --shadow: 0 40px 100px rgba(0,0,0,.60);
      }

      *{ box-sizing:border-box; }
      html,body{ height:100%; }
      body{
        margin:0;
        color:var(--ink);
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        background:
          radial-gradient(circle at 50% 0%, var(--steel), transparent 70%),
          radial-gradient(circle at 10% 90%, var(--tungsten), transparent 60%),
          linear-gradient(180deg, var(--bg0), var(--bg1));
        letter-spacing: -0.02em;
        overflow-x: hidden;
      }

      a{ color:inherit; text-decoration:none; transition: color 0.2s ease; }
      a:hover{ color: var(--accent); }

      .wrap{
        width:min(var(--max), calc(100% - 2*var(--pad)));
        margin: 0 auto;
        padding: 40px 0 80px;
      }

      /* Index Button */
      .index-btn {
        position: fixed;
        top: 20px;
        left: 20px;
        z-index: 100;
        padding: 8px 14px;
        background: rgba(5,6,8,0.8);
        border: 1px solid var(--line);
        color: var(--mut);
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        backdrop-filter: blur(4px);
        transition: all 0.2s ease;
      }
      .index-btn:hover { border-color: var(--accent); color: var(--accent); }

      /* Header */
      .top{
        display:flex;
        flex-wrap:wrap;
        align-items:flex-end;
        justify-content:space-between;
        gap: 20px;
        padding-bottom: 24px;
        border-bottom: 1px solid var(--line);
      }

      .mark{
        display:flex;
        flex-direction:column;
        gap: 8px;
        line-height:1;
      }

      .sig{
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: var(--accent);
      }

      .brand{
        font-weight: 700;
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .actions{
        display:flex;
        gap: 12px;
        align-items:center;
      }

      .chip{
        display:inline-flex;
        align-items:center;
        justify-content:center;
        padding: 10px 16px;
        border: 1px solid var(--line);
        background: rgba(255,255,255,.02);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        transition: all .2s ease;
        cursor: pointer;
      }

      .chip:hover{
        border-color: var(--accent);
        background: var(--accent-glow);
        color: #fff;
      }

      .chip.hot{
        background: var(--accent);
        border-color: var(--accent);
        color: #050608;
        font-weight: 700;
      }
      .chip.hot:hover{
        background: #fff;
        color: #000;
        box-shadow: 0 0 20px rgba(255,255,255,0.4);
      }

      /* Hero */
      .hero{
        margin-top: 40px;
        display:flex;
        flex-direction:column;
        gap: 20px;
      }

      .hero h1{
        margin:0;
        font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
        font-weight: 300;
        font-size: clamp(32px, 5vw, 64px);
        letter-spacing: -0.03em;
        line-height: 1.1;
        max-width: 20ch;
      }

      .hero p{
        margin:0;
        color: var(--mut);
        font-size: 14px;
        line-height: 1.8;
        max-width: 60ch;
        font-family: ui-monospace, monospace;
      }

      .meta{
        margin-top: 10px;
        display:flex;
        gap: 20px;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--mut);
        opacity: 0.7;
      }

      /* Aperture image */
      .aperture{
        margin-top: 30px;
        border: 1px solid var(--line);
        position: relative;
        height: min(480px, 60vh);
        overflow: hidden;
      }

      .aperture:after {
        content: "";
        position: absolute;
        inset: 0;
        background-image: 
            linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
        background-size: 40px 40px;
        pointer-events: none;
      }

      .aperture img{
        display:block;
        width:100%;
        height: 100%;
        object-fit: cover;
        filter: grayscale(20%) contrast(1.1);
      }

      .aplabel{
        position:absolute;
        bottom: 0;
        right: 0;
        background: var(--bg0);
        padding: 8px 12px;
        border-top: 1px solid var(--line);
        border-left: 1px solid var(--line);
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--accent);
      }

      /* Base Platforms Grid */
      .model-select-label {
        margin-top: 60px;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--mut);
        border-bottom: 1px solid var(--line);
        padding-bottom: 10px;
        display: flex;
        justify-content: space-between;
      }

      .model-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1px;
        background: var(--line);
        border: 1px solid var(--line);
        margin-top: 0;
      }

      .model-card {
        background: var(--bg0);
        padding: 24px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 20px;
        transition: background 0.2s ease;
        position: relative;
        cursor: pointer;
      }

      .model-card:hover {
        background: rgba(122,170,221,0.03);
      }
      .model-card:hover h3 { color: var(--accent); }

      .model-id {
        font-size: 10px;
        text-transform: uppercase;
        color: var(--mut);
        letter-spacing: 0.1em;
        display: flex;
        justify-content: space-between;
      }

      .model-price {
        color: var(--accent);
        font-weight: 700;
      }

      .model-card h3 {
        margin: 0;
        font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
        font-size: 18px;
        font-weight: 400;
        color: #fff;
        transition: color 0.2s ease;
      }

      .model-specs {
        font-size: 11px;
        color: var(--mut);
        line-height: 1.6;
        border-top: 1px solid var(--line2);
        padding-top: 12px;
      }

      /* --- TABBED PROCESS SECTION --- */
      .process-container {
        margin-top: 80px;
        border: 1px solid var(--line);
        background: rgba(255,255,255,0.01);
      }

      .tab-nav {
        display: flex;
        border-bottom: 1px solid var(--line);
        overflow-x: auto;
      }

      .tab-btn {
        flex: 1;
        padding: 16px;
        text-align: center;
        background: transparent;
        border: none;
        border-right: 1px solid var(--line);
        color: var(--mut);
        font-family: ui-monospace, monospace;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        cursor: pointer;
        transition: background-color 0.5s ease, color 0.5s ease;
        min-width: 100px;
      }
      .tab-btn:last-child { border-right: none; }
      .tab-btn:hover { color: #fff; background: rgba(255,255,255,0.02); }
      .tab-btn.active {
        color: var(--bg0);
        background: var(--accent);
        font-weight: 700;
      }

      .tab-stack {
        display: grid;
        grid-template-areas: "content";
        overflow: hidden;
      }

      .tab-content {
        grid-area: content;
        padding: 40px;
        opacity: 0;
        transform: translateY(10px);
        transition: opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1), transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        pointer-events: none;
        display: grid; 
        grid-template-columns: 1fr 1fr; 
        gap: 40px;
      }

      .tab-content.active { 
        opacity: 1; 
        transform: translateY(0);
        pointer-events: auto;
        z-index: 10;
      }
      
      .tab-text h2 {
        margin: 0 0 10px 0;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: var(--accent);
      }
      .tab-text h3 {
        margin: 0 0 20px 0;
        font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
        font-size: 24px;
        font-weight: 300;
        color: #fff;
      }
      .tab-text p {
        font-size: 14px;
        line-height: 1.8;
        color: var(--mut);
        margin-bottom: 24px;
      }
      .tab-data {
        border-top: 1px solid var(--line);
        padding-top: 20px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
      }
      .data-point span { display: block; }
      .data-label { font-size: 10px; text-transform: uppercase; color: var(--mut); letter-spacing: 0.1em; margin-bottom: 4px; }
      .data-val { font-size: 13px; color: #fff; font-weight: 700; }

      .tab-visual img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border: 1px solid var(--line);
        filter: grayscale(20%) contrast(1.1);
        min-height: 300px;
      }

      /* --- CONFIGURATOR --- */
      .configurator {
        margin-top: 80px;
        border-top: 1px solid var(--line);
        padding-top: 40px;
      }
      .config-grid {
        display: grid;
        grid-template-columns: 1fr 350px;
        gap: 40px;
      }
      .config-options {
        display: flex;
        flex-direction: column;
        gap: 30px;
      }
      .config-group h4 {
        margin: 0 0 12px 0;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--accent);
      }
      .option-row {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }
      .opt-btn {
        padding: 10px 16px;
        border: 1px solid var(--line);
        background: transparent;
        color: var(--mut);
        font-family: ui-monospace, monospace;
        font-size: 12px;
        cursor: pointer;
        transition: all 0.2s ease;
      }
      .opt-btn:hover { border-color: #fff; }
      .opt-btn.selected {
        background: #fff;
        color: var(--bg0);
        border-color: #fff;
        font-weight: 700;
      }

      .spec-sheet {
        border: 1px solid var(--accent);
        background: rgba(122,170,221,0.05);
        padding: 24px;
        font-family: ui-monospace, monospace;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }
      .spec-header {
        border-bottom: 1px solid var(--line);
        padding-bottom: 12px;
        margin-bottom: 12px;
        font-size: 12px;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }
      .spec-line {
        display: flex;
        justify-content: space-between;
        margin-bottom: 8px;
        font-size: 13px;
      }
      .spec-key { color: var(--mut); }
      .spec-val { color: #fff; }
      
      .ref-code {
        margin-top: 20px;
        padding: 12px;
        background: var(--bg0);
        border: 1px dashed var(--line);
        text-align: center;
        color: var(--accent);
        font-size: 14px;
        letter-spacing: 0.1em;
      }

      .price-est {
        margin-top: 15px;
        text-align: right;
        font-size: 18px;
        font-weight: 700;
        color: #fff;
      }
      .price-est span {
        font-size: 11px;
        color: var(--mut);
        font-weight: 400;
        margin-right: 8px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }

      /* --- MODALS --- */
      .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(5,6,8,0.9);
        backdrop-filter: blur(8px);
        z-index: 100;
        display: none;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s ease;
      }
      .modal-overlay.open { display: flex; opacity: 1; }
      
      .modal-card {
        width: min(600px, 90vw);
        background: var(--bg1);
        border: 1px solid var(--accent);
        padding: 40px;
        position: relative;
        box-shadow: 0 0 50px rgba(122,170,221,0.1);
        transform: translateY(20px);
        transition: transform 0.3s ease;
      }
      .modal-overlay.open .modal-card { transform: translateY(0); }

      .close-modal {
        position: absolute;
        top: 20px;
        right: 20px;
        background: transparent;
        border: none;
        color: var(--mut);
        cursor: pointer;
        font-size: 20px;
      }
      .close-modal:hover { color: #fff; }

      .blueprint-header {
        border-bottom: 1px solid var(--line);
        padding-bottom: 20px;
        margin-bottom: 20px;
      }
      .bp-title { font-family: ui-sans-serif, sans-serif; font-size: 24px; color: #fff; margin: 0; }
      .bp-sub { font-size: 12px; color: var(--accent); text-transform: uppercase; letter-spacing: 0.1em; margin-top: 5px; }
      
      .bp-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
      }
      .bp-row { border-bottom: 1px solid var(--line2); padding: 8px 0; font-size: 13px; display: flex; justify-content: space-between; }
      .bp-row span:first-child { color: var(--mut); }
      .bp-row span:last-child { color: #fff; }

      @media (max-width: 768px){
        .tab-content, .tab-content.active, .config-grid { grid-template-columns: 1fr; gap: 20px; }
        .hero h1{ font-size: 36px; }
        .tab-visual { order: -1; min-height: 200px; }
      }
    </style>
  </head>

  <body>
    <a href="/" class="index-btn">Index</a>

    <div id="modal-overlay" class="modal-overlay" aria-hidden="true">
      <div class="modal-card">
        <button class="close-modal" id="close-modal">×</button>
        <div id="modal-content">
            </div>
      </div>
    </div>

    <main class="wrap">
      <header class="top">
        <div class="mark">
          <div class="sig">Atelier 01 / Amsterdam</div>
          <div class="brand">{BRAND}</div>
        </div>

        <div class="actions">
          <a class="chip hot" href="#configurator">Build Spec</a>
        </div>
      </header>

      <section class="hero">
        <h1>{TAGLINE}</h1>
        <p>{SUBLINE}</p>

        <div class="meta">
          <span>{AREA}</span>
          <span>//</span>
          <span>Ref. SYS-2024</span>
        </div>

        <div class="aperture">
          <img src={HERO_IMG} alt="Watchmaker regulating a mechanical movement at the bench." loading="eager" />
          <div class="aplabel">Figure 01: Regulation</div>
        </div>
      </section>

      <div class="model-select-label">
        <span>Platform Families</span>
        <span>Open Blueprint</span>
      </div>
      <div class="model-grid">
        <div class="model-card" data-model="01">
          <div class="model-id">
            <span>TYPE 01</span>
            <span class="model-price">€1.450+</span>
          </div>
          <h3>Field Command</h3>
          <div class="model-specs">
            38mm 316L Steel / Bead-blasted<br/>
            High-contrast Dial Layout<br/>
            10 ATM Water Resistance
          </div>
        </div>

        <div class="model-card" data-model="02">
          <div class="model-id">
            <span>TYPE 02</span>
            <span class="model-price">€1.850+</span>
          </div>
          <h3>Deep Gauge</h3>
          <div class="model-specs">
            42mm Grade 5 Titanium<br/>
            Ceramic 120-click Bezel<br/>
            30 ATM Water Resistance
          </div>
        </div>

        <div class="model-card" data-model="03">
          <div class="model-id">
            <span>TYPE 03</span>
            <span class="model-price">€1.650+</span>
          </div>
          <h3>Aero Navigator</h3>
          <div class="model-specs">
            40mm DLC Coating<br/>
            Anti-magnetic Inner Cage<br/>
            Type-A Flieger Dial
          </div>
        </div>

        <div class="model-card" data-model="04">
          <div class="model-id">
            <span>TYPE 04</span>
            <span class="model-price">€2.200+</span>
          </div>
          <h3>Grand Caliber</h3>
          <div class="model-specs">
            39mm High-polish Steel<br/>
            Enamel Dial Finish<br/>
            Manual-wind Movement
          </div>
        </div>
      </div>

      <div class="process-container">
        <div class="tab-nav">
            <button class="tab-btn active" data-tab="design">01 Brief</button>
            <button class="tab-btn" data-tab="movement">02 Caliber</button>
            <button class="tab-btn" data-tab="assembly">03 Assembly</button>
            <button class="tab-btn" data-tab="commission">04 Commission</button>
        </div>

        <div class="tab-stack">
            <div class="tab-content active" id="design">
                <div class="tab-text">
                    <h2>Architecture</h2>
                    <h3>A watch that reads as one idea</h3>
                    <p>We don’t stack parts — we design a coherent system. You choose case profile (36mm–42mm), material (Steel, Titanium, Bronze), and dial finish. Hands are heat-blued or diamond-polished in-house for clean edges and controlled reflection.</p>
                    <div class="tab-data">
                        <div class="data-point"><span class="data-label">Materials</span><span class="data-val">316L / Grade 5 Ti</span></div>
                        <div class="data-point"><span class="data-label">Crystal</span><span class="data-val">Double-Dome Sapphire</span></div>
                        <div class="data-point"><span class="data-label">Finishes</span><span class="data-val">Brushed / Polished / Blasted</span></div>
                        <div class="data-point"><span class="data-label">Lume</span><span class="data-val">Super-Luminova BGW9</span></div>
                    </div>
                </div>
                <div class="tab-visual">
                    <img src={DESIGN_IMG} alt="Dial and case design notes on the bench." loading="lazy" />
                </div>
            </div>

            <div class="tab-content" id="movement">
                <div class="tab-text">
                    <h2>Heartbeat</h2>
                    <h3>Regulated for daily reality</h3>
                    <p>We build on Swiss (ETA/Sellita) or Japanese (Miyota 9-Series) calibers, then regulate each movement in multiple positions for stable, wearable accuracy. Every caliber is inspected, cleaned where needed, and lubricated with Moebius oils before casing.</p>
                    <div class="tab-data">
                        <div class="data-point"><span class="data-label">Adjustment</span><span class="data-val">5 Positions</span></div>
                        <div class="data-point"><span class="data-label">Target</span><span class="data-val">Tight Daily Tolerance</span></div>
                    </div>
                </div>
                <div class="tab-visual">
                    <img src={DESIGN_IMG} alt="Movement regulation and timing analysis." loading="lazy" />
                </div>
            </div>

            <div class="tab-content" id="assembly">
                <div class="tab-text">
                    <h2>Execution</h2>
                    <h3>Bench discipline, verified seals</h3>
                    <p>Assembly is done under controlled conditions. Hands are set with careful clearance, seals are pressure tested, and each watch runs through an extended cyclotest to verify power reserve and winding efficiency before it leaves the atelier.</p>
                    <div class="tab-data">
                        <div class="data-point"><span class="data-label">Environment</span><span class="data-val">Controlled Bench</span></div>
                        <div class="data-point"><span class="data-label">Testing</span><span class="data-val">Dry & Wet Pressure</span></div>
                    </div>
                </div>
                <div class="tab-visual">
                    <img src={DESIGN_IMG} alt="Final assembly and seal testing." loading="lazy" />
                </div>
            </div>

            <div class="tab-content" id="commission">
                <div class="tab-text">
                    <h2>Allocation</h2>
                    <h3>Reserve a build slot</h3>
                    <p>Typical lead time for a bespoke commission is 8–12 weeks. We cap output to protect finishing quality and communication. Use the configurator below to generate a build ticket and request a formal quote.</p>
                    <div class="tab-data">
                        <div class="data-point"><span class="data-label">Lead Time</span><span class="data-val">8-12 Weeks</span></div>
                        <div class="data-point"><span class="data-label">Status</span><span class="data-val" style="color:var(--accent);">Slots Available</span></div>
                    </div>
                </div>
                <div class="tab-visual">
                    <img src={DESIGN_IMG} alt="Commission documentation and build allocation." loading="lazy" />
                </div>
            </div>
        </div>
      </div>

      <section class="configurator" id="configurator">
        <div class="model-select-label">
            <span>Commission Specification</span>
            <span>Ref. Generator</span>
        </div>
        <div class="config-grid">
            <div class="config-options">
                <div class="config-group">
                    <h4>Case Material</h4>
                    <div class="option-row">
                        <button class="opt-btn selected" onclick="setConfig('case', '316L Steel')">316L Steel (Brushed/Polished)</button>
                        <button class="opt-btn" onclick="setConfig('case', 'Titanium')">Titanium (Grade 5)</button>
                        <button class="opt-btn" onclick="setConfig('case', 'Bronze')">Bronze (CuSn8)</button>
                        <button class="opt-btn" onclick="setConfig('case', 'DLC Black')">DLC Black (Stealth)</button>
                    </div>
                </div>
                <div class="config-group">
                    <h4>Dial Type</h4>
                    <div class="option-row">
                        <button class="opt-btn selected" onclick="setConfig('dial', 'Matte Black')">Matte Black (Tool)</button>
                        <button class="opt-btn" onclick="setConfig('dial', 'Enamel White')">Enamel White (Gloss)</button>
                        <button class="opt-btn" onclick="setConfig('dial', 'Sunburst Blue')">Sunburst Blue (Radial)</button>
                        <button class="opt-btn" onclick="setConfig('dial', 'Aventurine')">Aventurine (Night Sky)</button>
                    </div>
                </div>
                <div class="config-group">
                    <h4>Hand Finish</h4>
                    <div class="option-row">
                        <button class="opt-btn selected" onclick="setConfig('hands', 'Polished')">Polished (Diamond-cut)</button>
                        <button class="opt-btn" onclick="setConfig('hands', 'Heat Blued')">Heat Blued</button>
                        <button class="opt-btn" onclick="setConfig('hands', 'Rose Gold')">Rose Gold</button>
                        <button class="opt-btn" onclick="setConfig('hands', 'Skeleton')">Skeletonized</button>
                    </div>
                </div>
                <div class="config-group">
                    <h4>Strap System</h4>
                    <div class="option-row">
                        <button class="opt-btn selected" onclick="setConfig('strap', 'NATO Nylon')">NATO Nylon (Daily)</button>
                        <button class="opt-btn" onclick="setConfig('strap', 'Leather')">Horween Leather</button>
                        <button class="opt-btn" onclick="setConfig('strap', 'Steel Bracelet')">Steel Bracelet</button>
                        <button class="opt-btn" onclick="setConfig('strap', 'Rubber')">FKM Rubber</button>
                    </div>
                </div>
            </div>

            <div class="spec-sheet">
                <div>
                    <div class="spec-header">Build Ticket</div>
                    <div class="spec-line"><span class="spec-key">Case</span><span class="spec-val" id="out-case">316L Steel</span></div>
                    <div class="spec-line"><span class="spec-key">Dial</span><span class="spec-val" id="out-dial">Matte Black</span></div>
                    <div class="spec-line"><span class="spec-key">Hands</span><span class="spec-val" id="out-hands">Polished</span></div>
                    <div class="spec-line"><span class="spec-key">Strap</span><span class="spec-val" id="out-strap">NATO Nylon</span></div>
                    
                    <div class="price-est">
                        <span>Estimate</span>
                        <div id="out-price">€1.450</div>
                    </div>

                    <div class="ref-code" id="ref-code">REF-STL-BLK-POL-NATO</div>
                </div>
                <a id="mail-link" class="chip hot" style="width:100%; text-align:center; margin-top:20px;" href="#">Request a Quote</a>
            </div>
        </div>
      </section>

      <footer>
        <div class="fine">
          <span>© {YEAR} {BRAND}</span>
          <span>Commission Desk / AMS</span>
        </div>
      </footer>
    </main>

    <script is:inline>
      // --- MODAL LOGIC ---
      const modalOverlay = document.getElementById('modal-overlay');
      const modalContent = document.getElementById('modal-content');
      const closeModal = document.getElementById('close-modal');
      const modelCards = document.querySelectorAll('.model-card');

      const modelData = {
        "01": { title: "Field Command", sub: "Daily Utility Platform", specs: { "Diameter": "38mm", "Lug-to-Lug": "46mm", "Caliber": "SW200-1", "Crystal": "Sapphire" } },
        "02": { title: "Deep Gauge", sub: "Dive Specification Platform", specs: { "Diameter": "42mm", "Lug-to-Lug": "50mm", "Caliber": "SW200-1", "Bezel": "Ceramic" } },
        "03": { title: "Aero Navigator", sub: "Pilot Specification Platform", specs: { "Diameter": "40mm", "Lug-to-Lug": "48mm", "Caliber": "Miyota 90S5", "Cage": "Soft Iron" } },
        "04": { title: "Grand Caliber", sub: "Dress / Formal Platform", specs: { "Diameter": "39mm", "Lug-to-Lug": "45mm", "Caliber": "ETA 7001 (Manual)", "Finish": "High Polish" } }
      };

      modelCards.forEach(card => {
        card.addEventListener('click', () => {
            const id = card.getAttribute('data-model');
            const data = modelData[id];
            
            let specsHTML = '';
            for (const [key, value] of Object.entries(data.specs)) {
                specsHTML += `<div class="bp-row"><span>${key}</span><span>${value}</span></div>`;
            }

            modalContent.innerHTML = `
                <div class="blueprint-header">
                    <h2 class="bp-title">${data.title}</h2>
                    <div class="bp-sub">${data.sub}</div>
                </div>
                <div class="bp-grid">
                    ${specsHTML}
                </div>
                <div style="margin-top:20px; font-size:13px; color:var(--mut); line-height:1.6;">
                    Platform blueprint. Movements are regulated in-house. Seals and functions are verified before delivery.
                </div>
            `;
            modalOverlay.classList.add('open');
        });
      });

      closeModal.addEventListener('click', () => {
        modalOverlay.classList.remove('open');
      });

      // --- TAB LOGIC (SOFT TRANSITION) ---
      const tabs = document.querySelectorAll('.tab-btn');
      const contents = document.querySelectorAll('.tab-content');

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
            // Remove active
            tabs.forEach(t => t.classList.remove('active'));
            contents.forEach(c => c.classList.remove('active'));
            
            // Add active
            tab.classList.add('active');
            document.getElementById(tab.getAttribute('data-tab')).classList.add('active');
        });
      });

      // --- CONFIGURATOR LOGIC WITH PRICING ---
      const configState = {
        case: '316L Steel',
        dial: 'Matte Black',
        hands: 'Polished',
        strap: 'NATO Nylon'
      };

      const prices = {
        // Base: 1450
        'case': { '316L Steel': 0, 'Titanium': 200, 'Bronze': 150, 'DLC Black': 100 },
        'dial': { 'Matte Black': 0, 'Enamel White': 150, 'Sunburst Blue': 50, 'Aventurine': 250 },
        'hands': { 'Polished': 0, 'Heat Blued': 80, 'Rose Gold': 50, 'Skeleton': 50 },
        'strap': { 'NATO Nylon': 0, 'Leather': 80, 'Steel Bracelet': 150, 'Rubber': 50 }
      };

      const codes = {
        '316L Steel': 'STL', 'Titanium': 'TI', 'Bronze': 'BRZ', 'DLC Black': 'DLC',
        'Matte Black': 'BLK', 'Enamel White': 'WHT', 'Sunburst Blue': 'BLU', 'Aventurine': 'AVN',
        'Polished': 'POL', 'Heat Blued': 'BLU', 'Rose Gold': 'GLD', 'Skeleton': 'SKL',
        'NATO Nylon': 'NATO', 'Leather': 'LTH', 'Steel Bracelet': 'BRC', 'Rubber': 'RUB'
      };

      function calculatePrice() {
        let total = 1450; // Base Price
        total += prices.case[configState.case];
        total += prices.dial[configState.dial];
        total += prices.hands[configState.hands];
        total += prices.strap[configState.strap];
        return total.toLocaleString('de-DE'); // Euro format
      }

      window.setConfig = function(cat, val) {
        configState[cat] = val;
        
        // Update Buttons
        const btns = document.querySelectorAll(`.config-group:has(button[onclick*="'${cat}'"]) .opt-btn`);
        btns.forEach(b => {
            if(b.textContent.includes(val)) b.classList.add('selected');
            else b.classList.remove('selected');
        });

        // Update Text
        document.getElementById(`out-${cat}`).innerText = val;

        // Update Price
        document.getElementById('out-price').innerText = `€${calculatePrice()}`;

        // Update Ref Code
        const ref = `REF-${codes[configState.case]}-${codes[configState.dial]}-${codes[configState.hands]}-${codes[configState.strap]}`;
        document.getElementById('ref-code').innerText = ref;

        // Update Mail Link
        const mailLink = document.getElementById('mail-link');
        const subject = encodeURIComponent(`Commission Inquiry: ${ref}`);
        const body = encodeURIComponent(`Hello,\n\nI’d like to request a quote for the configuration below:\n\nReference: ${ref}\nCase: ${configState.case}\nDial: ${configState.dial}\nHands: ${configState.hands}\nStrap: ${configState.strap}\n\nEstimated Configuration Price: €${calculatePrice()}\n\nPlease share lead time, deposit terms, and any final confirmation steps.\n\nThank you.`);
        mailLink.setAttribute('href', `mailto:commissions@caliberstudio.nl?subject=${subject}&body=${body}`);
      };

    </script>
  </body>
</html>

---
const BRAND = "ORBITAL CRYPTO";

const NAV = [
  { label: "Products", href: "#capabilities" },
  { label: "Security", href: "#security" },
  { label: "Platform", href: "#interface" },
  { label: "Get Access", href: "/contact" },
];

const CAPABILITIES = [
  { k: "OTC TRADING DESK", v: "RFQ execution for BTC, ETH, and majors, priced with transparent spreads and timestamped quotes." },
  { k: "SMART ORDER ROUTING", v: "Splits orders across venues to reduce slippage, improve fills, and avoid market impact." },
  { k: "CUSTODY + SETTLEMENT", v: "Controlled settlement flows with policy checks, whitelists, and step-by-step confirmations." },
  { k: "TREASURY OPERATIONS", v: "Role-based approvals, velocity limits, and scheduled transfers for corporate crypto treasury." },
  { k: "REPORTING + EXPORTS", v: "Balances, fills, fees, and transfers, exportable for accounting, audit, and reconciliation." },
  { k: "API + FIX ACCESS", v: "Programmatic trading and reporting endpoints for funds, desks, and internal tooling teams." },
];

const SECURITY = [
  { k: "MPC KEY MANAGEMENT", v: "Distributed signing with enforced policy checks before any high-value movement is allowed." },
  { k: "ROLE-BASED CONTROLS", v: "Separate request, approve, and execute so no single operator can move funds alone." },
  { k: "AUDITABLE EVENTS", v: "Immutable action history for orders and transfers, built for reviews and incident response." },
];

const STRIP = [
  { k: "OTC EXECUTION", v: "RFQ, block trades" },
  { k: "CUSTODY", v: "Policy + whitelists" },
  { k: "TREASURY", v: "Approvals + limits" },
  { k: "REPORTING", v: "Exports + trails" },
];

const toId = (s: string) => String(s || "").toLowerCase().replace(/\s+/g, "-").replace(/[^\w-]/g, "");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{BRAND} | OTC, Custody, Treasury</title>
    <meta name="description" content="Institutional crypto platform concept, OTC execution, custody and settlement controls, treasury approvals, and audit-ready reporting." />

    <style>
      :root{
        /* No white surfaces. No gold. */
        --bg0:#040610;           /* deep indigo (not pure black) */
        --bg1:#070A14;
        --bg2:#0B1020;

        --ink:#E7ECF3;           /* light ink (text) */
        --ink-dim:rgba(231,236,243,0.70);
        --muted:rgba(231,236,243,0.55);

        --line:rgba(231,236,243,0.10);
        --line2:rgba(231,236,243,0.06);

        --p: #C9D0DA;            /* platinum */
        --a1:#35F1FF;            /* neon cyan */
        --a2:#A77BFF;            /* violet */
        --a3:#FF4FD8;            /* magenta (very subtle usage) */

        --glow: rgba(53,241,255,0.16);
        --glow2: rgba(167,123,255,0.14);

        /* PANORAMIC LAYOUT CONFIG */
        --max: 1860px;           /* ULTRA WIDE */
        --pad: clamp(30px, 4vw, 60px); 
        --radius: 14px;
        
        --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        --serif: "Times New Roman", Times, serif;
        --sans: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
      }

      *{ box-sizing:border-box; }
      html,body{ height:100%; scroll-behavior:smooth; }
      body{
        margin:0;
        color:var(--ink);
        font-family:var(--sans);
        background:
          radial-gradient(900px 560px at 18% 10%, rgba(167,123,255,0.16), transparent 60%),
          radial-gradient(860px 640px at 78% 22%, rgba(53,241,255,0.12), transparent 62%),
          radial-gradient(820px 780px at 45% 90%, rgba(201,208,218,0.06), transparent 68%),
          linear-gradient(180deg, var(--bg0), var(--bg2));
        overflow-x:hidden;
      }

      /* Low-noise grain (local) */
      body::before{
        content:"";
        position:fixed; inset:0;
        background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.045'/%3E%3C/svg%3E");
        pointer-events:none;
        mix-blend-mode: overlay;
        z-index:0;
      }

      /* Subtle gridlines */
      .gridlines{
        position:fixed; inset:0; pointer-events:none; z-index:0;
        background:
          linear-gradient(to right, rgba(231,236,243,0.04) 1px, transparent 1px),
          linear-gradient(to bottom, rgba(231,236,243,0.03) 1px, transparent 1px);
        background-size: 64px 64px;
        mask-image: radial-gradient(1600px 900px at 50% 30%, rgba(0,0,0,0.95), transparent 70%);
        opacity: 0.55;
      }

      a{ color:inherit; text-decoration:none; }
      .wrap{ position:relative; z-index:1; max-width:var(--max); margin:0 auto; padding: 0 var(--pad) 140px; }

      /* Topbar */
      .topbar{
        position:sticky; top:0; z-index:10;
        display:flex; align-items:center; justify-content:space-between; gap:18px;
        padding: 30px 0 20px;
        backdrop-filter: blur(10px);
        background: linear-gradient(180deg, rgba(4,6,16,0.82), rgba(4,6,16,0.35));
        border-bottom: 1px solid rgba(231,236,243,0.06);
      }
      
      .back-link{
        width: 32px; height: 32px;
        display: flex; align-items: center; justify-content: center;
        border: 1px solid rgba(231,236,243,0.15);
        border-radius: 50%;
        color: rgba(231,236,243,0.5);
        transition: all 0.3s ease;
      }
      .back-link:hover{
        border-color: var(--a1);
        color: var(--a1);
        box-shadow: 0 0 12px var(--glow);
      }
      .back-link svg{ width: 14px; height: 14px; fill: currentColor; }

      .brand{
        display:flex; align-items:center; gap:16px;
      }
      .brand-text{ display:flex; flex-direction:column; gap:4px; }
      .brand .name{
        font-family: var(--serif);
        font-weight: 400;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        font-size: 14px;
        color: var(--p);
      }
      .brand .sub{
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: rgba(231,236,243,0.45);
      }
      .nav{
        display:flex; align-items:center; gap:32px;
      }
      .nav a{
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: rgba(231,236,243,0.58);
        position: relative;
        padding: 10px 0;
        transition: color .25s ease;
      }
      .nav a:hover{ color: var(--p); }
      .nav a::after{
        content:"";
        position:absolute; left:0; right:100%; bottom:6px; height:1px;
        background: linear-gradient(90deg, var(--a2), var(--a1));
        transition: right .26s ease;
        opacity: 0.9;
      }
      .nav a:hover::after{ right:0; }

      /* Hero */
      .hero{
        padding: 120px 0 100px;
      }
      .heroGrid{
        display:grid;
        grid-template-columns: 1fr 1fr;
        gap: 200px; /* EXTREME GAP for De-Centering */
        align-items: center;
      }
      .h1{
        margin:0;
        font-family: var(--serif);
        font-weight: 400;
        font-size: clamp(52px, 6vw, 92px);
        line-height: 1.03;
        color: var(--ink);
      }
      .h1 .grad{
        background: linear-gradient(90deg, var(--a2), var(--a1));
        -webkit-background-clip:text;
        background-clip:text;
        color: transparent;
      }
      .lead{
        margin-top: 28px;
        max-width: 48ch; 
        color: var(--ink-dim);
        line-height: 1.85;
        font-size: 17px;
        letter-spacing: 0.01em;
        border-left: 1px solid rgba(201,208,218,0.22);
        padding-left: 28px;
      }
      .actions{
        margin-top: 42px;
        display:flex;
        gap: 20px;
        flex-wrap: wrap;
      }
      .btn{
        display:inline-flex; align-items:center; justify-content:center;
        padding: 18px 26px;
        border-radius: 999px;
        border: 1px solid rgba(231,236,243,0.14);
        background: rgba(255,255,255,0.02);
        color: rgba(231,236,243,0.88);
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        transition: transform .18s ease, border-color .18s ease, background .18s ease, box-shadow .18s ease;
      }
      .btn.primary{
        border-color: rgba(53,241,255,0.30);
        background: linear-gradient(180deg, rgba(53,241,255,0.08), rgba(255,255,255,0.02));
        box-shadow: 0 0 0 1px rgba(167,123,255,0.08) inset;
      }
      .btn:hover{
        transform: translateY(-1px);
        border-color: rgba(231,236,243,0.26);
        box-shadow: 0 14px 46px rgba(0,0,0,0.55), 0 0 26px rgba(53,241,255,0.10);
      }

      /* Halo Visual */
      .halo{
        position: relative;
        border-radius: var(--radius);
        border: 1px solid rgba(231,236,243,0.10);
        background: linear-gradient(135deg, rgba(255,255,255,0.03), rgba(0,0,0,0.22));
        overflow:hidden;
        min-height: 580px; /* Taller */
        display:flex; align-items:center; justify-content:center;
      }
      .halo::before{
        content:"";
        position:absolute; inset:-40%;
        background:
          radial-gradient(circle at 30% 30%, rgba(53,241,255,0.20), transparent 55%),
          radial-gradient(circle at 70% 60%, rgba(167,123,255,0.22), transparent 58%),
          radial-gradient(circle at 55% 82%, rgba(201,208,218,0.10), transparent 60%);
        filter: blur(18px);
        opacity: 0.85;
        animation: drift 16s linear infinite;
        pointer-events:none;
      }
      .halo::after{
        content:"";
        position:absolute; top:0; left:0; right:0; height:2px;
        background: linear-gradient(90deg, transparent, var(--a1), transparent);
        box-shadow: 0 0 15px var(--a1);
        opacity: 0.4;
        animation: scan 6s ease-in-out infinite;
        pointer-events:none;
      }

      .haloSvg{
        position: relative;
        width: min(500px, 86%);
        height: auto;
        opacity: 0.98;
        filter: drop-shadow(0 18px 60px rgba(0,0,0,0.55));
      }
      .hud{
        position:absolute; top: 24px; right: 24px; text-align:right;
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: rgba(231,236,243,0.52);
      }
      .hud strong{
        display:block;
        margin-top: 8px;
        color: rgba(231,236,243,0.88);
        letter-spacing: 0.18em;
        font-weight: 700;
        text-shadow: 0 0 8px var(--glow);
      }

      /* Strip */
      .strip{
        margin-top: 60px;
        border: 1px solid rgba(231,236,243,0.08);
        border-radius: var(--radius);
        overflow:hidden;
        background: rgba(255,255,255,0.015);
      }
      .stripRow{
        display:grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1px;
        background: rgba(231,236,243,0.08);
      }
      .stripItem{
        padding: 24px 22px;
        background: rgba(4,6,16,0.72);
        display:flex; flex-direction:column; gap:10px;
      }
      .stripItem .k{
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: rgba(231,236,243,0.56);
      }
      .stripItem .v{
        font-family: var(--serif);
        font-size: 18px;
        color: rgba(231,236,243,0.90);
        letter-spacing: 0.02em;
      }

      /* Sections */
      section{ margin-top: 160px; }
      .sectionHead{
        display:flex; align-items:flex-end; justify-content:space-between; gap:18px;
        padding-bottom: 22px;
        border-bottom: 1px solid rgba(231,236,243,0.08);
        margin-bottom: 50px;
      }
      .sectionHead h2{
        margin:0;
        font-family: var(--serif);
        font-weight: 400;
        font-size: 38px;
        letter-spacing: 0.02em;
      }
      .sectionHead .tag{
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: rgba(231,236,243,0.52);
      }

      /* Capability Grid */
      .cardGrid{
        display:grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px; /* Wider gap */
      }
      .card{
        border-radius: var(--radius);
        border: 1px solid rgba(231,236,243,0.10);
        background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(0,0,0,0.28));
        padding: 34px 28px;
        position: relative;
        overflow:hidden;
        transition: transform .18s ease, border-color .18s ease, box-shadow .18s ease;
      }
      .card::before{
        content:"";
        position:absolute; inset:-40%;
        background:
          radial-gradient(circle at 25% 30%, rgba(53,241,255,0.12), transparent 55%),
          radial-gradient(circle at 75% 70%, rgba(167,123,255,0.12), transparent 58%);
        filter: blur(20px);
        opacity: 0.55;
        transform: translate3d(0,0,0);
        pointer-events:none;
      }
      .card:hover{
        transform: translateY(-4px);
        border-color: rgba(231,236,243,0.20);
        box-shadow: 0 24px 70px rgba(0,0,0,0.55), 0 0 30px rgba(53,241,255,0.10);
      }
      
      .tech-corner{
        position: absolute; width: 6px; height: 6px;
        border-color: rgba(231,236,243,0.3); border-style: solid;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        pointer-events: none; opacity: 0;
      }
      .tl{ top: 10px; left: 10px; border-width: 1px 0 0 1px; }
      .tr{ top: 10px; right: 10px; border-width: 1px 1px 0 0; }
      .bl{ bottom: 10px; left: 10px; border-width: 0 0 1px 1px; }
      .br{ bottom: 10px; right: 10px; border-width: 0 1px 1px 0; }
      .card:hover .tech-corner{ opacity: 1; width: 14px; height: 14px; border-color: var(--a1); box-shadow: 0 0 8px var(--glow); }

      .card .k{
        position:relative;
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: rgba(231,236,243,0.62);
      }
      .card .v{
        position:relative;
        margin-top: 18px;
        font-family: var(--serif);
        font-weight: 400;
        font-size: 20px;
        line-height: 1.35;
        color: rgba(231,236,243,0.92);
      }

      /* Security Columns */
      .cols{
        display:grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
      }
      .col{
        border-radius: var(--radius);
        border: 1px solid rgba(231,236,243,0.10);
        background: rgba(255,255,255,0.02);
        padding: 34px;
        transition: border-color 0.3s;
      }
      .col:hover{ border-color: rgba(53,241,255,0.25); }
      .col .k{
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: rgba(231,236,243,0.62);
      }
      .col .v{
        margin-top: 14px;
        color: rgba(231,236,243,0.72);
        line-height: 1.75;
        font-size: 16px;
      }

      /* Liquidity Field */
      .liquidity{
        position: relative;
        border-radius: calc(var(--radius) + 4px);
        border: 1px solid rgba(231,236,243,0.10);
        overflow:hidden;
        background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(0,0,0,0.30));
        transition: border-color 0.5s;
      }
      .liquidity:hover{
        border-color: rgba(53,241,255,0.2);
        box-shadow: 0 0 60px rgba(53,241,255,0.08);
      }
      .liquidity::before{
        content:"";
        position:absolute; inset:-35%;
        background:
          conic-gradient(from 180deg at 50% 50%,
            rgba(53,241,255,0.00),
            rgba(53,241,255,0.14),
            rgba(167,123,255,0.12),
            rgba(201,208,218,0.06),
            rgba(53,241,255,0.14),
            rgba(53,241,255,0.00));
        filter: blur(22px);
        opacity: 0.85;
        animation: swirl 18s linear infinite;
        pointer-events:none;
      }
      .liquidity::after{
        content:"";
        position:absolute; inset:0;
        background:
          repeating-linear-gradient(135deg,
            rgba(231,236,243,0.06) 0px,
            rgba(231,236,243,0.06) 1px,
            transparent 12px,
            transparent 28px);
        opacity: 0.20;
        mix-blend-mode: overlay;
        pointer-events:none;
      }
      
      .aurora-border{
        position: absolute; top:0; left:0; right:0; height:1px;
        background: linear-gradient(90deg, transparent, var(--a1), var(--a2), transparent);
        opacity: 0.4;
        animation: scan 8s ease-in-out infinite reverse;
      }

      .liqInner{
        position: relative;
        padding: 80px 60px;
        display:grid;
        grid-template-columns: 1fr 1fr;
        gap: 160px; /* EXTREME GAP */
        align-items: center;
      }
      .liqTitle{
        margin:0;
        font-family: var(--serif);
        font-weight: 400;
        font-size: 42px;
        line-height: 1.08;
      }
      .liqLead{
        margin-top: 24px;
        color: rgba(231,236,243,0.70);
        line-height: 1.85;
        font-size: 16px;
        max-width: 52ch;
        border-left: 1px solid rgba(201,208,218,0.22);
        padding-left: 28px;
      }
      .liqRight{
        border-radius: var(--radius);
        border: 1px solid rgba(231,236,243,0.10);
        background: rgba(4,6,16,0.58);
        padding: 40px;
      }
      .liqRight .m{
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: rgba(231,236,243,0.56);
      }
      .liqRight .s{
        margin-top: 14px;
        font-family: var(--serif);
        font-size: 22px;
        color: rgba(231,236,243,0.90);
        line-height: 1.35;
      }

      /* Final CTA */
      .cta{
        margin-top: 60px;
        border-radius: calc(var(--radius) + 2px);
        border: 1px solid rgba(231,236,243,0.10);
        background:
          radial-gradient(900px 360px at 20% 20%, rgba(167,123,255,0.12), transparent 60%),
          radial-gradient(900px 360px at 80% 70%, rgba(53,241,255,0.10), transparent 60%),
          rgba(255,255,255,0.02);
        padding: 50px 40px;
        display:flex; align-items:center; justify-content:space-between; gap:40px;
      }
      .cta h3{
        margin:0;
        font-family: var(--serif);
        font-weight: 400;
        font-size: 32px;
      }
      .cta p{
        margin: 14px 0 0;
        color: rgba(231,236,243,0.66);
        line-height: 1.75;
        max-width: 60ch;
        font-size: 16px;
      }

      /* Reveal */
      .reveal{ opacity:0; transform: translateY(18px); transition: opacity .9s cubic-bezier(.19,1,.22,1), transform .9s cubic-bezier(.19,1,.22,1); }
      .reveal.on{ opacity:1; transform: translateY(0); }

      /* Footer */
      .footer{
        margin-top: 140px;
        padding-top: 24px;
        border-top: 1px solid rgba(231,236,243,0.08);
        color: rgba(231,236,243,0.42);
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
      }

      @keyframes drift{
        0%{ transform: translate3d(-2%, -1%, 0); }
        50%{ transform: translate3d(2%, 1%, 0); }
        100%{ transform: translate3d(-2%, -1%, 0); }
      }
      @keyframes swirl{
        0%{ transform: translate3d(-1%, -1%, 0) rotate(0deg); }
        100%{ transform: translate3d(1%, 1%, 0) rotate(360deg); }
      }
      @keyframes scan {
        0% { top: 0%; opacity: 0; }
        10% { opacity: 0.5; }
        90% { opacity: 0.5; }
        100% { top: 100%; opacity: 0; }
      }

      @media (max-width: 1200px){
        .heroGrid{ grid-template-columns: 1fr; gap: 60px; }
        .halo{ min-height: 400px; }
        .stripRow{ grid-template-columns: 1fr 1fr; }
        .cardGrid{ grid-template-columns: 1fr; }
        .cols{ grid-template-columns: 1fr; }
        .liqInner{ grid-template-columns: 1fr; padding: 50px 30px; gap: 40px; }
        .cta{ flex-direction: column; align-items:flex-start; }
        .wrap { padding: 0 24px 100px; }
      }

      @media (prefers-reduced-motion: reduce){
        html,body{ scroll-behavior:auto; }
        .reveal{ opacity:1; transform:none; transition:none; }
        .halo::before{ animation:none; }
        .liquidity::before{ animation:none; }
        .halo::after, .aurora-border{ animation:none; opacity: 0.2; }
      }
    </style>
  </head>

  <body>
    <div class="gridlines" aria-hidden="true"></div>

    <div class="wrap">
      <header class="topbar reveal">
        <div class="brand" aria-label="Brand">
          <a href="/" class="back-link" aria-label="Back to Index">
            <svg viewBox="0 0 24 24"><path d="M3 3h7v7H3V3zm11 0h7v7h-7V3zm0 11h7v7h-7v-7zM3 14h7v7H3v-7z"/></svg>
          </a>
          <div class="brand-text">
            <div class="name">{BRAND}</div>
            <div class="sub">institutional crypto platform concept</div>
          </div>
        </div>
        <nav class="nav" aria-label="Primary navigation">
          {NAV.map((n) => <a href={n.href}>{n.label}</a>)}
        </nav>
      </header>

      <main>
        <section class="hero">
          <div class="heroGrid">
            <div class="reveal">
              <h1 class="h1">
                Trade and custody crypto.
                <br />
                <span class="grad">With controls that hold up.</span>
              </h1>
              <div class="lead">
                OTC execution, custody and settlement workflows, and treasury approvals.
                Built for funds and companies that need clear routing, clean logs, and fewer mistakes.
              </div>
              <div class="actions" aria-label="Primary actions">
                <a class="btn primary" href="/contact" aria-label="Request a demo">Request Demo</a>
                <a class="btn" href="#capabilities" aria-label="View products">View Products</a>
              </div>

              <div class="strip reveal" aria-label="Product strip">
                <div class="stripRow">
                  {STRIP.map((i) => (
                    <div class="stripItem" aria-label={i.k}>
                      <div class="k">{i.k}</div>
                      <div class="v">{i.v}</div>
                    </div>
                  ))}
                </div>
              </div>
            </div>

            <div class="halo reveal" aria-label="Holographic settlement halo">
              <div class="hud" aria-hidden="true">
                WORKFLOW
                <strong>RFQ TO SETTLEMENT</strong>
              </div>

              <svg class="haloSvg" viewBox="0 0 520 520" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Orbital crypto emblem">
                <defs>
                  <linearGradient id="holo" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#A77BFF" />
                    <stop offset="50%" stop-color="#35F1FF" />
                    <stop offset="100%" stop-color="#C9D0DA" />
                  </linearGradient>
                  <filter id="softGlow" x="-20%" y="-20%" width="140%" height="140%">
                    <feGaussianBlur stdDeviation="3" result="b"/>
                    <feMerge>
                      <feMergeNode in="b"/>
                      <feMergeNode in="SourceGraphic"/>
                    </feMerge>
                  </filter>
                </defs>

                <g filter="url(#softGlow)" fill="none" stroke="url(#holo)" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="260" cy="260" r="222" stroke-width="2" opacity="0.75"/>
                  <circle cx="260" cy="260" r="196" stroke-width="1" opacity="0.35" stroke-dasharray="2 10"/>

                  <path d="M120 260c22-78 82-132 140-140" stroke-width="2" opacity="0.65"/>
                  <path d="M400 260c-22 78-82 132-140 140" stroke-width="2" opacity="0.65"/>

                  <circle cx="120" cy="260" r="5" fill="#35F1FF" opacity="0.85" stroke="none"/>
                  <circle cx="400" cy="260" r="5" fill="#A77BFF" opacity="0.85" stroke="none"/>
                  <circle cx="260" cy="64" r="4" fill="#C9D0DA" opacity="0.70" stroke="none"/>
                  <circle cx="260" cy="456" r="4" fill="#C9D0DA" opacity="0.70" stroke="none"/>

                  <rect x="170" y="190" width="180" height="140" rx="16" stroke-width="2" opacity="0.70"/>
                  <path d="M200 230h120M200 260h140M200 290h96" stroke-width="2" opacity="0.55"/>

                  <path d="M260 110v300M110 260h300" stroke-width="1" opacity="0.18"/>
                </g>
              </svg>
            </div>
          </div>
        </section>

        <section id="capabilities" class="reveal" aria-label="Capabilities">
          <div class="sectionHead">
            <h2>Products</h2>
            <div class="tag">Built to be used</div>
          </div>

          <div class="cardGrid">
            {CAPABILITIES.map((c) => (
              <article class="card" aria-label={c.k}>
                <div class="tech-corner tl"></div>
                <div class="tech-corner tr"></div>
                <div class="tech-corner bl"></div>
                <div class="tech-corner br"></div>
                
                <div class="k">{c.k}</div>
                <div class="v">{c.v}</div>
              </article>
            ))}
          </div>
        </section>

        <section id="security" class="reveal" aria-label="Security posture">
          <div class="sectionHead">
            <h2>Security</h2>
            <div class="tag">Defense through process</div>
          </div>

          <div class="cols">
            {SECURITY.map((s) => (
              <div class="col" aria-label={s.k}>
                <div class="k">{s.k}</div>
                <div class="v">{s.v}</div>
              </div>
            ))}
          </div>
        </section>

        <section id="interface" class="reveal" aria-label="Interface section">
          <div class="sectionHead">
            <h2>Platform</h2>
            <div class="tag">Operator clarity</div>
          </div>

          <div class="liquidity" aria-label="Platform panel">
            <div class="aurora-border" aria-hidden="true"></div>
            <div class="liqInner">
              <div>
                <h3 class="liqTitle">Every critical action has a visible trail.</h3>
                <div class="liqLead">
                  Quote requests, order fills, transfers, approvals, and settlements are shown as a single timeline.
                  If something breaks, you can point to the exact step that broke.
                </div>
              </div>
              <div class="liqRight" aria-label="Platform note">
                <div class="m">WHAT YOU SEE</div>
                <div class="s">RFQ tickets, execution status, custody balances, approvals, exports, and audit history.</div>
              </div>
            </div>
          </div>

          <div class="cta reveal" aria-label="Final call to action">
            <div>
              <h3>Want a walkthrough?</h3>
              <p>
                Send your use case, OTC size, custody needs, and approval structure.
                We map the workflow and show how it runs end to end.
              </p>
            </div>
            <a class="btn primary" href="/contact" aria-label="Contact for demo">Request Demo</a>
          </div>
        </section>

        <footer class="footer reveal">
          OTC. Custody. Treasury. Reporting. Concept build.
        </footer>
      </main>
    </div>

    <script>
      (function () {
        var reduce = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (reduce) return;

        var obs = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) e.target.classList.add("on");
          });
        }, { threshold: 0.12 });

        document.querySelectorAll(".reveal").forEach(function (el) { obs.observe(el); });
      })();
    </script>
  </body>
</html>

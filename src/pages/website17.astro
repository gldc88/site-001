---
const BRAND = "Atelier Private Catering";
const BOOKING_EMAIL = "reservations@atelier.dining";

const NAV = [
  { label: "Philosophy", href: "#philosophy" },
  { label: "Sourcing", href: "#provenance" },
  { label: "Menu Directions", href: "#menu" },
];

// Hero Image: Moody, focused chef's finish
const HERO_IMG = "https://images.unsplash.com/photo-1600565193348-f74bd3c7ccdf?q=80&w=2000";
const DETAIL_IMG = "https://images.unsplash.com/photo-1514362545857-3bc16c4c7d1b?auto=format&fit=crop&w=1200&q=80";

const PHILOSOPHY = [
  { k: "SILENCE", v: "Early load-in, tight footprint, no disruption to the room." },
  { k: "PACING", v: "Courses timed to conversation, speeches, and the energy at the table." },
  { k: "SOURCING", v: "Season-led ingredients from farms, day-boats, and small makers." },
  { k: "CLOSEOUT", v: "Full kitchen reset—surfaces, bins, dish zone—back to zero." }
];

const PROVENANCE_DATA = [
  { id: "01", item: "Hand-Dived Scallops", origin: "Isle of Skye, Scotland", type: "Day-Boat / Hand-Dived" },
  { id: "02", item: "Périgord Black Truffle", origin: "Dordogne, France", type: "Seasonal Forage" },
  { id: "03", item: "Heritage Micro-Herbs", origin: "Atelier Garden, Local", type: "Hyper-Local Cultivation" }
];

const MENUS = [
  {
    id: "botanical",
    title: "Botanical",
    line: "Vegetable-first, knife-edge balance.",
    desc: "A seasonal vegetable menu built around acidity, smoke, and texture. Proteins appear sparingly—supporting roles, never the loudest voice.",
    courses: ["Wild Allium Tart", "Smoked Beetroot", "Mushroom Consommé", "Pine Nut Glace"]
  },
  {
    id: "ocean",
    title: "Coastal",
    line: "Cold-water clarity, bright finish.",
    desc: "Raw and lightly cooked seafood with citrus, herb oils, and gentle heat. We prioritize day-boat supply and adjust daily to landings.",
    courses: ["Scallop Crudo", "Oyster Emulsion", "Line-Caught Cod", "Sea Buckthorn"]
  },
  {
    id: "terroir",
    title: "Terroir",
    line: "Deep land, fermentation, smoke.",
    desc: "Roots, game, and preservation—balanced with sharp pickling and clean broths. Rich flavors, controlled weight, long finish.",
    courses: ["Venison Tartare", "Roasted Salsify", "Aged Duck Breast", "Blackberry & Smoke"]
  }
];

const DURATIONS = [
  { v: "3h", l: "3 Hours (Standard Dinner)" },
  { v: "4h", l: "4 Hours (Extended Course)" },
  { v: "5h", l: "5 Hours (Full Evening)" },
  { v: "custom", l: "Custom / All Day" }
];

const PAIRING_OPTS = [
  { v: "none", l: "No Pairing (Food Only)" },
  { v: "wine", l: "Wine Pairing (Sommelier Selected)" },
  { v: "non-alc", l: "Juice & Tea Pairing (House Made)" },
  { v: "mixed", l: "Mixed Pairing" }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{BRAND} — Private Dining</title>
    <meta name="description" content="Chef-led private dining, delivered with discretion. Seasonal menus, calm service, and a clean closeout." />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Manrope:wght@200;300;400;500&display=swap" rel="stylesheet">

    <style>
      :root{
        --bg: #08080A;
        --bg-panel: #0E0E12;
        --text: #EAEAE6;
        --text-mute: #8A8A90;
        
        --copper: #C28E5B;
        --copper-glow: rgba(194, 142, 91, 0.25);
        --copper-dim: rgba(194, 142, 91, 0.4);

        --line: rgba(255,255,255,0.06);
        --radius: 4px;
        
        --font-head: 'Cormorant Garamond', serif;
        --font-body: 'Manrope', sans-serif;
      }

      *{ box-sizing:border-box; }
      html,body{ height:100%; scroll-behavior:smooth; }
      body{
        margin:0; background: var(--bg); color: var(--text);
        font-family: var(--font-body); letter-spacing: 0.02em;
        overflow-x:hidden;
      }

      /* Noise Texture */
      body::before {
        content: ""; position: fixed; inset: 0; pointer-events: none; z-index: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
        mix-blend-mode: overlay;
      }

      a{ color:inherit; text-decoration:none; transition: color 0.3s; }
      
      .wrap{
        position: relative; z-index: 2; max-width: 1400px; margin: 0 auto; padding: 0 40px;
      }

      /* NAV */
      .nav-bar{
        position: fixed; top: 0; left: 0; width: 100%; z-index: 50;
        padding: 30px 40px; display: flex; justify-content: space-between; align-items: center;
        background: linear-gradient(180deg, rgba(8,8,10,0.95) 0%, rgba(8,8,10,0) 100%);
        pointer-events: none;
      }
      .nav-bar > * { pointer-events: auto; }

      /* MORPHING LOGO / EXIT BUTTON */
      .morph-brand {
        position: relative;
        height: 24px;
        min-width: 120px; /* Ensure space for the transition */
        display: flex;
        align-items: center;
        overflow: hidden;
        cursor: pointer;
        text-decoration: none;
      }
      
      .morph-layer {
        position: absolute;
        top: 0; left: 0;
        transition: transform 0.5s cubic-bezier(0.19, 1, 0.22, 1), opacity 0.4s ease;
        white-space: nowrap;
      }

      /* Layer 1: The Brand Name */
      .layer-brand {
        font-family: var(--font-head); font-size: 24px; font-weight: 600; 
        letter-spacing: 0.05em; color: var(--copper); text-transform: uppercase;
        transform: translateY(0);
        opacity: 1;
      }

      /* Layer 2: The Exit Command */
      .layer-exit {
        font-family: var(--font-body); font-size: 11px; letter-spacing: 0.15em;
        text-transform: uppercase; color: var(--text-mute);
        transform: translateY(100%);
        opacity: 0;
        display: flex; align-items: center; gap: 6px;
        height: 100%;
      }
      .layer-exit i { font-style: normal; color: var(--copper); }

      /* Hover Logic */
      .morph-brand:hover .layer-brand {
        transform: translateY(-100%);
        opacity: 0;
      }
      .morph-brand:hover .layer-exit {
        transform: translateY(0);
        opacity: 1;
        color: var(--copper); /* Highlight on full hover */
      }

      /* Menu Links */
      .menu-links{ display: flex; gap: 40px; align-items: center; }
      .menu-link{
        font-size: 11px; text-transform: uppercase; letter-spacing: 0.15em; color: var(--text-mute);
        position: relative;
      }
      .menu-link:hover{ color: var(--text); }
      .menu-link::after{
        content: ""; position: absolute; bottom: -6px; left: 0; width: 0; height: 1px; background: var(--copper);
        transition: width 0.3s ease;
      }
      .menu-link:hover::after{ width: 100%; }

      /* Reserve Button */
      .btn-book{
        padding: 12px 24px; border: 1px solid var(--copper-dim); color: var(--copper);
        font-family: var(--font-body); font-size: 11px; text-transform: uppercase; letter-spacing: 0.15em;
        background: rgba(8,8,10,0.6); backdrop-filter: blur(4px); cursor: pointer;
        transition: all 0.3s ease;
      }
      .btn-book:hover{
        background: var(--copper); color: #000; border-color: var(--copper);
        box-shadow: 0 0 30px var(--copper-glow);
      }

      /* HERO */
      .hero{
        height: 100vh; display: flex; align-items: center; justify-content: center;
        position: relative; overflow: hidden;
      }
      .hero-bg{
        position: absolute; inset: 0; z-index: -1;
      }
      .hero-bg img{
        width: 100%; height: 100%; object-fit: cover; opacity: 0.5;
        transform: scale(1.1); filter: grayscale(0.3) contrast(1.2) brightness(0.8);
        animation: slowZoom 20s infinite alternate ease-in-out;
      }
      .hero-content{ text-align: center; max-width: 800px; }
      .hero-sub{
        font-family: var(--font-body); font-size: 12px; text-transform: uppercase; letter-spacing: 0.4em;
        color: var(--copper); margin-bottom: 24px; display: block; opacity: 0; animation: fadeUp 1s forwards 0.5s;
      }
      .hero-title{
        font-family: var(--font-head); font-size: clamp(48px, 8vw, 96px); line-height: 0.9;
        margin: 0 0 40px; font-weight: 300; opacity: 0; animation: fadeUp 1s forwards 0.7s;
      }
      .hero-title i{ font-family: var(--font-head); font-weight: 400; font-style: italic; color: var(--copper); }
      
      .scroll-hint{
        position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%);
        display: flex; flex-direction: column; align-items: center; gap: 8px; opacity: 0.6;
      }
      .scroll-line{ width: 1px; height: 60px; background: linear-gradient(180deg, var(--copper), transparent); }

      /* SECTIONS */
      section{ padding: 140px 0; border-bottom: 1px solid var(--line); }

      .grid-2{ display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
      .grid-3{ display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; }

      .txt-sm{ font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--copper); margin-bottom: 16px; display: block; }
      .txt-h2{ font-family: var(--font-head); font-size: 48px; line-height: 1.1; margin: 0 0 24px; font-weight: 300; }
      .txt-p{ font-size: 16px; line-height: 1.7; color: var(--text-mute); max-width: 45ch; }

      /* PHILOSOPHY */
      .phil-list{ display: grid; gap: 40px; }
      .phil-item{ border-left: 1px solid var(--line); padding-left: 24px; transition: border-color 0.3s; }
      .phil-item:hover{ border-color: var(--copper); }
      .phil-k{ font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text); margin-bottom: 8px; }
      .phil-v{ font-family: var(--font-head); font-size: 24px; color: var(--text-mute); }

      /* PROVENANCE VISUALIZER */
      .prov-grid {
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 60px;
      }
      .prov-card {
        background: linear-gradient(145deg, rgba(255,255,255,0.02), rgba(0,0,0,0.2));
        border: 1px solid var(--line); padding: 32px;
        position: relative; overflow: hidden; transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
      }
      .prov-card::before {
        content: ""; position: absolute; inset: 0;
        background: radial-gradient(circle at 50% 0%, var(--copper-glow), transparent 70%);
        opacity: 0; transition: opacity 0.5s ease;
      }
      .prov-card:hover {
        transform: translateY(-8px); border-color: var(--copper-dim);
        box-shadow: 0 20px 40px -10px rgba(0,0,0,0.5);
      }
      .prov-card:hover::before { opacity: 1; }

      .prov-id { font-family: var(--font-body); font-size: 10px; color: var(--copper); opacity: 0.6; margin-bottom: 16px; display: block; }
      .prov-item { font-family: var(--font-head); font-size: 28px; margin-bottom: 8px; color: var(--text); position: relative; }
      .prov-origin { font-size: 14px; color: var(--text-mute); display: flex; align-items: center; gap: 8px; }
      .prov-origin::before { content:""; width: 6px; height: 6px; background: var(--copper); border-radius: 50%; display: inline-block; }
      .prov-type {
        position: absolute; bottom: 32px; right: 32px;
        font-size: 10px; text-transform: uppercase; letter-spacing: 0.2em;
        color: var(--text-mute); opacity: 0.5; writing-mode: vertical-rl;
      }

      /* MENUS */
      .menu-card{
        background: var(--bg-panel); border: 1px solid var(--line); padding: 40px;
        transition: all 0.4s ease; position: relative; overflow: hidden;
      }
      .menu-card:hover{ transform: translateY(-10px); border-color: var(--copper-dim); }
      .menu-card::before{
        content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 4px; background: var(--copper);
        transform: scaleX(0); transform-origin: left; transition: transform 0.4s ease;
      }
      .menu-card:hover::before{ transform: scaleX(1); }
      
      .menu-t{ font-family: var(--font-head); font-size: 32px; margin-bottom: 8px; }
      .menu-l{ font-size: 12px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--copper); margin-bottom: 24px; }
      .menu-desc{ font-size: 14px; color: var(--text-mute); line-height: 1.6; margin-bottom: 32px; border-bottom: 1px solid var(--line); padding-bottom: 24px; }
      .course-list{ list-style: none; padding: 0; margin: 0; }
      .course-list li{ font-family: var(--font-head); font-size: 18px; color: var(--text); margin-bottom: 8px; font-style: italic; }

      /* BOOKING */
      .booking-sec{ background: linear-gradient(180deg, var(--bg) 0%, #121216 100%); position: relative; }
      .booking-grid{ display: grid; grid-template-columns: 1fr 1.2fr; gap: 80px; }
      
      .form-panel{
        background: rgba(255,255,255,0.03); border: 1px solid var(--line); padding: 48px;
        backdrop-filter: blur(12px); box-shadow: 0 40px 100px -20px rgba(0,0,0,0.8);
      }
      .form-row{ display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px; }
      .form-group{ display: flex; flex-direction: column; gap: 8px; margin-bottom: 24px; }
      .form-group label{ font-size: 10px; text-transform: uppercase; letter-spacing: 0.15em; color: var(--text-mute); }
      
      .input, .select, textarea{
        background: rgba(0,0,0,0.3); border: 1px solid var(--line); padding: 16px;
        color: var(--text); font-family: var(--font-body); font-size: 14px;
        transition: border-color 0.3s; width: 100%;
      }
      .input:focus, .select:focus, textarea:focus{ outline: none; border-color: var(--copper); box-shadow: 0 0 20px var(--copper-glow); }
      textarea{ min-height: 120px; resize: vertical; }

      .btn-submit{
        width: 100%; background: var(--copper); color: #08080A; border: none; padding: 18px;
        font-family: var(--font-body); text-transform: uppercase; letter-spacing: 0.2em; font-weight: 600;
        cursor: pointer; transition: all 0.3s;
      }
      .btn-submit:hover{ background: #D4A370; box-shadow: 0 0 30px var(--copper-glow); }

      .ics-link{
        display: block; text-align: center; margin-top: 16px; font-size: 11px;
        color: var(--text-mute); text-decoration: underline; cursor: pointer;
      }

      /* FOOTER */
      footer{ padding: 80px 40px; border-top: 1px solid var(--line); text-align: center; }
      .foot-brand{ font-family: var(--font-head); font-size: 32px; color: var(--copper); margin-bottom: 24px; display: block; }
      .foot-meta{ color: var(--text-mute); font-size: 12px; letter-spacing: 0.1em; }

      /* UTILS */
      .reveal{ opacity: 0; transform: translateY(30px); transition: all 0.8s ease; }
      .reveal.active{ opacity: 1; transform: translateY(0); }

      @keyframes slowZoom { from { transform: scale(1.1); } to { transform: scale(1.15); } }
      @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

      @media(max-width: 900px){
        .grid-2, .grid-3, .booking-grid, .prov-grid{ grid-template-columns: 1fr; gap: 40px; }
        .hero-title{ font-size: 48px; }
        .nav-bar{ padding: 20px; flex-direction: row; justify-content: space-between; }
        .menu-links{ display: none; }
        .wrap{ padding: 0 20px; }
        .form-panel{ padding: 24px; }
        /* Mobile Morph adjustment */
        .layer-brand { font-size: 20px; }
      }
    </style>
  </head>

  <body>
    
    <nav class="nav-bar">
      <a href="/" class="morph-brand">
        <span class="morph-layer layer-brand">ATELIER</span>
        <span class="morph-layer layer-exit"><i>[</i> SYSTEM EXIT <i>]</i></span>
      </a>

      <div class="menu-links">
        {NAV.map(n => <a href={n.href} class="menu-link">{n.label}</a>)}
      </div>
      
      <a href="#reserve" class="btn-book">Reserve</a>
    </nav>

    <header class="hero">
      <div class="hero-bg"><img src={HERO_IMG} alt="Chef finishing a dish in dark atmosphere" /></div>
      <div class="hero-content">
        <span class="hero-sub">Residences • Studios • Retreats</span>
        <h1 class="hero-title">Private dining, <br><i>properly handled.</i></h1>
        <div class="scroll-hint">
          <span style="font-size:10px; letter-spacing:0.2em; color:var(--text-mute)">SCROLL</span>
          <div class="scroll-line"></div>
        </div>
      </div>
    </header>

    <div class="wrap">
      
      <section id="philosophy" class="reveal">
        <div class="grid-2">
          <div>
            <span class="txt-sm">Philosophy</span>
            <h2 class="txt-h2">Quiet service. Clear timing.</h2>
            <p class="txt-p">
              We cook in your space the way a good crew should: early arrival, clean stations, calm movement.
              Dinner stays focused on your guests, not on production. When the last course lands, we close out completely and leave the kitchen as we found it.
            </p>
          </div>
          <div class="phil-list">
            {PHILOSOPHY.map(p => (
              <div class="phil-item">
                <div class="phil-k">{p.k}</div>
                <div class="phil-v">{p.v}</div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="provenance" class="reveal">
        <span class="txt-sm" style="text-align:center">Sourcing</span>
        <h2 class="txt-h2" style="text-align:center;">Provenance, not buzzwords</h2>
        <p class="txt-p" style="text-align:center; margin: 0 auto;">
          Menus follow what’s at peak. We keep a short provenance list for each event—who grew it, who landed it, and why it’s on the table.
          Availability shifts weekly; quality doesn’t.
        </p>
        
        <div class="prov-grid">
          {PROVENANCE_DATA.map(item => (
            <div class="prov-card">
              <span class="prov-id">REF. {item.id}</span>
              <div class="prov-item">{item.item}</div>
              <div class="prov-origin">{item.origin}</div>
              <div class="prov-type">{item.type}</div>
            </div>
          ))}
        </div>
      </section>

      <section id="menu" class="reveal">
        <span class="txt-sm" style="text-align:center">Culinary Direction</span>
        <h2 class="txt-h2" style="text-align:center; margin-bottom: 60px;">Menus in rotation</h2>
        
        <div class="grid-3">
          {MENUS.map(m => (
            <div class="menu-card">
              <div class="menu-t">{m.title}</div>
              <div class="menu-l">{m.line}</div>
              <p class="menu-desc">{m.desc}</p>
              <ul class="course-list">
                {m.courses.map(c => <li>{c}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <section id="reserve" class="booking-sec reveal">
        <div class="booking-grid">
          <div>
            <span class="txt-sm">Reservations</span>
            <h2 class="txt-h2">Request availability</h2>
            <p class="txt-p" style="margin-bottom: 40px;">
              Send a structured inquiry with your date, guest count, and direction.
              We’ll reply with availability, a draft menu outline, and a clear estimate—handled personally via email.
            </p>
            <img src={DETAIL_IMG} style="width:100%; border-radius:4px; opacity:0.8;" alt="Wine detail" />
          </div>

          <div class="form-panel">
            <form id="bookingForm" onsubmit="event.preventDefault();">
              <div class="form-row">
                <div class="form-group">
                  <label>Date</label>
                  <input type="date" class="input" required id="date">
                </div>
                <div class="form-group">
                  <label>Time</label>
                  <select class="select" id="time">
                    <option>18:30 (Early)</option>
                    <option selected>19:30 (Prime)</option>
                    <option>20:30 (Late)</option>
                  </select>
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label>Guests</label>
                  <select class="select" id="guests">
                    <option>2 Guests (Intimate)</option>
                    <option>4-6 Guests (Small Group)</option>
                    <option>8-12 Guests (Dinner Party)</option>
                    <option>12+ (Event)</option>
                  </select>
                </div>
                <div class="form-group">
                  <label>Duration</label>
                  <select class="select" id="duration">
                    {DURATIONS.map(d => <option value={d.v}>{d.l}</option>)}
                  </select>
                </div>
              </div>

              <div class="form-group">
                <label>Menu Direction</label>
                <select class="select" id="menuSelect">
                  {MENUS.map(m => <option value={m.title}>{m.title} — {m.line}</option>)}
                </select>
              </div>

              <div class="form-group">
                <label>Wine / Pairing</label>
                <select class="select" id="pairing">
                  {PAIRING_OPTS.map(p => <option value={p.v}>{p.l}</option>)}
                </select>
              </div>

              <div class="form-group">
                <label>Name</label>
                <input type="text" class="input" placeholder="Your Name" id="name">
              </div>

              <div class="form-group">
                <label>Requests / Dietary</label>
                <textarea class="input" placeholder="Allergies, dislikes, and any timing notes (toasts, speeches, etc.)."></textarea>
              </div>

              <button class="btn-submit" id="submitBtn">Generate Request</button>
              <a id="icsLink" class="ics-link" style="display:none">Download Calendar Invite (.ics)</a>
            </form>
          </div>
        </div>
      </section>

    </div>

    <footer>
      <span class="foot-brand">{BRAND}</span>
      <div class="foot-meta">
        &copy; 2024 Atelier Private Catering. All rights reserved.<br>
        {BOOKING_EMAIL}
      </div>
    </footer>

    <script>
      // Scroll Reveal
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if(entry.isIntersecting) entry.target.classList.add('active');
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

      // Booking Logic
      const btn = document.getElementById('submitBtn');
      const icsLink = document.getElementById('icsLink');

      if(btn && icsLink) {
        btn.addEventListener('click', () => {
          const name = (document.getElementById('name') as HTMLInputElement).value || 'Guest';
          const date = (document.getElementById('date') as HTMLInputElement).value || new Date().toISOString();
          const menu = (document.getElementById('menuSelect') as HTMLSelectElement).value;
          
          // Generate Mailto
          const subject = `Reservation Request: ${name} - ${menu}`;
          const body = `I would like to request a reservation.\n\nDate: ${date}\nMenu: ${menu}\n\nPlease confirm availability.`;
          window.location.href = `mailto:${'reservations@atelier.dining'}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

          // Generate Fake ICS (Simulated)
          const icsContent = `BEGIN:VCALENDAR\nVERSION:2.0\nBEGIN:VEVENT\nSUMMARY:Dinner at Atelier\nDESCRIPTION:Menu: ${menu}\nEND:VEVENT\nEND:VCALENDAR`;
          const blob = new Blob([icsContent], { type: 'text/calendar' });
          icsLink.setAttribute('href', URL.createObjectURL(blob));
          icsLink.setAttribute('download', 'dinner.ics');
          icsLink.style.display = 'block';
          icsLink.innerText = 'Invite Generated - Click to Download';
        });
      }
    </script>
  </body>
</html>

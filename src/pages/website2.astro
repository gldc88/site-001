---
const HOTEL = "NOCTURNE HOTEL";
const TAGLINE = "Neon outside, hush within.";
const CITYLINE = "Tokyo, Minato, After Dark Address";

const NAV = [
  { label: "Suites", href: "#suites" },
  { label: "Kitchen", href: "#dining" },
  { label: "Bathhouse", href: "#spa" },
  { label: "Rituals", href: "#experiences" },
  { label: "Frames", href: "#gallery" },
  { label: "Find Us", href: "#location" },
];

const HERO_IMG =
  "https://images.unsplash.com/photo-1520607162513-77705c0f0d4a?auto=format&fit=crop&w=2200&q=80";
const SUITE_1 =
  "https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?auto=format&fit=crop&w=1400&q=80";
const SUITE_2 =
  "https://images.unsplash.com/photo-1541971875076-8f970d573be6?auto=format&fit=crop&w=1400&q=80";
  
// FIXED: Working Garden Image (Mood: Dark wood/greenery)
const SUITE_3 =
  "https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?auto=format&fit=crop&w=1400&q=80";

const DINING_IMG =
  "https://images.unsplash.com/photo-1529692236671-f1f6cf9683ba?auto=format&fit=crop&w=2000&q=80";
const SPA_IMG =
  "https://images.unsplash.com/photo-1544161515-4ab6ce6db874?auto=format&fit=crop&w=2000&q=80";

const GALLERY = [
  "https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?auto=format&fit=crop&w=1400&q=80",
  "https://images.unsplash.com/photo-1523906834658-6e24ef2386f9?auto=format&fit=crop&w=1400&q=80",
  // FIXED: Working Architecture Detail (Mood: Shadow/Form)
  "https://images.unsplash.com/photo-1518602164578-cd0074062767?auto=format&fit=crop&w=1400&q=80",
  "https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&fit=crop&w=1400&q=80",
  "https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=1400&q=80",
];

const EXPERIENCES = [
  {
    title: "Lantern Tea, Late",
    line: "Warm cup, quiet hands, slow breathing.",
  },
  {
    title: "Rooftop Rain Walk",
    line: "Umbrella, skyline, your thoughts finally turning down.",
  },
  {
    title: "Private Listening Room",
    line: "Vinyl, velvet, and a drink that arrives before you ask.",
  },
];

const SUITES = [
  {
    title: "Atrium Suite",
    line: "Stone warmth, soft shadow, a room that lowers your pulse.",
    img: SUITE_1,
  },
  {
    title: "Corner Panorama",
    line: "Glass edge, city glow, blackout calm when you want it.",
    img: SUITE_2,
  },
  {
    title: "Garden Residence",
    line: "Wood grain, green hush, air that feels private.",
    img: SUITE_3,
  },
];

const ROOM_TYPES = ["Atrium Suite", "Corner Panorama", "Garden Residence", "Signature Penthouse"];
const GUEST_OPTIONS = ["1", "2", "3", "4"];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{HOTEL} | Tokyo After Dark</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&family=Inter:wght@300;400;500&family=JetBrains+Mono:wght@400&display=swap"
      rel="stylesheet"
    />

    <style>
      :root{
        --bg:#050506;
        --bg2:#0b0b0d;
        --stone:#111114;
        --ink: rgba(236, 230, 214, .86);
        --muted: rgba(236, 230, 214, .56);
        --faint: rgba(236, 230, 214, .36);

        --ember: rgba(203, 164, 98, 1);
        --ember2: rgba(203, 164, 98, .68);
        --line: rgba(255,255,255,.08);
        --line2: rgba(203,164,98,.18);
        --shadow: rgba(0,0,0,.66);
        --glass: rgba(255,255,255,.03);

        --r12: 12px;
        --r16: 16px;
        --r20: 20px;
      }

      *{ box-sizing:border-box; }
      html,body{ height:100%; scroll-behavior: smooth; }
      body{
        margin:0;
        background: var(--bg);
        color: var(--ink);
        font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
        letter-spacing: .01em;
        overflow-x:hidden;
      }

      /* Cinematic ambience */
      body::before{
        content:"";
        position:fixed;
        inset:0;
        pointer-events:none;
        background:
          radial-gradient(1100px 640px at 16% 12%, rgba(203,164,98,.12), transparent 62%),
          radial-gradient(900px 520px at 80% 18%, rgba(203,164,98,.08), transparent 64%),
          radial-gradient(980px 720px at 50% 92%, rgba(255,255,255,.03), transparent 62%),
          linear-gradient(180deg, rgba(255,255,255,.02), transparent 25%, transparent 78%, rgba(0,0,0,.35));
        opacity:1;
        z-index: 0;
      }
      body::after{
        content:"";
        position:fixed;
        inset:0;
        pointer-events:none;
        background: radial-gradient(1200px 900px at 50% 40%, transparent 52%, rgba(0,0,0,.72) 100%);
        mix-blend-mode:multiply;
        z-index: 0;
      }

      a{ color:inherit; text-decoration:none; }
      a:focus-visible{ outline:2px solid rgba(203,164,98,.55); outline-offset:3px; border-radius: 10px; }

      .wrap{
        position:relative;
        max-width: 1240px;
        margin: 0 auto;
        padding: 24px 18px 80px;
        z-index: 1;
      }

      /* Topbar */
      .topbar{
        position:sticky;
        top:0;
        z-index:50;
        backdrop-filter: blur(20px);
        background: rgba(7,7,8,0.7);
        border-bottom: 1px solid rgba(255,255,255,.04);
        transition: background 0.3s ease;
      }
      .topbar-inner{
        max-width: 1240px;
        margin: 0 auto;
        padding: 14px 18px;
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap:16px;
      }

      /* FIXED: BACK LINK */
      .back-link {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: JetBrains Mono, monospace;
        font-size: 10px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: rgba(236,230,214,0.5);
        transition: color 0.2s;
        margin-right: 20px;
      }
      .back-link:hover {
        color: var(--ember);
      }

      .brand{
        display:flex;
        flex-direction:column;
        gap:3px;
        min-width: 220px;
      }
      .brand .name{
        font-family: Cinzel, Georgia, serif;
        font-weight:600;
        font-size: 14px;
        letter-spacing:.22em;
        text-transform:uppercase;
        color: rgba(203,164,98,.95);
        text-shadow: 0 0 20px rgba(203,164,98,.2);
      }
      .brand .sub{
        font-family: JetBrains Mono, monospace;
        font-size: 10px;
        letter-spacing:.24em;
        text-transform:uppercase;
        color: rgba(236,230,214,.34);
      }

      nav{
        display:flex;
        align-items:center;
        gap: 18px;
        flex: 1;
        justify-content:center;
        min-width: 0;
      }
      nav a{
        font-family: Cinzel, Georgia, serif;
        font-weight: 400;
        font-size: 14px;
        letter-spacing: .12em;
        color: rgba(236,230,214,.62);
        padding: 10px 10px;
        border-radius: 999px;
        transition: all .3s ease;
        white-space: nowrap;
      }
      nav a:hover{
        color: rgba(203,164,98,1);
        text-shadow: 0 0 10px rgba(203,164,98,.4);
      }

      .reserve{
        display:flex;
        align-items:center;
        gap:10px;
        min-width: 190px;
        justify-content:flex-end;
      }
      .reserve a{
        display:inline-flex;
        align-items:center;
        justify-content:center;
        height: 38px;
        padding: 0 14px;
        border-radius: 999px;
        border: 1px solid rgba(203,164,98,.26);
        background: rgba(203,164,98,.06);
        color: rgba(203,164,98,.95);
        font-family: JetBrains Mono, monospace;
        font-size: 11px;
        letter-spacing:.18em;
        text-transform: uppercase;
        transition: all 0.3s ease;
      }
      .reserve a:hover{
        transform: translateY(-1px);
        border-color: rgba(203,164,98,.6);
        background: rgba(203,164,98,.15);
        box-shadow: 0 0 20px rgba(203,164,98,.15);
      }

      /* Hero */
      .hero{
        padding: 34px 0 18px;
      }
      .hero-grid{
        display:grid;
        gap: 18px;
        align-items: stretch;
      }

      .hero-copy{
        border: 1px solid rgba(255,255,255,.07);
        border-radius: var(--r20);
        background: linear-gradient(180deg, rgba(255,255,255,.02), rgba(0,0,0,.35));
        box-shadow: 0 30px 90px var(--shadow);
        padding: 32px;
        overflow:hidden;
        position:relative;
      }
      .hero-copy::before{
        content:"";
        position:absolute;
        inset:-1px;
        background:
          radial-gradient(700px 360px at 12% 10%, rgba(203,164,98,.10), transparent 62%),
          radial-gradient(520px 320px at 74% 30%, rgba(255,255,255,.03), transparent 62%);
        pointer-events:none;
        opacity:.95;
      }

      .micro{
        font-family: JetBrains Mono, monospace;
        font-size: 10px;
        letter-spacing:.26em;
        text-transform: uppercase;
        color: rgba(236,230,214,.38);
        position:relative;
      }

      .h1{
        margin: 18px 0 14px;
        font-family: Cinzel, Georgia, serif;
        font-weight: 600;
        font-size: clamp(36px, 4.2vw, 64px);
        line-height: .95;
        letter-spacing: .04em;
        position:relative;
        background: linear-gradient(180deg, #ECE6D6 0%, #A8A08E 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .h1 .ember{
        color: rgba(203,164,98,.95);
        -webkit-text-fill-color: rgba(203,164,98,.95);
      }

      .tagline{
        margin: 0;
        max-width: 62ch;
        color: rgba(236,230,214,.64);
        line-height: 1.8;
        font-size: 14px;
        position:relative;
      }

      .hero-pills{
        margin-top: 24px;
        display:flex;
        flex-wrap:wrap;
        gap: 10px;
        position:relative;
      }
      .pill{
        display:inline-flex;
        align-items:center;
        gap:8px;
        padding: 10px 14px;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,.08);
        background: rgba(255,255,255,.02);
        color: rgba(236,230,214,.70);
        font-family: JetBrains Mono, monospace;
        font-size: 10px;
        letter-spacing:.18em;
        text-transform: uppercase;
        transition: background 0.3s;
      }
      .pill:hover {
        background: rgba(255,255,255,.05);
        border-color: rgba(255,255,255,.15);
      }
      .pill i{
        display:inline-block;
        width: 6px; height: 6px;
        border-radius: 999px;
        background: rgba(203,164,98,.80);
        box-shadow: 0 0 8px rgba(203,164,98,.4);
        animation: pulse 4s infinite;
      }

      @keyframes pulse {
        0%, 100% { opacity: 0.6; transform: scale(1); }
        50% { opacity: 1; transform: scale(1.2); }
      }

      .hero-visual{
        border-radius: var(--r20);
        overflow:hidden;
        border: 1px solid rgba(255,255,255,.07);
        background: rgba(0,0,0,.25);
        box-shadow: 0 30px 90px rgba(0,0,0,.65);
        position:relative;
        min-height: 420px;
      }
      .hero-visual::after{
        content:"";
        position:absolute;
        inset:0;
        pointer-events:none;
        background:
          linear-gradient(90deg, rgba(0,0,0,.55), transparent 45%, rgba(0,0,0,.58)),
          linear-gradient(180deg, rgba(0,0,0,.15), transparent 45%, rgba(0,0,0,.72));
      }
      .hero-visual img{
        display:block;
        width:100%;
        height:100%;
        object-fit: cover;
        filter: saturate(.9) contrast(1.06) brightness(.86);
        transform: scale(1.02);
        transition: transform 3s ease-out;
        will-change: transform;
      }
      .hero-visual:hover img {
        transform: scale(1.05);
      }

      .hero-hud{
        position:absolute;
        left: 16px;
        right: 16px;
        bottom: 14px;
        display:flex;
        align-items:flex-end;
        justify-content:space-between;
        gap: 14px;
        pointer-events:none;
      }
      .hud{
        border: 1px solid rgba(255,255,255,.10);
        background: rgba(0,0,0,.4);
        backdrop-filter: blur(12px);
        border-radius: 14px;
        padding: 10px 14px;
      }
      .hud .k{
        font-family: JetBrains Mono, monospace;
        font-size: 10px;
        letter-spacing:.22em;
        text-transform: uppercase;
        color: rgba(203,164,98,.92);
      }
      .hud .v{
        margin-top: 6px;
        font-size: 12px;
        color: rgba(236,230,214,.8);
        letter-spacing:.02em;
      }

      /* Sections */
      .section{
        margin-top: 32px;
        border-radius: var(--r20);
        border: 1px solid rgba(255,255,255,.07);
        background: linear-gradient(180deg, rgba(255,255,255,.02), rgba(0,0,0,.34));
        box-shadow: 0 26px 80px rgba(0,0,0,.55);
        overflow:hidden;
      }
      .section-inner{
        padding: 22px;
      }

      .section-head{
        display:flex;
        align-items:flex-end;
        justify-content:space-between;
        gap: 16px;
        margin-bottom: 14px;
      }
      .h2{
        margin:0;
        font-family: Cinzel, Georgia, serif;
        font-weight: 600;
        letter-spacing:.06em;
        font-size: 22px;
        color: rgba(236,230,214,.90);
      }
      .hint{
        font-family: JetBrains Mono, monospace;
        font-size: 10px;
        letter-spacing:.22em;
        text-transform: uppercase;
        color: rgba(236,230,214,.34);
        white-space: nowrap;
      }
      .rule{
        height:1px;
        background: linear-gradient(90deg, transparent, rgba(203,164,98,.22), transparent);
        margin: 14px 0 0;
      }

      /* Suites grid */
      .cards{
        display:grid;
        gap: 14px;
        margin-top: 18px;
      }
      .card{
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,.07);
        background: rgba(0,0,0,.22);
        overflow:hidden;
        display:grid;
        grid-template-columns: 1fr;
        transition: transform .3s ease, border-color .3s ease, box-shadow .3s ease;
      }
      .card:hover{
        transform: translateY(-4px);
        border-color: rgba(203,164,98,.3);
        box-shadow: 0 20px 70px rgba(0,0,0,.7);
      }
      .card-img{
        position:relative;
        height: 200px;
        overflow:hidden;
      }
      .card-img::after{
        content:"";
        position:absolute;
        inset:0;
        background: linear-gradient(180deg, transparent 45%, rgba(0,0,0,.78));
        pointer-events:none;
      }
      .card-img img{
        width:100%;
        height:100%;
        object-fit:cover;
        filter: saturate(.92) contrast(1.08) brightness(.86);
        transform: scale(1.02);
        transition: transform 1s ease;
      }
      .card:hover .card-img img{
        transform: scale(1.05);
      }
      .card-body{
        padding: 18px;
      }
      .card-title{
        margin:0;
        font-family: Cinzel, Georgia, serif;
        font-weight: 600;
        letter-spacing:.04em;
        font-size: 18px;
        color: rgba(236,230,214,.92);
      }
      .card-line{
        margin: 8px 0 0;
        color: rgba(236,230,214,.60);
        font-size: 13px;
        line-height: 1.7;
      }

      /* Feature split */
      .feature{
        display:grid;
        gap: 14px;
        margin-top: 18px;
      }
      .feature-panel{
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,.07);
        background: rgba(0,0,0,.18);
        overflow:hidden;
        position:relative;
      }
      .feature-grid{
        display:grid;
        gap: 12px;
      }
      .feature-visual{
        border-radius: 16px;
        overflow:hidden;
        border: 1px solid rgba(255,255,255,.06);
        position:relative;
        height: 260px;
      }
      .feature-visual::after{
        content:"";
        position:absolute;
        inset:0;
        background:
          linear-gradient(90deg, rgba(0,0,0,.68), transparent 55%),
          linear-gradient(180deg, rgba(0,0,0,.18), transparent 55%, rgba(0,0,0,.72));
        pointer-events:none;
      }
      .feature-visual img{
        width:100%;
        height:100%;
        object-fit: cover;
        filter: saturate(.9) contrast(1.06) brightness(.85);
        transform: scale(1.03);
        will-change: transform;
      }
      .feature-copy{
        padding: 16px;
      }
      .feature-title{
        margin: 0;
        font-family: Cinzel, Georgia, serif;
        font-weight: 600;
        letter-spacing:.05em;
        font-size: 18px;
        color: rgba(236,230,214,.92);
      }
      .feature-text{
        margin: 10px 0 0;
        color: rgba(236,230,214,.62);
        font-size: 13px;
        line-height: 1.8;
      }
      .feature-tags{
        margin-top: 16px;
        display:flex;
        flex-wrap:wrap;
        gap: 8px;
      }
      .tag{
        padding: 6px 12px;
        border-radius: 999px;
        border: 1px solid rgba(203,164,98,.16);
        background: rgba(203,164,98,.05);
        color: rgba(203,164,98,.88);
        font-family: JetBrains Mono, monospace;
        font-size: 10px;
        letter-spacing:.18em;
        text-transform: uppercase;
      }

      /* Experiences */
      .xp{
        display:grid;
        gap: 12px;
        margin-top: 18px;
      }
      .xp-item{
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,.07);
        background: rgba(0,0,0,.18);
        padding: 18px;
        transition: transform .2s ease, border-color .2s ease, box-shadow .2s ease;
      }
      .xp-item:hover{
        transform: translateY(-2px);
        border-color: rgba(203,164,98,.22);
        box-shadow: 0 18px 60px rgba(0,0,0,.55);
      }
      .xp-title{
        margin:0;
        font-family: Cinzel, Georgia, serif;
        font-weight: 600;
        letter-spacing:.05em;
        font-size: 16px;
        color: rgba(236,230,214,.92);
      }
      .xp-line{
        margin: 8px 0 0;
        color: rgba(236,230,214,.60);
        font-size: 13px;
        line-height: 1.75;
      }

      /* Gallery strip */
      .strip{
        margin-top: 18px;
        display:grid;
        gap: 10px;
        grid-template-columns: repeat(2, 1fr);
      }
      .strip figure{
        margin:0;
        border-radius: 16px;
        overflow:hidden;
        border: 1px solid rgba(255,255,255,.07);
        background: rgba(0,0,0,.18);
        position:relative;
        height: 160px;
        transition: transform 0.3s ease;
      }
      .strip figure:hover{
        transform: scale(0.98);
        border-color: rgba(203,164,98,.3);
      }
      .strip figure::after{
        content:"";
        position:absolute;
        inset:0;
        background: linear-gradient(180deg, transparent 55%, rgba(0,0,0,.70));
        pointer-events:none;
      }
      .strip img{
        width:100%;
        height:100%;
        object-fit: cover;
        filter: saturate(.9) contrast(1.06) brightness(.84);
        transform: scale(1.02);
        transition: transform 0.5s ease;
      }
      .strip figure:hover img{
        transform: scale(1.1);
      }

      /* Location + Booking */
      .two{
        display:grid;
        gap: 14px;
        margin-top: 18px;
      }
      .panel{
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,.07);
        background: rgba(0,0,0,.18);
        padding: 24px;
      }
      .panel h3{
        margin:0;
        font-family: Cinzel, Georgia, serif;
        font-weight:600;
        letter-spacing:.05em;
        font-size: 16px;
        color: rgba(236,230,214,.92);
      }
      .panel p{
        margin: 10px 0 0;
        color: rgba(236,230,214,.62);
        font-size: 13px;
        line-height: 1.8;
      }

      .form{
        display:grid;
        gap: 10px;
        margin-top: 12px;
      }
      .row{
        display:grid;
        gap: 10px;
      }
      label{
        font-family: JetBrains Mono, monospace;
        font-size: 10px;
        letter-spacing:.22em;
        text-transform: uppercase;
        color: rgba(236,230,214,.38);
      }
      input, select{
        width:100%;
        height: 44px;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,.08);
        background: rgba(255,255,255,.02);
        color: rgba(236,230,214,.86);
        padding: 0 12px;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
      }
      input:focus, select:focus{
        border-color: rgba(203,164,98,.30);
        box-shadow: 0 0 0 4px rgba(203,164,98,.08);
      }
      .submit{
        margin-top: 8px;
        display:flex;
        gap: 10px;
        align-items:center;
        justify-content:space-between;
      }
      .btn{
        display:inline-flex;
        align-items:center;
        justify-content:center;
        height: 42px;
        padding: 0 18px;
        border-radius: 12px;
        border: 1px solid rgba(203,164,98,.26);
        background: rgba(203,164,98,.08);
        color: rgba(203,164,98,.95);
        font-family: JetBrains Mono, monospace;
        font-size: 11px;
        letter-spacing:.18em;
        text-transform: uppercase;
        transition: all 0.2s ease;
      }
      .btn:hover{
        transform: translateY(-1px);
        border-color: rgba(203,164,98,.42);
        background: rgba(203,164,98,.12);
        box-shadow: 0 18px 50px rgba(0,0,0,.45);
      }
      .note{
        color: rgba(236,230,214,.40);
        font-size: 12px;
        line-height: 1.7;
      }

      /* Reveal (Visual Upgrade: Blur + Slide) */
      .reveal{
        opacity: 0;
        filter: blur(10px);
        transform: translateY(20px);
        transition: opacity 1s cubic-bezier(.16,1,.3,1), transform 1s cubic-bezier(.16,1,.3,1), filter 1s ease;
        will-change: opacity, transform, filter;
      }
      .reveal.on{
        opacity: 1;
        filter: blur(0);
        transform: translateY(0);
      }

      /* Footer */
      footer{
        margin-top: 60px;
        padding-top: 24px;
        border-top: 1px solid rgba(255,255,255,.06);
        color: rgba(236,230,214,.32);
        font-family: JetBrains Mono, monospace;
        font-size: 10px;
        letter-spacing:.22em;
        text-transform: uppercase;
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap: 12px;
        flex-wrap:wrap;
      }

      @media (min-width: 980px){
        .hero-grid{
          grid-template-columns: 1.05fr .95fr;
          gap: 24px;
        }
        .hero-copy { padding: 40px; }
        .cards{
          grid-template-columns: repeat(3, 1fr);
          gap: 20px;
        }
        .feature-grid{
          grid-template-columns: 1fr 1fr;
          align-items: stretch;
          gap: 0;
        }
        .feature-visual{ height: 320px; border-radius: 16px 0 0 16px; border-right: none; }
        .feature-copy { padding: 30px; display: flex; flex-direction: column; justify-content: center; }
        .xp{
          grid-template-columns: repeat(3, 1fr);
          gap: 20px;
        }
        .strip{
          grid-template-columns: repeat(5, 1fr);
          gap: 16px;
        }
        .strip figure{ height: 180px; }
        .two{
          grid-template-columns: 1fr 1fr;
          gap: 24px;
        }
        .row{
          grid-template-columns: 1fr 1fr;
        }
      }

      @media (max-width: 560px){
        nav{ display:none; }
        .reserve{ min-width: auto; }
      }

      @media (prefers-reduced-motion: reduce){
        html, body { scroll-behavior:auto; }
        .reveal{ opacity:1; transform:none; transition:none; filter:none; }
        .card:hover, .xp-item:hover, .btn:hover, .reserve a:hover { transform:none; }
        .hero-visual img, .feature-visual img { transform:none; }
      }
    </style>
  </head>

  <body>
    <header class="topbar">
      <div class="topbar-inner">
        <a href="/" class="back-link">← INDEX</a>

        <div class="brand" aria-label="Hotel brand">
          <div class="name">{HOTEL}</div>
          <div class="sub">{CITYLINE}</div>
        </div>

        <nav aria-label="Primary">
          {NAV.map((l) => (
            <a href={l.href}>{l.label}</a>
          ))}
        </nav>

        <div class="reserve">
          <a href="#booking" aria-label="Reserve now">Book Tonight</a>
        </div>
      </div>
    </header>

    <main class="wrap">
      <section class="hero">
        <div class="hero-grid">
          <div class="hero-copy reveal">
            <div class="micro">NOCTURNE HOTEL // TOKYO</div>
            <h1 class="h1">
              {TAGLINE} <span class="ember">Nocturne.</span>
            </h1>
            <p class="tagline">
              Tokyo moves fast, bright, loud. We do not.
              Step inside, drop your shoulders, let the stone do its job.
              Late dining, warm baths, and rooms built for deep sleep, not small talk.
            </p>

            <div class="hero-pills" aria-label="Highlights">
              <span class="pill"><i></i> Late Check-In</span>
              <span class="pill"><i></i> Omakase Counter</span>
              <span class="pill"><i></i> Bathhouse</span>
              <span class="pill"><i></i> Private Lift</span>
            </div>
          </div>

          <aside class="hero-visual reveal" aria-label="Hero visual">
            <img src={HERO_IMG} alt="Lantern lit interior, low light, stone and shadow" loading="eager" decoding="async" />
            <div class="hero-hud" aria-hidden="true">
              <div class="hud">
                <div class="k">FIG_01 // LOBBY</div>
                <div class="v">Lantern light, calm tone</div>
              </div>
              <div class="hud">
                <div class="k">STATUS</div>
                <div class="v">Rates and rooms live</div>
              </div>
            </div>
          </aside>
        </div>
      </section>

      <section class="section reveal" id="suites" aria-label="Suites">
        <div class="section-inner">
          <div class="section-head">
            <h2 class="h2">Suites</h2>
            <div class="hint">Three moods</div>
          </div>
          <div class="rule" aria-hidden="true"></div>

          <div class="cards" aria-label="Suite cards">
            {SUITES.map((s) => (
              <article class="card">
                <div class="card-img">
                  <img src={s.img} alt={s.title} loading="lazy" decoding="async" />
                </div>
                <div class="card-body">
                  <h3 class="card-title">{s.title}</h3>
                  <p class="card-line">{s.line}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section reveal" id="dining" aria-label="Dining">
        <div class="section-inner">
          <div class="section-head">
            <h2 class="h2">Kitchen</h2>
            <div class="hint">Late seating</div>
          </div>
          <div class="rule" aria-hidden="true"></div>

          <div class="feature">
            <div class="feature-panel">
              <div class="feature-grid">
                <div class="feature-visual">
                  <img src={DINING_IMG} alt="Warm dining room with candlelight and wood tones" loading="lazy" decoding="async" />
                </div>
                <div class="feature-copy">
                  <div class="micro">KITCHEN_01 // COUNTER</div>
                  <h3 class="feature-title">Lantern Course</h3>
                  <p class="feature-text">
                    Seasonal plates with sharp technique and soft pacing.
                    Smoke, salt, citrus, and a quiet room where you can actually hear yourself think.
                  </p>
                  <div class="feature-tags" aria-label="Dining tags">
                    <span class="tag">Omakase</span>
                    <span class="tag">Late Service</span>
                    <span class="tag">Sake Cellar</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section reveal" id="spa" aria-label="Spa">
        <div class="section-inner">
          <div class="section-head">
            <h2 class="h2">Bathhouse</h2>
            <div class="hint">Reset</div>
          </div>
          <div class="rule" aria-hidden="true"></div>

          <div class="feature">
            <div class="feature-panel">
              <div class="feature-grid">
                <div class="feature-copy">
                  <div class="micro">BATH_01 // RECOVERY</div>
                  <h3 class="feature-title">Steam, Soak, Still</h3>
                  <p class="feature-text">
                    Hot water, cold plunge, and a slow return to baseline.
                    Low light on purpose, silence on purpose, the kind of calm you feel in your jaw.
                  </p>
                  <div class="feature-tags" aria-label="Spa tags">
                    <span class="tag">Sauna</span>
                    <span class="tag">Cold Plunge</span>
                    <span class="tag">Massage</span>
                  </div>
                </div>
                <div class="feature-visual">
                  <img src={SPA_IMG} alt="Steam bath and warm spa lighting" loading="lazy" decoding="async" />
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section reveal" id="experiences" aria-label="Experiences">
        <div class="section-inner">
          <div class="section-head">
            <h2 class="h2">Rituals</h2>
            <div class="hint">By request</div>
          </div>
          <div class="rule" aria-hidden="true"></div>

          <div class="xp" aria-label="Experience cards">
            {EXPERIENCES.map((x) => (
              <div class="xp-item">
                <h3 class="xp-title">{x.title}</h3>
                <p class="xp-line">{x.line}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="section reveal" id="gallery" aria-label="Gallery">
        <div class="section-inner">
          <div class="section-head">
            <h2 class="h2">Frames</h2>
            <div class="hint">Details</div>
          </div>
          <div class="rule" aria-hidden="true"></div>

          <div class="strip" aria-label="Gallery strip">
            {GALLERY.map((src, idx) => (
              <figure aria-label={`Gallery image ${idx + 1}`}>
                <img src={src} alt={`Nocturne detail ${idx + 1}`} loading="lazy" decoding="async" />
              </figure>
            ))}
          </div>
        </div>
      </section>

      <section class="section reveal" id="location" aria-label="Location and Contact">
        <div class="section-inner">
          <div class="section-head">
            <h2 class="h2">Find Us</h2>
            <div class="hint">Minato</div>
          </div>
          <div class="rule" aria-hidden="true"></div>

          <div class="two">
            <div class="panel">
              <h3>Address</h3>
              <p>
                Minato City, Tokyo<br />
                106-0032, Japan<br />
                +81 3 5550 1234<br />
                concierge@nocturnehotel.jp
              </p>
              <p>
                Check-in: 15:00 to 24:00<br />
                Check-out: 12:00
              </p>
            </div>

            <div class="panel" id="booking" aria-label="Booking panel">
              <h3>Book a Stay</h3>
              <p class="note">Choose dates and guests, we will show live rates.</p>

              <form class="form" action="#" method="get">
                <div class="row">
                  <div>
                    <label for="in">Check-in</label>
                    <input id="in" name="in" type="date" />
                  </div>
                  <div>
                    <label for="out">Check-out</label>
                    <input id="out" name="out" type="date" />
                  </div>
                </div>

                <div class="row">
                  <div>
                    <label for="guests">Guests</label>
                    <select id="guests" name="guests">
                      {GUEST_OPTIONS.map((g) => (
                        <option value={g}>{g}</option>
                      ))}
                    </select>
                  </div>
                  <div>
                    <label for="room">Room</label>
                    <select id="room" name="room">
                      {ROOM_TYPES.map((r) => (
                        <option value={r}>{r}</option>
                      ))}
                    </select>
                  </div>
                </div>

                <div class="submit">
                  <button class="btn" type="submit">Show Rates</button>
                  <div class="note">Fast confirmation, no noise.</div>
                </div>
              </form>
            </div>
          </div>
        </div>
      </section>

      <footer aria-label="Footer">
        <span>NOCTURNE HOTEL</span>
        <span>NEON // STONE // REST</span>
        <span>MINATO EDITION</span>
      </footer>
    </main>

    <script is:inline>
      (() => {
        /** @type {boolean} */
        const reduceMotion = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        // Smooth anchor scroll (kept calm)
        if (!reduceMotion) {
          /** @type {NodeListOf<HTMLAnchorElement>} */
          const anchors = document.querySelectorAll('a[href^="#"]');
          anchors.forEach((a) => {
            a.addEventListener("click", (e) => {
              const href = a.getAttribute("href");
              if (!href) return;

              const id = href.slice(1);
              if (!id) return;

              const target = document.getElementById(id);
              if (!target) return;

              e.preventDefault();
              target.scrollIntoView({ behavior: "smooth", block: "start" });
              history.replaceState(null, "", href);
            });
          });
        }

        // Reveal on scroll
        /** @type {NodeListOf<HTMLElement>} */
        const items = document.querySelectorAll(".reveal");
        if (reduceMotion) {
          items.forEach((el) => el.classList.add("on"));
          return;
        }

        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                /** @type {HTMLElement} */ (entry.target).classList.add("on");
              }
            });
          },
          { threshold: 0.14 }
        );

        items.forEach((el) => io.observe(el));

        // Micro-parallax for hero image (subtle)
        const heroImg = document.querySelector(".hero-visual img");
        if (heroImg && heroImg instanceof HTMLImageElement) {
          let raf = 0;
          const onScroll = () => {
            if (raf) return;
            raf = window.requestAnimationFrame(() => {
              raf = 0;
              const y = window.scrollY || 0;
              const t = Math.min(18, Math.max(0, y * 0.03));
              heroImg.style.transform = `scale(1.03) translateY(${t}px)`;
            });
          };
          window.addEventListener("scroll", onScroll, { passive: true });
          onScroll();
        }
      })();
    </script>
  </body>
</html>

---
const BRAND = "GREENLINE TREE SURGERY";

const NAV = [
  { label: "Services", href: "#services" },
  { label: "Recent Work", href: "#work" },
  { label: "Areas", href: "#areas" },
  { label: "FAQ", href: "#faq" },
  { label: "Contact", href: "#contact" },
];

const CONTACT = {
  phoneDisplay: "07 900 123 456",
  phoneHref: "tel:+447900123456",
  emailDisplay: "hello@greenlinetrees.example",
  emailHref: "mailto:hello@greenlinetrees.example",
  hours: "Mon–Sat 08:00–18:00",
  note: "Example site — replace phone/email with real details.",
};

const SERVICES = [
  { title: "Crown Reduction", line: "Reduce height and spread while keeping a natural shape.", meta: "Pruning & Balance" },
  { title: "Crown Lift & Thin", line: "More clearance and light through the canopy.", meta: "Light & Clearance" },
  { title: "Tree Removal", line: "Straight fell where possible, or sectional dismantle with rigging.", meta: "Safe Removal" },
  { title: "Stump Grinding", line: "Stumps removed below ground level, area left tidy.", meta: "Ground Works" },
  { title: "Hedge Cutting", line: "Annual trims, reductions, and boundary shaping.", meta: "Hedges & Screens" },
  { title: "Emergency Call-outs", line: "Storm damage, hanging limbs, and hazard make-safe work.", meta: "Rapid Response" },
];

const SPECS = [
  { k: "INSURED", v: "£10M Public Liability" },
  { k: "QUALIFIED", v: "NPTC / LANTRA" },
  { k: "SAFE WORK", v: "Risk assessment on-site" },
  { k: "TIDY FINISH", v: "Waste removed / recycled" },
];

const PROCESS = [
  { id: "01", t: "Free Call or Message", d: "Tell us what you need and where you are. Photos help." },
  { id: "02", t: "Site Visit", d: "We check access, hazards, wildlife, and any TPO / conservation constraints." },
  { id: "03", t: "Fixed Quote", d: "Clear scope, clear price, and a date that works for you." },
  { id: "04", t: "Job Day", d: "Safe rigging, controlled cuts, and the site left clean and tidy." },
];

const WORK = [
  { title: "Conifer Reduction", where: "Residential garden", what: "Reduced height and reshaped for light." },
  { title: "Sectional Dismantle", where: "Over driveway", what: "Rigged removal with protected drop zone." },
  { title: "Storm Damage Make-Safe", where: "Roadside", what: "Removed split limb and cleared debris." },
];

const AREAS = [
  "Your Town",
  "Nearby Village",
  "Surrounding Estates",
  "Local Industrial Sites",
  "Schools & Parks",
  "Landlords & Lettings",
];

const FAQ = [
  { q: "Do you remove all waste?", a: "Yes. We can chip on site and remove all arisings unless you ask to keep logs/woodchip." },
  { q: "Can you work on trees with a TPO?", a: "We can advise. If permission is needed, we’ll tell you what paperwork is required before any work starts." },
  { q: "Will you protect lawns and driveways?", a: "We set drop zones, use rigging where needed, and protect surfaces with boards/mats on request." },
  { q: "Can you do emergency work?", a: "Yes. If a tree is unsafe after a storm, contact us and we’ll prioritise make-safe work." },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{BRAND} — Local Tree Surgeon</title>
    <meta name="description" content="Local tree surgeon for pruning, removals, stump grinding, and emergency call-outs. Fully insured, qualified, and tidy." />
    <meta name="color-scheme" content="dark" />

    <style>
      :root{
        /* PALETTE: "Deep Forest" (Richer Greens) */
        --bg-body: #0f1a15;      /* Deep Forest Green Base */
        --bg-panel: #16241e;     /* Lighter Canopy Shadow */

        --ink: #e8eceb;          /* Off-white */
        --ink-dim: #94a89e;      /* Lichen Grey */

        /* ACCENT: Safety Orange (High Vis) */
        --accent: #ff7b42;

        /* ACCENT: Rope / Tech */
        --rope: #d4a373;         /* Climbing rope color */
        --leaf: #5fa882;         /* Leaf Green */

        --border: rgba(255,255,255,0.08);
        --border-heavy: rgba(255,255,255,0.15);

        --serif: "Georgia", serif;
        --sans: ui-sans-serif, system-ui, -apple-system, sans-serif;
        --mono: ui-monospace, monospace;

        --max: 1100px;
        --pad: 24px;
      }

      *{ box-sizing:border-box; }
      html,body{ height:100%; scroll-behavior:smooth; }

      body{
        margin:0;
        font-family: var(--sans);
        color: var(--ink);
        background-color: var(--bg-body);
        background-image:
          url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.06'/%3E%3C/svg%3E"),
          linear-gradient(180deg, #0a120f 0%, var(--bg-body) 100%);
        overflow-x:hidden;
      }

      a{ color:inherit; text-decoration:none; }
      .wrap{ max-width:var(--max); margin:0 auto; padding: 0 var(--pad); position: relative; }

      /* THE CLIMBING LINE (Vertical Guide) */
      .climbing-line{
        position: absolute; left: 40px; top: 0; bottom: 0; width: 2px;
        background: repeating-linear-gradient(180deg,
          var(--rope) 0, var(--rope) 4px,
          transparent 4px, transparent 8px);
        opacity: 0.15; z-index: 0; pointer-events: none;
      }
      .knot{
        position: absolute; left: -5px; width: 12px; height: 12px;
        border: 2px solid var(--rope); border-radius: 50%; background: var(--bg-body);
        z-index: 1; opacity: 0.4;
      }

      /* UTILITY */
      .label{
        font-family: var(--mono); font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase;
        color: var(--accent); display: block; margin-bottom: 12px; font-weight: 800;
      }
      .muted{ color: var(--ink-dim); }

      /* HEADER */
      header{
        padding: 30px 0;
        position: relative; z-index: 20;
      }
      .head-inner{ display:flex; justify-content:space-between; align-items:flex-end; padding-left: 60px; }

      .brand-group{ display:flex; align-items: center; gap: 16px; }

      /* BACK LINK */
      .back-link{
        width: 32px; height: 32px;
        display: flex; align-items: center; justify-content: center;
        border: 1px solid var(--border-heavy);
        border-radius: 2px;
        color: var(--ink-dim);
        transition: all 0.2s ease;
      }
      .back-link:hover{
        border-color: var(--accent);
        color: var(--accent);
        background: rgba(255,123,66,0.1);
      }
      .back-link svg{ width: 14px; height: 14px; fill: currentColor; }

      .brand{ font-family: var(--serif); font-weight: 800; font-size: 18px; color: #fff; letter-spacing: 0.08em; line-height: 1; text-transform: uppercase; }
      .brand-sub{ font-family: var(--mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(232,236,235,0.45); margin-top: 6px; }

      nav{ display:flex; gap: 26px; align-items:center; }
      nav a{
        font-size: 12px; font-weight: 700; color: var(--ink-dim); text-transform: uppercase; letter-spacing: 0.08em;
        transition: color 0.2s;
      }
      nav a:hover{ color: #fff; }

      /* HERO */
      .hero{
        padding: 80px 0 100px;
        display: grid; grid-template-columns: 1fr 420px;
        gap: 80px; align-items: start;
        padding-left: 60px;
      }

      h1{
        margin:0; font-family: var(--serif); font-size: 54px; line-height: 1.05; color: #fff; font-weight: 800;
        letter-spacing: -0.01em;
      }
      .lead{
        margin-top: 22px; font-size: 17px; line-height: 1.7; color: var(--ink-dim); max-width: 48ch;
      }

      .actions{ margin-top: 34px; display:flex; gap: 16px; align-items: center; flex-wrap:wrap; }

      .btn{
        padding: 16px 22px; background: var(--accent); color: #0f1a15;
        font-weight: 900; text-transform: uppercase; font-size: 11px; letter-spacing: 0.12em;
        border: none; transition: all 0.2s; cursor: pointer; border-radius: 2px;
        display:inline-flex; align-items:center; justify-content:center;
      }
      .btn:hover{ background: #ff9e70; }

      .btn.ghost{
        background: transparent;
        color: #fff;
        border: 1px solid var(--border-heavy);
      }
      .btn.ghost:hover{
        border-color: var(--accent);
        color: var(--accent);
        background: rgba(255,123,66,0.10);
      }

      .link-btn{
        font-size: 12px; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 800; color: var(--ink);
        border-bottom: 1px solid var(--border-heavy); padding-bottom: 2px;
      }
      .link-btn:hover{ color: var(--accent); border-color: var(--accent); }

      /* VISUAL: JOB SHEET CARD */
      .manifest-container{ position: relative; top: 20px; }
      .manifest-card{
        background: #e3e8e5;
        color: #1a2b23;
        border-radius: 2px;
        padding: 24px 28px;
        box-shadow: -20px 20px 60px rgba(0,0,0,0.4);
        font-family: var(--mono);
        position: relative;
        transform: rotate(-1deg);
      }
      .man-header{
        border-bottom: 2px solid #1a2b23; padding-bottom: 14px; margin-bottom: 18px;
        display:flex; justify-content:space-between; align-items:flex-end;
      }
      .man-title{ font-weight: 900; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; }
      .man-id{ font-size: 10px; opacity: 0.6; }

      .man-row{
        display: flex; justify-content: space-between; align-items: center;
        padding: 9px 0; border-bottom: 1px solid rgba(0,0,0,0.1);
      }
      .man-label{ font-size: 11px; text-transform: uppercase; font-weight: 700; letter-spacing: 0.05em; }
      .check-box{
        width: 14px; height: 14px; border: 1px solid #1a2b23; display: flex; align-items: center; justify-content: center;
      }
      .check-box::after{ content:"✓"; font-size: 12px; font-weight: 900; color: var(--accent); }

      .man-status{
        margin-top: 22px; background: #1a2b23; color: #fff; padding: 12px;
        text-align: center; font-size: 11px; font-weight: 900; letter-spacing: 0.12em;
        text-transform: uppercase;
      }
      .stamp{
        position: absolute; bottom: 26px; right: 18px;
        border: 2px solid var(--accent); color: var(--accent);
        padding: 4px 10px; font-weight: 900; font-size: 11px;
        text-transform: uppercase; transform: rotate(-8deg);
        mix-blend-mode: multiply;
      }

      /* SERVICES */
      .services-section{ padding: 100px 0; position: relative; padding-left: 60px; }
      .services-section .knot{ top: 100px; left: 35px; }

      .spec-sheet{ border-top: 2px solid var(--border); }
      .spec-row{
        display: grid; grid-template-columns: 90px 1fr 1.2fr 40px;
        padding: 24px 0;
        border-bottom: 1px solid var(--border);
        align-items: baseline;
        transition: background 0.2s;
      }
      .spec-row:hover{ background: rgba(255,255,255,0.02); }
      .spec-num{ font-family: var(--mono); color: rgba(232,236,235,0.35); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; }
      .spec-title{ font-family: var(--serif); font-size: 22px; color: #fff; font-weight: 600; }
      .spec-desc{ font-size: 15px; color: var(--ink-dim); line-height: 1.5; }
      .spec-icon{ color: var(--accent); font-size: 18px; opacity: 0; transition: opacity 0.2s; }
      .spec-row:hover .spec-icon{ opacity: 1; }

      /* METHOD */
      .method-section{ padding: 60px 0 90px; padding-left: 60px; position: relative; }
      .method-section .knot{ top: 60px; left: 35px; }

      .method-grid{ display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 60px; }
      .method-content h2{ font-family: var(--serif); font-size: 34px; color: #fff; margin: 0 0 18px; font-weight: 800; }
      .method-content p{ font-size: 16px; color: var(--ink-dim); line-height: 1.75; margin: 0 0 16px; }

      .stats-block{
        background: var(--bg-panel);
        border: 1px solid var(--border);
        padding: 26px;
        border-radius: 2px;
      }
      .stat-row{
        display: flex; justify-content: space-between; align-items: center;
        padding: 14px 0; border-bottom: 1px solid var(--border);
      }
      .stat-row:last-child{ border-bottom: none; }
      .stat-label{ font-family: var(--mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--ink-dim); font-weight: 800; }
      .stat-val{ font-weight: 900; color: #fff; }

      /* PROCESS */
      .process-section{ padding: 60px 0 110px; padding-left: 60px; position: relative; }
      .process-section .knot{ top: 60px; left: 35px; }

      .timeline{
        display: flex; flex-direction: column; gap: 34px; margin-top: 28px;
        border-left: 1px solid var(--border); padding-left: 40px;
        position: relative; margin-left: 20px;
      }
      .timeline-step{ position: relative; }
      .timeline-step::before{
        content:""; position: absolute; left: -45px; top: 7px;
        width: 9px; height: 9px; background: var(--bg-body); border: 2px solid var(--accent); border-radius: 50%;
      }
      .ts-head{ display: flex; align-items: baseline; gap: 14px; margin-bottom: 8px; }
      .ts-id{ font-family: var(--mono); color: var(--accent); font-size: 11px; font-weight: 900; letter-spacing: 0.14em; }
      .ts-title{ font-family: var(--serif); font-size: 20px; color: #fff; font-weight: 800; }
      .ts-desc{ color: var(--ink-dim); max-width: 52ch; font-size: 15px; line-height: 1.6; }

      /* WORK */
      .work-section{ padding: 60px 0 90px; padding-left: 60px; position: relative; }
      .work-section .knot{ top: 60px; left: 35px; }

      .work-grid{
        margin-top: 18px;
        display:grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
      }
      .work-card{
        border: 1px solid var(--border);
        background: rgba(22,36,30,0.55);
        border-radius: 2px;
        padding: 18px;
        transition: border-color .2s, transform .2s, background .2s;
      }
      .work-card:hover{
        transform: translateY(-2px);
        border-color: rgba(255,123,66,0.45);
        background: rgba(22,36,30,0.75);
      }
      .work-k{ font-family: var(--mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.14em; color: rgba(232,236,235,0.55); font-weight: 800; }
      .work-t{ margin-top: 10px; font-family: var(--serif); font-size: 20px; color: #fff; font-weight: 800; }
      .work-d{ margin-top: 10px; color: var(--ink-dim); font-size: 14px; line-height: 1.6; }

      /* AREAS */
      .areas-section{ padding: 60px 0 90px; padding-left: 60px; position: relative; }
      .areas-section .knot{ top: 60px; left: 35px; }

      .chips{ display:flex; flex-wrap:wrap; gap: 10px; margin-top: 14px; }
      .chip{
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 10px 12px;
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(232,236,235,0.72);
        background: rgba(255,255,255,0.02);
      }

      /* FAQ */
      .faq-section{ padding: 60px 0 110px; padding-left: 60px; position: relative; }
      .faq-section .knot{ top: 60px; left: 35px; }

      details{
        border-top: 1px solid var(--border);
        padding: 14px 0;
      }
      details:last-child{ border-bottom: 1px solid var(--border); }
      summary{
        cursor: pointer;
        list-style: none;
        display:flex; align-items: baseline; justify-content: space-between; gap: 16px;
        font-family: var(--serif);
        font-size: 18px;
        font-weight: 800;
        color: #fff;
      }
      summary::-webkit-details-marker{ display:none; }
      summary span{
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(255,123,66,0.85);
      }
      details p{
        margin: 12px 0 0;
        color: var(--ink-dim);
        line-height: 1.7;
        max-width: 72ch;
      }

      /* CONTACT */
      .contact-section{ padding-left: 60px; padding-bottom: 110px; position: relative; }
      .contact-section .knot{ top: 18px; left: 35px; }

      .contact-grid{
        display:grid;
        grid-template-columns: 1fr 0.95fr;
        gap: 18px;
        margin-top: 14px;
      }
      .contact-card{
        border: 1px solid var(--border);
        background: rgba(22,36,30,0.55);
        border-radius: 2px;
        padding: 22px;
      }
      .contact-row{ margin-top: 12px; display:flex; flex-direction:column; gap: 8px; }
      .contact-link{
        display:inline-flex; align-items:center; gap: 10px;
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(232,236,235,0.85);
        border-bottom: 1px solid rgba(255,255,255,0.12);
        padding-bottom: 2px;
        width: fit-content;
      }
      .contact-link:hover{ color: var(--accent); border-bottom-color: rgba(255,123,66,0.55); }
      .smallnote{ margin-top: 12px; color: rgba(232,236,235,0.45); font-size: 12px; line-height: 1.6; }

      form{ margin-top: 12px; display:grid; gap: 10px; }
      label{
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(232,236,235,0.55);
        font-weight: 800;
      }
      input, textarea{
        width:100%;
        border-radius: 2px;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(15,26,21,0.55);
        color: #fff;
        padding: 12px;
        outline: none;
      }
      input:focus, textarea:focus{
        border-color: rgba(255,123,66,0.55);
        box-shadow: 0 0 0 3px rgba(255,123,66,0.10);
      }
      textarea{ min-height: 120px; resize: vertical; }
      .form-actions{ display:flex; gap: 12px; flex-wrap:wrap; margin-top: 8px; }

      footer{
        border-top: 1px solid var(--border);
        padding: 40px 0 40px 60px;
        color: var(--ink-dim);
        font-size: 11px;
        font-family: var(--mono);
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }

      /* Reveal */
      section{ opacity:0; transform:translateY(20px); transition: all 0.6s ease-out; }
      section.on{ opacity:1; transform:translateY(0); }

      /* Responsive */
      @media(max-width: 980px){
        .hero{ grid-template-columns: 1fr; gap: 50px; }
        .manifest-container{ width: 100%; max-width: 420px; }
        .method-grid{ grid-template-columns: 1fr; }
        .work-grid{ grid-template-columns: 1fr; }
        .contact-grid{ grid-template-columns: 1fr; }
        .spec-row{ grid-template-columns: 70px 1fr; grid-gap: 8px; }
        .spec-desc, .spec-icon { display: none; }
      }
      @media(max-width: 600px){
        .climbing-line, .knot{ display: none; }
        .wrap, .hero, .services-section, .method-section, .process-section, .work-section, .areas-section, .faq-section, .contact-section, footer, .head-inner{
          padding-left: 20px;
        }
        nav{ display: none; }
        h1{ font-size: 44px; }
      }
    </style>
  </head>

  <body>
    <div class="wrap" style="height:0; overflow:visible;">
      <div class="climbing-line"></div>
    </div>

    <header>
      <div class="wrap head-inner">
        <div class="brand-group">
          <a href="/" class="back-link" aria-label="Return to index">
            <svg viewBox="0 0 24 24"><path d="M3 3h7v7H3V3zm11 0h7v7h-7V3zm0 11h7v7h-7v-7zM3 14h7v7H3v-7z"/></svg>
          </a>

          <div>
            <div class="brand">{BRAND}</div>
            <div class="brand-sub">Local pruning • removals • stump grinding</div>
          </div>
        </div>

        <nav aria-label="Primary">
          {NAV.map(l => <a href={l.href}>{l.label}</a>)}
        </nav>
      </div>
    </header>

    <main class="wrap">
      <section class="hero" aria-label="Hero">
        <div class="hero-content">
          <span class="label">Local Tree Surgeon</span>
          <h1>Safe tree work.<br/>Clean finish.</h1>
          <p class="lead">
            We handle reductions, removals, and storm damage with controlled rigging and careful ground protection.
            If you want it done properly—and left tidy—you’re in the right place.
          </p>
          <div class="actions" aria-label="Hero actions">
            <a class="btn" href="#contact" aria-label="Jump to contact">Get a Quote</a>
            <a class="btn ghost" href={CONTACT.phoneHref} aria-label="Call now">Call Now</a>
            <a class="link-btn" href="#services" aria-label="View services">See Services</a>
          </div>
          <p class="smallnote">{CONTACT.note}</p>
        </div>

        <div class="manifest-container" aria-label="Job checklist">
          <div class="manifest-card">
            <div class="man-header">
              <div class="man-title">JOB CHECKLIST</div>
              <div class="man-id">REF: LOCAL-07</div>
            </div>

            <div class="man-row"><span class="man-label">Access Checked</span><div class="check-box"></div></div>
            <div class="man-row"><span class="man-label">Risk Assessment</span><div class="check-box"></div></div>
            <div class="man-row"><span class="man-label">Wildlife / Nest Check</span><div class="check-box"></div></div>
            <div class="man-row"><span class="man-label">Drop Zone Set</span><div class="check-box"></div></div>
            <div class="man-row"><span class="man-label">Rigging Plan</span><div class="check-box"></div></div>
            <div class="man-row"><span class="man-label">Site Left Tidy</span><div class="check-box"></div></div>

            <div class="man-status">ON-SITE: READY TO START</div>
            <div class="stamp">INSURED</div>
          </div>
        </div>
      </section>

      <section id="services" class="services-section" aria-label="Services">
        <div class="knot"></div>
        <span class="label">Services</span>
        <div class="spec-sheet" role="list">
          {SERVICES.map((s, i) => (
            <div class="spec-row" role="listitem" aria-label={s.title}>
              <div class="spec-num">{s.meta}</div>
              <div class="spec-title">{s.title}</div>
              <div class="spec-desc">{s.line}</div>
              <div class="spec-icon" aria-hidden="true">→</div>
            </div>
          ))}
        </div>
      </section>

      <section id="method" class="method-section" aria-label="Method">
        <div class="knot"></div>
        <div class="method-grid">
          <div class="method-content">
            <span class="label">How we work</span>
            <h2>Careful cuts, controlled lowering.</h2>
            <p>
              We plan the job around what’s underneath: roofs, fences, sheds, patios, planting beds.
              If a tree can’t be felled in one piece, we dismantle it safely using rigging.
            </p>
            <p>
              We chip and remove waste unless you want to keep logs or woodchip.
              The goal is simple: safe work, clear communication, tidy finish.
            </p>
          </div>

          <div class="stats-block" aria-label="Credentials">
            {SPECS.map(s => (
              <div class="stat-row" aria-label={s.k}>
                <span class="stat-label">{s.k}</span>
                <span class="stat-val">{s.v}</span>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="process" class="process-section" aria-label="Process">
        <div class="knot"></div>
        <span class="label">Process</span>

        <div class="timeline" aria-label="Process timeline">
          {PROCESS.map(p => (
            <div class="timeline-step" aria-label={`Step ${p.id}`}>
              <div class="ts-head">
                <span class="ts-id">{p.id}</span>
                <span class="ts-title">{p.t}</span>
              </div>
              <div class="ts-desc">{p.d}</div>
            </div>
          ))}
        </div>
      </section>

      <section id="work" class="work-section" aria-label="Recent work">
        <div class="knot"></div>
        <span class="label">Recent work</span>

        <div class="work-grid" aria-label="Recent job cards">
          {WORK.map((w) => (
            <article class="work-card" aria-label={w.title}>
              <div class="work-k">{w.where}</div>
              <div class="work-t">{w.title}</div>
              <div class="work-d">{w.what}</div>
            </article>
          ))}
        </div>

        <p class="smallnote">
          Want photos here? Add a simple gallery grid (before/after) once you’ve got real job shots.
        </p>
      </section>

      <section id="areas" class="areas-section" aria-label="Areas covered">
        <div class="knot"></div>
        <span class="label">Areas covered</span>
        <div class="muted">We cover your local area and surrounding villages. If you’re unsure, ask.</div>

        <div class="chips" aria-label="Areas list">
          {AREAS.map((a) => <span class="chip" aria-label={a}>{a}</span>)}
        </div>
      </section>

      <section id="faq" class="faq-section" aria-label="FAQ">
        <div class="knot"></div>
        <span class="label">FAQ</span>

        {FAQ.map((f, idx) => (
          <details aria-label={`FAQ ${idx + 1}`}>
            <summary>
              {f.q}
              <span>{String(idx + 1).padStart(2, "0")}</span>
            </summary>
            <p>{f.a}</p>
          </details>
        ))}
      </section>

      <section id="contact" class="contact-section" aria-label="Contact">
        <div class="knot"></div>
        <span class="label">Contact</span>

        <div class="contact-grid">
          <div class="contact-card" aria-label="Contact details">
            <div style="font-family: var(--serif); font-size: 26px; font-weight: 800; color:#fff;">
              Get in touch
            </div>
            <div class="muted" style="margin-top:10px; line-height:1.7;">
              Send a message with your postcode and a short description.
              If you can, include photos of the tree and any nearby targets (sheds, fences, lines).
            </div>

            <div class="contact-row">
              <a class="contact-link" href={CONTACT.phoneHref} aria-label="Phone">
                Phone: {CONTACT.phoneDisplay}
              </a>
              <a class="contact-link" href={CONTACT.emailHref} aria-label="Email">
                Email: {CONTACT.emailDisplay}
              </a>
              <div class="smallnote">Hours: {CONTACT.hours}</div>
            </div>
          </div>

          <div class="contact-card" aria-label="Quick quote form">
            <div style="font-family: var(--serif); font-size: 20px; font-weight: 800; color:#fff;">
              Quick quote request
            </div>

            <form action="#" method="post">
              <div>
                <label for="name">Name</label>
                <input id="name" name="name" type="text" placeholder="Your name" />
              </div>
              <div>
                <label for="postcode">Postcode</label>
                <input id="postcode" name="postcode" type="text" placeholder="e.g. AB12 3CD" />
              </div>
              <div>
                <label for="message">What do you need?</label>
                <textarea id="message" name="message" placeholder="Tree size, access, and what you want done."></textarea>
              </div>

              <div class="form-actions">
                <button class="btn" type="submit">Send Request</button>
                <a class="btn ghost" href={CONTACT.phoneHref} aria-label="Call instead">Call Instead</a>
              </div>

              <div class="smallnote">
                This form is a front-end placeholder. Wire it to your contact handler when ready.
              </div>
            </form>
          </div>
        </div>
      </section>

      <footer aria-label="Footer">
        {BRAND} • Local, insured, qualified • {CONTACT.note}
      </footer>
    </main>

    <script is:inline>
      // Reveal sections on scroll
      (function () {
        const reduce = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (reduce) {
          document.querySelectorAll("section").forEach((s) => s.classList.add("on"));
          return;
        }

        const obs = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) e.target.classList.add("on");
          });
        }, { threshold: 0.12 });

        document.querySelectorAll("section").forEach((section) => obs.observe(section));
      })();
    </script>
  </body>
</html>

---
import "../styles/global.css";

const BRAND = "GROUNDSPEC.";
const TAGLINE = "PAVING AND FENCING, BUILT SQUARE";
const PHONE = "+31 6 2048 7712";
const TEL = PHONE.replace(/\s/g, "");
const EMAIL = "quotes@groundspec.nl";
const AREA = "AMS / HRL / UTR / NH";

const YEAR = new Date().getFullYear();
const SHEET = {
  id: "GS-CAD-025",
  rev: "FINAL-V1.17",
  date: new Date().toISOString().slice(0, 10),
};

const ICON = {
  mark: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>`,
  phone: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
  mail: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  print: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect width="12" height="8" x="6" y="14"/></svg>`,
  arrow: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>`,
  back: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>`,
  map: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{BRAND} // PRO ESTIMATOR</title>
    <style>
      /* High-end subtle noise + gradient background */
      .bg-premium-texture {
        background-color: #0a0a0a;
        background-image: 
          radial-gradient(circle at 50% 0%, rgba(255,255,255,0.05) 0%, transparent 70%), /* Subtle top light */
          url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.04'/%3E%3C/svg%3E"); /* Fine noise texture */
        background-repeat: no-repeat, repeat;
        background-size: cover, 120px 120px;
        background-attachment: fixed;
      }

      input[type=range] {
        -webkit-appearance: none;
        background: transparent;
      }
      input[type=range]::-webkit-slider-thumb {
        -webkit-appearance: none;
        height: 18px;
        width: 18px;
        border-radius: 0;
        background: #eab308;
        cursor: pointer;
        margin-top: -7px;
        border: 2px solid #fff;
      }
      input[type=range]::-webkit-slider-runnable-track {
        width: 100%;
        height: 4px;
        cursor: pointer;
        background: #333;
      }
      .side-btn.active, .shape-btn.active {
        background-color: #10b981;
        color: black;
        border-color: #10b981;
      }
      .text-hover-bright {
        transition: color 0.3s ease;
      }
      .text-hover-bright:hover {
        color: #ffffff;
      }
    </style>
  </head>

  <body class="min-h-screen bg-[#0a0a0a] text-zinc-200 font-sans antialiased selection:bg-yellow-500 selection:text-black bg-premium-texture">
    
    <header class="fixed top-0 inset-x-0 z-50 bg-[#0a0a0a]/90 backdrop-blur-md border-b border-white/10 transition-colors duration-500">
      <div class="mx-auto max-w-7xl px-6 h-24 flex items-center justify-between">
        <div class="flex items-center gap-8">
            <a href="/" class="group flex items-center gap-2 text-sm font-bold uppercase tracking-widest text-zinc-400 hover:text-white transition-colors border-r border-white/10 pr-8 h-10">
                <span class="w-4 h-4 group-hover:-translate-x-1 transition-transform"><Fragment set:html={ICON.back} /></span>
                Index
            </a>
            <div class="flex items-center gap-4">
                <div class="w-10 h-10 bg-yellow-500 flex items-center justify-center text-black shadow-lg shadow-yellow-500/20">
                    <span class="w-6 h-6"><Fragment set:html={ICON.mark} /></span>
                </div>
                <div>
                    <span class="block font-black text-xl text-white tracking-tight leading-none">{BRAND}</span>
                    <span class="block text-xs font-bold text-zinc-400 uppercase tracking-widest">Paving and Fencing</span>
                </div>
            </div>
        </div>
        <nav class="hidden md:flex items-center gap-10">
            <a href="#calculator" class="text-sm font-bold text-zinc-400 hover:text-yellow-500 transition-colors uppercase">Estimator</a>
            <a href="#specs" class="text-sm font-bold text-zinc-400 hover:text-yellow-500 transition-colors uppercase">Standards</a>
            <a href="#contact" class="text-sm font-bold text-zinc-400 hover:text-yellow-500 transition-colors uppercase">Contact</a>
        </nav>
        <a href={`tel:${TEL}`} class="hidden lg:flex items-center gap-3 bg-white/5 hover:bg-white hover:text-black text-white px-6 py-4 font-bold text-base uppercase transition-all border border-white/10">
            <span class="w-5 h-5"><Fragment set:html={ICON.phone} /></span>
            <span>{PHONE}</span>
        </a>
      </div>
    </header>

    <main class="pt-24">
      
      <section class="relative border-b border-white/5 bg-transparent py-32 lg:py-48 overflow-hidden">
         <div class="absolute top-0 right-0 w-1/2 h-full opacity-5 pointer-events-none transition-opacity duration-1000">
             <svg viewBox="0 0 100 100" class="w-full h-full text-white" fill="currentColor">
                 <path d="M0 100 L100 0 L100 100 Z" />
             </svg>
         </div>

         <div class="mx-auto max-w-7xl px-6 relative z-10">
            <div class="flex flex-col gap-12 max-w-7xl">
                
                <h1 class="text-6xl md:text-9xl font-black text-white leading-[0.85] tracking-tighter subpixel-antialiased">
                    Accurate Takeoffs <br/>
                    <span class="text-zinc-500 text-hover-bright transition-colors duration-500">Before We Break Ground.</span>
                </h1>
                
                <p class="text-xl md:text-3xl text-zinc-300 max-w-4xl leading-relaxed text-hover-bright font-light tracking-tight">
                    Size your patio, driveway, path, or fence run in minutes. Get area and perimeter instantly, then we convert it into a clean quote with materials, base prep, and labor.
                </p>

                <div class="flex flex-col gap-10 mt-12 items-start">
                    <a href="#calculator" class="inline-flex items-center gap-6 text-white text-3xl font-black uppercase tracking-tighter border-b-2 border-transparent hover:border-zinc-500 pb-1 transition-all duration-300 group">
                        <span>Open Estimator</span> 
                        <span class="w-7 h-7 group-hover:translate-x-2 transition-transform duration-500"><Fragment set:html={ICON.arrow} /></span>
                    </a>
                    
                    <a href="#contact" class="inline-flex items-center text-zinc-500 text-3xl font-black uppercase tracking-tighter border-b-2 border-transparent hover:border-zinc-500 hover:text-white pb-1 transition-all duration-300">
                        <span>Request a Site Visit</span>
                    </a>
                </div>
            </div>
         </div>
      </section>

      <section id="calculator" class="py-12 md:py-20 px-4 md:px-8 mx-auto max-w-4xl">
        <div class="flex justify-between items-end mb-8">
            <h2 class="text-2xl font-black text-white uppercase tracking-tight">Estimator Console</h2>
            <div class="font-mono text-yellow-600 text-xs font-bold tracking-widest">{SHEET.id}</div>
        </div>

        <div class="grid lg:grid-cols-12 gap-0 border border-white/10 bg-[#161616]/80 backdrop-blur-sm shadow-2xl rounded-sm overflow-hidden ring-1 ring-white/5">
            <div class="lg:col-span-7 border-b lg:border-b-0 lg:border-r border-white/10 relative bg-black/40 min-h-[360px]">
                <div class="w-full h-full flex items-center justify-center p-8">
                    <svg id="cadCanvas" viewBox="0 0 800 600" class="w-full h-full max-w-[600px]" preserveAspectRatio="xMidYMid meet">
                        <defs>
                            <pattern id="brickPattern" width="20" height="10" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
                                <rect width="19" height="9" fill="#222" stroke="#444" stroke-width="1"/>
                            </pattern>
                            <pattern id="slabPattern" width="40" height="40" patternUnits="userSpaceOnUse">
                                <rect width="39" height="39" fill="#1a1a1a" stroke="#333" stroke-width="1"/>
                            </pattern>
                            <pattern id="herringPattern" width="30" height="30" patternUnits="userSpaceOnUse" patternTransform="rotate(30)">
                                <path d="M0 0 L15 0 L15 30 L0 30 Z M15 15 L30 15" stroke="#444" fill="#222"/>
                            </pattern>
                            <marker id="arrowHead" markerWidth="10" markerHeight="10" refX="9" refY="3" orient="auto">
                                <path d="M0,0 L0,6 L9,3 z" fill="#aaa" />
                            </marker>
                        </defs>
                        <rect x="50" y="50" width="700" height="500" fill="none" stroke="#222" stroke-width="1" stroke-dasharray="8 4" />
                        <g id="projectGroup" transform="translate(400, 300)"> 
                            <path id="svgMainPath" fill="url(#brickPattern)" stroke="#eab308" stroke-width="3" d="" class="transition-all duration-300" />
                            <g id="dims" opacity="0.6">
                                <line id="dimW" stroke="#888" marker-start="url(#arrowHead)" marker-end="url(#arrowHead)" />
                                <text id="txtW" fill="#eab308" font-family="monospace" font-size="16" font-weight="bold" text-anchor="middle"></text>
                                <line id="dimL" stroke="#888" marker-start="url(#arrowHead)" marker-end="url(#arrowHead)" />
                                <text id="txtL" fill="#eab308" font-family="monospace" font-size="16" font-weight="bold" text-anchor="middle"></text>
                            </g>
                            <g id="fences" stroke="#10b981" stroke-width="6" stroke-linecap="square"></g>
                        </g>
                    </svg>
                </div>
            </div>
            <div class="lg:col-span-5 flex flex-col bg-[#141414]/90">
                <div class="p-6 overflow-y-auto flex-1 space-y-10">
                    <div>
                        <h3 class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest mb-4">Layout and finish</h3>
                        <div class="grid grid-cols-2 gap-2 mb-4">
                            <button class="shape-btn h-10 border border-white/10 bg-black/50 text-[10px] font-black uppercase transition-colors active" data-shape="rect">Rectangle</button>
                            <button class="shape-btn h-10 border border-white/10 bg-black/50 text-[10px] font-black uppercase transition-colors" data-shape="lshape">L-Shape</button>
                        </div>
                        <select id="inTexture" class="w-full h-10 bg-black/50 border border-white/10 text-xs font-bold text-zinc-300 px-3 uppercase outline-none focus:border-yellow-500 transition-colors">
                            <option value="brickPattern">Concrete Pavers</option>
                            <option value="slabPattern">Porcelain Slabs</option>
                            <option value="herringPattern">Herringbone</option>
                        </select>
                    </div>

                    <div>
                        <h3 class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest mb-4">Dimensions</h3>
                        <div class="space-y-6">
                            <div>
                                <div class="flex justify-between text-[10px] font-black text-zinc-400 mb-2 uppercase tracking-widest">
                                    <span>Width</span>
                                    <span id="valWidth" class="text-yellow-500 font-mono">6.0m</span>
                                </div>
                                <input id="inWidth" type="range" min="3" max="15" step="0.5" value="6" class="w-full accent-yellow-600" />
                            </div>
                            <div>
                                <div class="flex justify-between text-[10px] font-black text-zinc-400 mb-2 uppercase tracking-widest">
                                    <span>Length</span>
                                    <span id="valLength" class="text-yellow-500 font-mono">4.0m</span>
                                </div>
                                <input id="inLength" type="range" min="3" max="10" step="0.5" value="4" class="w-full accent-yellow-600" />
                            </div>
                            <div id="lControls" class="hidden space-y-6 pt-4 border-t border-white/10">
                                <div>
                                    <div class="flex justify-between text-[10px] font-black text-zinc-400 mb-2 uppercase tracking-widest">
                                        <span>Inset Width</span>
                                        <span id="valOffW" class="text-yellow-500 font-mono">2.0m</span>
                                    </div>
                                    <input id="inOffW" type="range" min="1" max="5" step="0.5" value="2" class="w-full accent-yellow-600" />
                                </div>
                                <div>
                                    <div class="flex justify-between text-[10px] font-black text-zinc-400 mb-2 uppercase tracking-widest">
                                        <span>Inset Length</span>
                                        <span id="valOffL" class="text-yellow-500 font-mono">2.0m</span>
                                    </div>
                                    <input id="inOffL" type="range" min="1" max="5" step="0.5" value="2" class="w-full accent-yellow-600" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="bg-black/80 p-8 border-t border-white/10">
                    <div class="grid grid-cols-2 gap-6 mb-8">
                        <div>
                            <span class="block text-[10px] font-bold text-zinc-500 uppercase mb-2">Paving Area</span>
                            <span id="outArea" class="text-2xl font-black text-yellow-500 font-mono tracking-tighter">--</span>
                        </div>
                        <div>
                            <span class="block text-[10px] font-bold text-zinc-500 uppercase mb-2">Fence Run</span>
                            <span id="outFenceLen" class="text-2xl font-black text-emerald-500 font-mono tracking-tighter">--</span>
                        </div>
                    </div>
                    <a href={`mailto:${EMAIL}`} class="block w-full bg-white text-black py-4 text-center text-sm font-black uppercase tracking-[0.2em] hover:bg-yellow-500 transition-all shadow-xl">
                        Request a Detailed Quote
                    </a>
                </div>
            </div>
        </div>
      </section>

      <section id="specs" class="py-32 border-t border-white/5 bg-transparent">
         <div class="mx-auto max-w-7xl px-6">
            <div class="grid md:grid-cols-2 gap-24 lg:gap-32">
                <div>
                    <h3 class="text-3xl font-black text-white uppercase mb-16 flex items-center gap-6">
                        <span class="w-16 h-1.5 bg-yellow-500 shadow-lg shadow-yellow-500/20"></span> Paving Standards
                    </h3>
                    <ul class="space-y-24">
                        <li class="flex gap-10 group">
                            <span class="text-yellow-500 font-black text-3xl transition-opacity group-hover:opacity-100 opacity-60">01</span>
                            <div>
                                <strong class="block text-white uppercase text-xl tracking-tight group-hover:text-yellow-500 transition-colors">Base and Drainage</strong>
                                <p class="text-lg text-zinc-400 leading-relaxed font-light mt-2 max-w-md">We excavate to a stable depth, separate where needed, and build a compacted sub-base that drains. No soft spots, no future dips.</p>
                            </div>
                        </li>
                        <li class="flex gap-10 group">
                            <span class="text-yellow-500 font-black text-3xl transition-opacity group-hover:opacity-100 opacity-60">02</span>
                            <div>
                                <strong class="block text-white uppercase text-xl tracking-tight group-hover:text-yellow-500 transition-colors">Edge Restraint</strong>
                                <p class="text-lg text-zinc-400 leading-relaxed font-light mt-2 max-w-md">We lock the perimeter with concrete haunching or steel edging so the pattern stays tight through traffic, weather, and time.</p>
                            </div>
                        </li>
                        <li class="flex gap-10 group">
                            <span class="text-yellow-500 font-black text-3xl transition-opacity group-hover:opacity-100 opacity-60">03</span>
                            <div>
                                <strong class="block text-white uppercase text-xl tracking-tight group-hover:text-yellow-500 transition-colors">Falls and Jointing</strong>
                                <p class="text-lg text-zinc-400 leading-relaxed font-light mt-2 max-w-md">Correct falls for water run-off, layered compaction, then joints finished properly so units stay flat, quiet, and clean.</p>
                            </div>
                        </li>
                    </ul>
                </div>
                <div>
                    <h3 class="text-3xl font-black text-white uppercase mb-16 flex items-center gap-6">
                        <span class="w-16 h-1.5 bg-emerald-500 shadow-lg shadow-emerald-500/20"></span> Fencing Standards
                    </h3>
                    <ul class="space-y-24">
                        <li class="flex gap-10 group">
                            <span class="text-emerald-500 font-black text-3xl transition-opacity group-hover:opacity-100 opacity-60">01</span>
                            <div>
                                <strong class="block text-white uppercase text-xl tracking-tight group-hover:text-emerald-500 transition-colors">Footings That Hold</strong>
                                <p class="text-lg text-zinc-400 leading-relaxed font-light mt-2 max-w-md">Posts set deep with concrete matched to the ground. Gate posts get extra mass so they do not twist, lean, or sag.</p>
                            </div>
                        </li>
                        <li class="flex gap-10 group">
                            <span class="text-emerald-500 font-black text-3xl transition-opacity group-hover:opacity-100 opacity-60">02</span>
                            <div>
                                <strong class="block text-white uppercase text-xl tracking-tight group-hover:text-emerald-500 transition-colors">Straight Lines</strong>
                                <p class="text-lg text-zinc-400 leading-relaxed font-light mt-2 max-w-md">String lines, levels, and laser checks, then rails and panels tensioned so the fence stays true across the full run.</p>
                            </div>
                        </li>
                        <li class="flex gap-10 group">
                            <span class="text-emerald-500 font-black text-3xl transition-opacity group-hover:opacity-100 opacity-60">03</span>
                            <div>
                                <strong class="block text-white uppercase text-xl tracking-tight group-hover:text-emerald-500 transition-colors">Materials and Fixings</strong>
                                <p class="text-lg text-zinc-400 leading-relaxed font-light mt-2 max-w-md">Treated timber, composite, or galvanized steel with the right fixings. Clean caps, clean corners, and hardware that does not rust out.</p>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
         </div>
      </section>

      <footer id="contact" class="bg-black/80 border-t border-white/10 pt-32 pb-12">
        <div class="mx-auto max-w-7xl px-6">
          <div class="grid md:grid-cols-4 gap-16 mb-24">
              <div class="col-span-2">
                  <h4 class="text-4xl font-black text-white uppercase tracking-tighter mb-8">{BRAND}</h4>
                  <p class="text-zinc-500 text-lg max-w-sm leading-relaxed font-light">
                      Specialists in paving, fencing, and boundary finishes. Driveways, patios, paths, gates, and full perimeter runs, built square, drained right, and left clean.
                  </p>
              </div>
              <div>
                  <h5 class="text-xs font-black text-white uppercase tracking-widest mb-10 text-zinc-400">Contact</h5>
                  <ul class="space-y-6 text-sm text-zinc-200 font-bold uppercase tracking-wide">
                      <li><a href={`tel:${TEL}`} class="hover:text-yellow-500 transition-all flex items-center gap-4 group"><span class="w-4 h-4 opacity-50 group-hover:opacity-100 transition-opacity"><Fragment set:html={ICON.phone} /></span> {PHONE}</a></li>
                      <li><a href={`mailto:${EMAIL}`} class="hover:text-yellow-500 transition-all flex items-center gap-4 group"><span class="w-4 h-4 opacity-50 group-hover:opacity-100 transition-opacity"><Fragment set:html={ICON.mail} /></span> {EMAIL}</a></li>
                  </ul>
              </div>
              <div>
                  <h5 class="text-xs font-black text-white uppercase tracking-widest mb-10 text-zinc-400">Service Area</h5>
                  <ul class="space-y-4 text-sm text-zinc-500 font-bold uppercase tracking-wide">
                      <li class="flex items-center gap-4"><span class="w-4 h-4 opacity-50"><Fragment set:html={ICON.map} /></span> {AREA}</li>
                      <li class="pl-8 text-xs opacity-50 leading-relaxed">Full Netherlands coverage available for larger contracts.</li>
                  </ul>
              </div>
          </div>
          <div class="border-t border-white/10 pt-12 flex flex-col md:flex-row justify-between items-center gap-8 text-[10px] text-zinc-600 font-black uppercase tracking-[0.3em]">
              <div class="flex items-center gap-12">
                <span>© {YEAR} {BRAND}</span>
                <span class="hidden md:inline">Paving and Fencing</span>
              </div>
              <div class="flex items-center gap-12 opacity-40">
                <span>Build: {SHEET.rev}</span>
                <span>Hash: {SHEET.id}</span>
              </div>
          </div>
        </div>
      </footer>
    </main>

    <script is:inline>
      (function() {
        const inWidth = document.getElementById('inWidth');
        const inLength = document.getElementById('inLength');
        const inOffW = document.getElementById('inOffW');
        const inOffL = document.getElementById('inOffL');
        const inTexture = document.getElementById('inTexture');
        const shapeBtns = document.querySelectorAll('.shape-btn');
        const lControls = document.getElementById('lControls');

        const svgMainPath = document.getElementById('svgMainPath');
        const dimW = document.getElementById('dimW');
        const txtW = document.getElementById('txtW');
        const dimL = document.getElementById('dimL');
        const txtL = document.getElementById('txtL');
        const outArea = document.getElementById('outArea');
        const outFenceLen = document.getElementById('outFenceLen');

        let currentShape = 'rect';
        const PIXELS_PER_METER = 35;

        function update() {
            const w = parseFloat(inWidth.value);
            const l = parseFloat(inLength.value);
            const ow = parseFloat(inOffW.value);
            const ol = parseFloat(inOffL.value);

            document.getElementById('valWidth').innerText = w.toFixed(1) + 'm';
            document.getElementById('valLength').innerText = l.toFixed(1) + 'm';
            document.getElementById('valOffW').innerText = ow.toFixed(1) + 'm';
            document.getElementById('valOffL').innerText = ol.toFixed(1) + 'm';

            const pxW = w * PIXELS_PER_METER;
            const pxL = l * PIXELS_PER_METER;
            const pxOw = ow * PIXELS_PER_METER;
            const pxOl = ol * PIXELS_PER_METER;

            const hW = pxW / 2;
            const hL = pxL / 2;

            let pathData = "";
            let area = 0;
            let perimeter = 0;

            if (currentShape === 'rect') {
                pathData = `M${-hW} ${-hL} L${hW} ${-hL} L${hW} ${hL} L${-hW} ${hL} Z`;
                area = w * l;
                perimeter = (w * 2) + (l * 2);
                lControls.classList.add('hidden');
            } else {
                pathData = `M${-hW} ${-hL} L${hW} ${-hL} L${hW} ${hL - pxOl} L${hW - pxOw} ${hL - pxOl} L${hW - pxOw} ${hL} L${-hW} ${hL} Z`;
                area = (w * l) - (ow * ol);
                perimeter = (w * 2) + (l * 2); 
                lControls.classList.remove('hidden');
            }

            svgMainPath.setAttribute('d', pathData);
            svgMainPath.setAttribute('fill', `url(#${inTexture.value})`);

            dimW.setAttribute('x1', -hW); dimW.setAttribute('x2', hW);
            dimW.setAttribute('y1', -hL - 20); dimW.setAttribute('y2', -hL - 20);
            txtW.setAttribute('x', 0); txtW.setAttribute('y', -hL - 35); txtW.innerHTML = w.toFixed(1) + 'm';

            dimL.setAttribute('x1', -hW - 20); dimL.setAttribute('x2', -hW - 20);
            dimL.setAttribute('y1', -hL); dimL.setAttribute('y2', hL);
            txtL.setAttribute('x', -hW - 35); txtL.setAttribute('y', 0); 
            txtL.setAttribute('transform', `rotate(-90, ${-hW - 35}, 0)`);
            txtL.innerHTML = l.toFixed(1) + 'm';

            outArea.innerText = area.toFixed(1) + ' m²';
            outFenceLen.innerText = perimeter.toFixed(1) + ' m';
        }

        [inWidth, inLength, inOffW, inOffL, inTexture].forEach(el => el.addEventListener('input', update));
        
        shapeBtns.forEach(btn => {
            btn.addEventListener('click', (e) => {
                shapeBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                currentShape = btn.dataset.shape;
                update();
            });
        });

        update();
      })();
    </script>
  </body>
</html>
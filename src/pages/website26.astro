---
import "../styles/global.css";

const BRAND = "EMBERLINE GAS & HEATING";
const TAGLINE = "Boiler service. Breakdown repair. Gas safety checks.";
const PHONE = "+31 6 4810 2239";
const TEL = PHONE.replace(/\s/g, "");
const EMAIL = "service@emberline.nl";
const AREA = "Amsterdam • Haarlem • Utrecht • Region";
const HOURS = "Breakdowns when capacity allows • Planned visits by appointment";
const YEAR = new Date().getFullYear();

const ICON = {
  flame: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-1.12-2.5-2.5-2.5S6 10.62 6 12a2.5 2.5 0 0 0 2.5 2.5Z"/><path d="M15.5 14.5A2.5 2.5 0 0 0 18 12c0-1.38-1.12-2.5-2.5-2.5S13 10.62 13 12a2.5 2.5 0 0 0 2.5 2.5Z"/><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10Z"/><path d="M12 18a6 6 0 0 0 6-6c0-3.314-2.686-6-6-6s-6 2.686-6 6a6 6 0 0 0 6 6Z"/><path d="M12 14a2 2 0 0 0 2-2c0-1.105-.895-2-2-2s-2 .895-2 2a2 2 0 0 0 2 2Z"/></svg>`,
  alert: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 9v4m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 17c-.77 1.333.192 3 1.732 3z"/></svg>`,
  refresh: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>`,
  back: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>`
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{BRAND} — Gas & Heating</title>
    <meta
      name="description"
      content="Gas and heating engineers for boiler service, breakdown repair, controls, upgrades, and gas safety inspections across Amsterdam, Haarlem, Utrecht, and surrounding areas."
    />

    <script is:inline>
      (function() {
        const w = window;
        w.tailwind = w.tailwind || {};
        w.tailwind.config = {
          theme: {
            extend: {
              colors: {
                ember: '#f6a11a',
                alert: '#ff4d4d',
              },
              keyframes: {
                "heat-drift": {
                  "0%": { transform: "translate3d(0,0,0) scale(1)", opacity: ".55" },
                  "50%": { transform: "translate3d(2.5%,-2%,0) scale(1.02)", opacity: ".72" },
                  "100%": { transform: "translate3d(0,0,0) scale(1)", opacity: ".55" }
                },
                "ember-pulse": {
                  "0%,100%": { opacity: ".55" },
                  "50%": { opacity: ".95" }
                }
              },
              animation: {
                "heat-drift": "heat-drift 18s ease-in-out infinite",
                "ember-pulse": "ember-pulse 2.8s ease-in-out infinite"
              }
            }
          }
        };
      })();
    </script>

    <style>
      :root{
        --bg0:#07070a;
        --bg1:#0b0c12;
        --ink:#f4f6fb;
        --mut:rgba(244,246,251,.72);
        --line:rgba(244,246,251,.14);
        --line2:rgba(244,246,251,.08);
        --heat:#f6a11a;
        --max: 1060px;
        --pad: 18px;
      }

      *{ box-sizing:border-box; }
      html,body{ height:100%; }
      body{
        margin:0;
        color:var(--ink);
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, "Apple Color Emoji","Segoe UI Emoji";
        background:
          radial-gradient(900px 520px at 18% 14%, rgba(246,161,26,.16), transparent 62%),
          radial-gradient(860px 560px at 82% 68%, rgba(159,215,255,.10), transparent 64%),
          linear-gradient(180deg, var(--bg0), var(--bg1));
        transition: background 0.5s ease;
      }
      
      body.emergency-mode {
        background: #1a0505;
        background-image: 
            radial-gradient(circle at 50% 50%, rgba(255, 0, 0, 0.15), transparent 70%),
            repeating-linear-gradient(45deg, rgba(255,0,0,0.05) 0px, rgba(255,0,0,0.05) 2px, transparent 2px, transparent 10px);
      }
      body.emergency-mode .mast-top, 
      body.emergency-mode .meta, 
      body.emergency-mode .section-label, 
      body.emergency-mode .protocol-grid, 
      body.emergency-mode .card:not(.emergency-card), 
      body.emergency-mode footer,
      body.emergency-mode .tools-section,
      body.emergency-mode .safety {
        opacity: 0.2;
        pointer-events: none;
        filter: grayscale(100%);
      }
      body.emergency-mode .emergency-overlay {
        display: flex;
      }

      a{ color:inherit; text-decoration:none; }
      a:hover{ text-decoration:underline; text-underline-offset: 3px; }

      .wrap{
        width:min(var(--max), calc(100% - 2*var(--pad)));
        margin: 0 auto;
        padding: 26px 0 42px;
        position: relative;
        z-index: 10;
      }

      /* Core CSS */
      .mast{ border-bottom: 1px solid var(--line2); padding-bottom: 18px; }
      .mast-top{ display:flex; flex-wrap:wrap; align-items:flex-end; justify-content:space-between; gap: 14px; }
      .brand{ line-height:1.05; }
      .brand-header { display: flex; align-items: center; gap: 10px; }
      .brand .name{ font-weight: 950; letter-spacing: -0.02em; font-size: 14px; text-transform: uppercase; color: rgba(244,246,251,.86); }
      .brand .tag{ margin-top: 10px; font-weight: 950; letter-spacing: -0.03em; font-size: clamp(28px, 3.7vw, 46px); }
      .brand .sub{ margin-top: 10px; color: var(--mut); font-size: 14px; line-height: 1.6; max-width: 70ch; }
      .contact{ display:flex; flex-wrap:wrap; gap: 10px; align-items:center; justify-content:flex-end; }
      
      .btn{ display:inline-flex; align-items:center; justify-content:center; gap:10px; padding: 12px 14px; border-radius: 999px; border: 1px solid var(--line); background: rgba(255,255,255,.06); font-weight: 900; letter-spacing: .2px; font-size: 12px; white-space: nowrap; transition: all 0.3s ease; }
      .btn.primary{ background: linear-gradient(180deg, rgba(246,161,26,.98), rgba(246,161,26,.72)); border-color: rgba(246,161,26,.55); color: #0b0c12; }

      .meta{ margin-top: 14px; display:flex; flex-wrap:wrap; gap: 10px 14px; color: rgba(244,246,251,.62); font-size: 12px; }
      .dot{ width:6px; height:6px; border-radius:50%; background: rgba(246,161,26,.9); display:inline-block; margin-right: 8px; transform: translateY(-1px); box-shadow: 0 0 16px rgba(246,161,26,.55); }

      .safety{ margin-top: 18px; padding: 14px 0 0; }
      .rail{ border-left: 2px solid rgba(246,161,26,.55); padding-left: 14px; }
      .rail h2{ margin:0; font-size: 12px; letter-spacing: .22em; text-transform: uppercase; color: rgba(244,246,251,.70); }
      .rail .alert{ margin-top: 10px; background: rgba(255,91,91,.08); border: 1px solid rgba(255,91,91,.30); padding: 12px 12px 12px 12px; border-radius: 14px; }
      .rail .alert strong{ color: rgba(255,91,91,.95); }
      .rail .alert p{ margin: 8px 0 0; color: rgba(244,246,251,.78); font-size: 13px; line-height: 1.55; }
      .rail .alert ul{ margin: 10px 0 0; padding-left: 18px; color: rgba(244,246,251,.82); font-size: 13px; line-height: 1.55; }

      .protocol-grid { margin-top: 60px; display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px; }
      .section-label { font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(244,246,251,.4); margin-bottom: 20px; margin-top: 60px; border-bottom: 1px solid var(--line2); padding-bottom: 10px; }
      
      .booking-compact { margin-top: 60px; padding: 30px; background: rgba(246,161,26,0.03); border: 1px solid rgba(246,161,26,0.15); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px; border-radius: 4px; }
      .booking-text { font-size: 14px; color: var(--mut); max-width: 60ch; line-height: 1.5; }
      .booking-text strong { color: var(--ink); }
      footer { margin-top: 60px; padding-top: 20px; border-top: 1px solid var(--line2); color: var(--mut); font-size: 12px; opacity: 0.6; }
      @media (max-width: 740px){ .contact{ justify-content:flex-start; } .booking-compact { flex-direction: column; align-items: flex-start; } }

      .emergency-overlay {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 50;
        align-items: center;
        justify-content: center;
        background: rgba(0,0,0,0.8);
        backdrop-filter: blur(8px);
      }
      .emergency-content {
        background: #111;
        border: 4px solid #ff4d4d;
        padding: 40px;
        max-width: 500px;
        width: 90%;
        text-align: center;
        border-radius: 4px;
        box-shadow: 0 0 80px rgba(255, 0, 0, 0.4);
        animation: pulse-red 2s infinite;
      }
      @keyframes pulse-red {
        0%, 100% { box-shadow: 0 0 30px rgba(255, 0, 0, 0.2); border-color: #ff4d4d; }
        50% { box-shadow: 0 0 80px rgba(255, 0, 0, 0.5); border-color: #ff0000; }
      }

      /* --- RESTORED CSS ANIMATIONS FOR CERTIFICATE --- */
      @keyframes draw-check {
        0% { stroke-dashoffset: 60; opacity: 0; }
        20% { stroke-dashoffset: 0; opacity: 1; }
        80% { stroke-dashoffset: 0; opacity: 1; }
        100% { stroke-dashoffset: 0; opacity: 0; }
      }

      @keyframes draw-sig {
        0% { stroke-dashoffset: 200; opacity: 0; }
        20% { stroke-dashoffset: 0; opacity: 1; }
        80% { stroke-dashoffset: 0; opacity: 1; }
        100% { stroke-dashoffset: 0; opacity: 0; }
      }

      .cert-seq {
        stroke-dasharray: 60;
        stroke-dashoffset: 60;
        opacity: 0;
        animation: draw-check 8s infinite;
      }
      
      .sig-seq {
        stroke-dasharray: 200;
        stroke-dashoffset: 200;
        opacity: 0;
        animation: draw-sig 8s infinite;
      }

      /* Delays for sequence */
      .d-1 { animation-delay: 0s; }
      .d-2 { animation-delay: 1.5s; }
      .d-3 { animation-delay: 3s; }
      .d-4 { animation-delay: 4.5s; }

      /* Custom Range Slider */
      input[type=range].heat-slider {
        -webkit-appearance: none;
        width: 100%;
        background: transparent;
      }
      input[type=range].heat-slider::-webkit-slider-thumb {
        -webkit-appearance: none;
        height: 16px;
        width: 16px;
        border-radius: 50%;
        background: #f6a11a;
        cursor: pointer;
        margin-top: -6px;
        box-shadow: 0 0 10px rgba(246,161,26, 0.8);
        border: 2px solid white;
      }
      input[type=range].heat-slider::-webkit-slider-runnable-track {
        width: 100%;
        height: 4px;
        cursor: pointer;
        background: rgba(255,255,255,0.1);
        border-radius: 2px;
      }
    </style>
  </head>

  <body>
    <div class="fixed top-4 right-4 z-50">
        <label class="flex items-center cursor-pointer gap-3 bg-black/80 backdrop-blur-md px-4 py-2 rounded-full border border-white/10 hover:border-red-500/50 transition-colors shadow-lg">
            <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-400 group-hover:text-red-400">Gas Alert Mode</span>
            <div class="relative">
                <input type="checkbox" id="emergencyToggle" class="sr-only">
                <div class="block bg-zinc-900 w-10 h-6 rounded-full border border-zinc-700 toggle-bg transition-colors duration-300"></div>
                <div class="dot absolute left-1 top-1 bg-zinc-500 w-4 h-4 rounded-full transition transform duration-300"></div>
            </div>
        </label>
    </div>

    <div class="emergency-overlay">
        <div class="emergency-content">
            <div class="text-red-500 mb-6 mx-auto w-16 h-16 animate-pulse"><Fragment set:html={ICON.alert} /></div>
            <h2 class="text-4xl font-black text-white uppercase tracking-tighter mb-4">Gas Leak Protocol</h2>
            <p class="text-zinc-300 text-base mb-8 leading-relaxed max-w-xs mx-auto">
                Ventilate if safe, leave the property, and contact the gas emergency line. Do not create sparks.
            </p>
            <a href={`tel:${TEL}`} class="block w-full bg-red-600 hover:bg-red-500 text-white font-black uppercase tracking-widest py-5 rounded transition-colors text-xl shadow-[0_0_30px_rgba(255,0,0,0.4)]">
                Call {PHONE} Now
            </a>
            <button id="closeEmergency" class="mt-8 text-[10px] text-zinc-600 hover:text-red-400 uppercase tracking-widest underline transition-colors">Exit Alert Mode</button>
        </div>
    </div>

    <main class="wrap">
      
      <header class="mast">
        <div class="mb-8">
            <a href="/" class="group inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-zinc-500 hover:text-white transition-colors">
                <span class="w-3 h-3 group-hover:-translate-x-1 transition-transform"><Fragment set:html={ICON.back} /></span>
                Index
            </a>
        </div>

        <div class="mast-top">
          <div class="brand">
            <div class="brand-header">
              <span class="brand-icon text-[#f6a11a] w-6 h-6 drop-shadow-[0_0_8px_rgba(246,161,26,0.8)]"><Fragment set:html={ICON.flame} /></span>
              <div class="name">{BRAND}</div>
            </div>
            <div class="tag">{TAGLINE}</div>
            <p class="sub">
              Gas boilers, central heating, controls, repairs, and safety inspections, handled with a calm, documented process.
              We log what we changed, what we tested, and what your system should do next.
            </p>
          </div>

          <div class="contact" aria-label="Contact actions">
            <a class="btn primary shadow-[0_4px_20px_-4px_rgba(246,161,26,0.5)] hover:shadow-[0_8px_30px_-4px_rgba(246,161,26,0.8)] hover:scale-[1.02] transition-transform" href={`tel:${TEL}`}>Call {PHONE}</a>
            <a class="btn hover:border-[#f6a11a]/50 hover:bg-[#f6a11a]/10 hover:text-white transition-colors" href={`mailto:${EMAIL}?subject=${encodeURIComponent("Service request, gas and heating")}`}>Email {EMAIL}</a>
          </div>
        </div>

        <div class="meta">
          <span><span class="dot animate-ember-pulse"></span>{AREA}</span> <span>•</span>
          <span>{HOURS}</span>
        </div>
      </header>

      <section class="safety" aria-label="Gas safety guidance">
        <div class="rail border-l-[#f6a11a]/50">
          <h2>Safety guidance</h2>
          <div class="alert shadow-[0_0_30px_-10px_rgba(255,91,91,0.15)] border-red-500/20" role="note" aria-label="Gas safety note">
            <strong class="text-red-400">If you smell gas or suspect a leak:</strong>
            <p>
              Treat it as urgent. Get to fresh air if needed and contact your local gas emergency service.
              Do not use open flames, and do not create sparks.
            </p>
            <ul>
              <li>Ventilate if it is safe to do so.</li>
              <li>Do not switch electrical devices on or off.</li>
              <li>Shut off the gas supply only if you know exactly how and it is safe.</li>
              <li>If someone feels unwell, move to fresh air and contact emergency services.</li>
            </ul>
          </div>
        </div>
      </section>

      <div class="section-label">Core Services</div>

      <div class="protocol-grid">
        <div class="card group relative overflow-hidden rounded-md border border-white/5 bg-white/5 p-6 transition-all duration-500 hover:border-[#f6a11a]/60 hover:shadow-[0_0_40px_-10px_rgba(246,161,26,0.25)] hover:-translate-y-1">
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-[#f6a11a]/12 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
          <h3 class="relative z-10 text-white font-black uppercase text-sm tracking-wide mb-2">Boiler Service</h3>
          <p class="relative z-10 text-zinc-400 text-sm leading-relaxed">Seasonal maintenance for safer combustion and steadier heat. We test under load and flag wear before it becomes a winter failure.</p>
        </div>

        <div class="card group relative overflow-hidden rounded-md border border-white/5 bg-white/5 p-6 transition-all duration-500 hover:border-[#f6a11a]/60 hover:shadow-[0_0_40px_-10px_rgba(246,161,26,0.25)] hover:-translate-y-1">
           <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-[#f6a11a]/12 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
          <h3 class="relative z-10 text-white font-black uppercase text-sm tracking-wide mb-2">Breakdown Repair</h3>
          <p class="relative z-10 text-zinc-400 text-sm leading-relaxed">Ignition faults, no hot water, pressure drops, circulation issues. We diagnose properly, then fix the cause, not just the symptom.</p>
        </div>

        <div class="card group relative overflow-hidden rounded-md border border-white/5 bg-white/5 p-6 transition-all duration-500 hover:border-[#f6a11a]/60 hover:shadow-[0_0_40px_-10px_rgba(246,161,26,0.25)] hover:-translate-y-1">
           <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-[#f6a11a]/12 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
          <h3 class="relative z-10 text-white font-black uppercase text-sm tracking-wide mb-2">Heating Balance</h3>
          <p class="relative z-10 text-zinc-400 text-sm leading-relaxed">Cold radiators, noisy pipes, uneven rooms. We balance the system, check flow, and tune settings for stable comfort.</p>
        </div>

        <div class="card group relative overflow-hidden rounded-md border border-white/5 bg-white/5 p-6 transition-all duration-500 hover:border-[#f6a11a]/60 hover:shadow-[0_0_40px_-10px_rgba(246,161,26,0.25)] hover:-translate-y-1">
           <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-[#f6a11a]/12 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
          <h3 class="relative z-10 text-white font-black uppercase text-sm tracking-wide mb-2">Controls Setup</h3>
          <p class="relative z-10 text-zinc-400 text-sm leading-relaxed">Thermostats, zoning, schedules, smart controls. We configure it cleanly and hand over a setup you actually understand.</p>
        </div>

        <div class="card group relative overflow-hidden rounded-md border border-white/5 bg-white/5 p-6 transition-all duration-500 hover:border-[#f6a11a]/60 hover:shadow-[0_0_40px_-10px_rgba(246,161,26,0.25)] hover:-translate-y-1">
           <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-[#f6a11a]/12 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
          <h3 class="relative z-10 text-white font-black uppercase text-sm tracking-wide mb-2">Boiler Upgrade</h3>
          <p class="relative z-10 text-zinc-400 text-sm leading-relaxed">Right-sized replacements with correct flue routing and safe commissioning. Cleaner installs, quieter operation, better efficiency.</p>
        </div>
      </div>

      <div class="section-label tools-section">Interactive Tools</div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-16 tools-section">
        <div class="card bg-white/5 border border-white/10 rounded-md p-8 shadow-lg hover:border-white/20 transition-colors">
            <h3 class="text-white font-black uppercase text-sm tracking-wide mb-6 flex items-center gap-3">
                <span class="w-2 h-2 rounded-full bg-ember animate-pulse"></span>
                Quick Heat Output Estimator
            </h3>
            <div class="space-y-6">
                <div>
                    <div class="flex justify-between text-xs font-bold text-zinc-400 uppercase tracking-widest mb-2">
                        <span>Room Length (m)</span>
                        <span id="dispL" class="text-ember">4.0m</span>
                    </div>
                    <input type="range" id="inL" min="2" max="10" step="0.5" value="4" class="heat-slider">
                </div>
                <div>
                    <div class="flex justify-between text-xs font-bold text-zinc-400 uppercase tracking-widest mb-2">
                        <span>Room Width (m)</span>
                        <span id="dispW" class="text-ember">3.5m</span>
                    </div>
                    <input type="range" id="inW" min="2" max="8" step="0.5" value="3.5" class="heat-slider">
                </div>
                <div>
                    <div class="flex justify-between text-xs font-bold text-zinc-400 uppercase tracking-widest mb-2">
                        <span>Ceiling Height (m)</span>
                        <span id="dispH" class="text-ember">2.4m</span>
                    </div>
                    <input type="range" id="inH" min="2" max="4" step="0.1" value="2.4" class="heat-slider">
                </div>
                
                <div class="pt-6 border-t border-white/10 flex items-center justify-between">
                    <span class="text-xs font-bold text-zinc-500 uppercase">Estimated Output</span>
                    <div class="text-right">
                        <span id="outBTU" class="block text-2xl font-black text-white tracking-tighter shadow-ember/50 drop-shadow-[0_0_10px_rgba(246,161,26,0.3)]">-- BTU</span>
                        <span id="outWatts" class="block text-xs font-bold text-zinc-500">-- Watts</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card bg-white/5 border border-white/10 rounded-md p-8 shadow-lg flex flex-col hover:border-white/20 transition-colors">
            <h3 class="text-white font-black uppercase text-sm tracking-wide mb-6 flex items-center gap-3">
                <span class="w-2 h-2 rounded-full bg-blue-400"></span>
                Boiler Type Guide
            </h3>
            

Diagram reference: combi boiler internal schematic

            <div class="mb-8">
                <p class="text-xs font-bold text-zinc-400 uppercase tracking-widest mb-4">Bathrooms needing hot water?</p>
                <div class="grid grid-cols-3 gap-4">
                    <button class="bath-btn py-3 border border-white/10 rounded hover:border-ember hover:text-ember text-zinc-400 text-sm font-bold transition-all bg-white/5" data-val="1">1</button>
                    <button class="bath-btn py-3 border border-white/10 rounded hover:border-ember hover:text-ember text-zinc-400 text-sm font-bold transition-all bg-white/5" data-val="2">2</button>
                    <button class="bath-btn py-3 border border-white/10 rounded hover:border-ember hover:text-ember text-zinc-400 text-sm font-bold transition-all bg-white/5" data-val="3">3+</button>
                </div>
            </div>
            <div class="flex-1 grid grid-cols-3 gap-2">
                <div id="resCombi" class="sys-card border border-white/5 bg-black/20 rounded p-3 flex flex-col justify-center items-center text-center opacity-40 transition-all duration-500">
                    <span class="text-[10px] font-black uppercase text-zinc-500 mb-1">1 Bath</span>
                    <strong class="text-white text-sm">Combi Boiler</strong>
                </div>
                <div id="resSystem" class="sys-card border border-white/5 bg-black/20 rounded p-3 flex flex-col justify-center items-center text-center opacity-40 transition-all duration-500">
                    <span class="text-[10px] font-black uppercase text-zinc-500 mb-1">2 Baths</span>
                    <strong class="text-white text-sm">System Boiler</strong>
                </div>
                <div id="resRegular" class="sys-card border border-white/5 bg-black/20 rounded p-3 flex flex-col justify-center items-center text-center opacity-40 transition-all duration-500">
                    <span class="text-[10px] font-black uppercase text-zinc-500 mb-1">3+ Baths</span>
                    <strong class="text-white text-sm">Boiler + Cylinder</strong>
                </div>
            </div>
        </div>

        <div class="col-span-1 lg:col-span-2 card bg-white/5 border border-white/10 rounded-md p-8 shadow-lg hover:border-white/20 transition-colors">
            <div class="flex justify-between items-start mb-6">
                <h3 class="text-white font-black uppercase text-sm tracking-wide flex items-center gap-3">
                    <span class="text-red-500 w-4 h-4"><Fragment set:html={ICON.alert} /></span>
                    Fault Triage Tool
                </h3>
                <button id="resetTriage" class="text-zinc-500 hover:text-white transition-colors" title="Reset">
                    <div class="w-5 h-5"><Fragment set:html={ICON.refresh} /></div>
                </button>
            </div>
            <div id="triageContainer" class="relative min-h-[120px] flex items-center justify-center">
                <div id="step1" class="triage-step w-full text-center transition-all duration-300">
                    <p class="text-xl text-white font-bold mb-8">Do you smell gas?</p>
                    <div class="flex justify-center gap-4">
                        <button onclick="triage('resEmergency')" class="px-8 py-3 bg-red-500/10 border border-red-500/50 text-red-400 font-bold uppercase rounded hover:bg-red-500 hover:text-white transition-all shadow-lg hover:shadow-red-500/20">Yes</button>
                        <button onclick="triage('step2')" class="px-8 py-3 bg-zinc-800 border border-zinc-700 text-zinc-300 font-bold uppercase rounded hover:border-white transition-all">No</button>
                    </div>
                </div>

                <div id="step2" class="triage-step w-full text-center hidden opacity-0 transition-all duration-300">
                    <p class="text-xl text-white font-bold mb-6">Is the boiler display or pilot light ON?</p>
                    <div class="flex justify-center gap-4 mb-6">
                        <button onclick="triage('step3')" class="px-8 py-3 bg-zinc-800 border border-zinc-700 text-zinc-300 font-bold uppercase rounded hover:border-ember hover:text-ember transition-all">Yes</button>
                        <button onclick="triage('resBook')" class="px-8 py-3 bg-zinc-800 border border-zinc-700 text-zinc-300 font-bold uppercase rounded hover:border-white transition-all">No</button>
                    </div>
                    <button onclick="goBack()" class="text-[10px] text-zinc-500 hover:text-white uppercase tracking-widest transition-colors flex items-center gap-1 mx-auto"><span class="w-3 h-3 rotate-0"><Fragment set:html={ICON.back} /></span> Back</button>
                </div>

                <div id="step3" class="triage-step w-full text-center hidden opacity-0 transition-all duration-300">
                    <p class="text-xl text-white font-bold mb-6">Is there an error code (F1, E1, Low) or flashing red light?</p>
                    <div class="flex justify-center gap-4 mb-6">
                        <button onclick="triage('resPressure')" class="px-8 py-3 bg-zinc-800 border border-zinc-700 text-zinc-300 font-bold uppercase rounded hover:border-blue-400 hover:text-blue-400 transition-all">Yes</button>
                        <button onclick="triage('step4')" class="px-8 py-3 bg-zinc-800 border border-zinc-700 text-zinc-300 font-bold uppercase rounded hover:border-white transition-all">No</button>
                    </div>
                    <button onclick="goBack()" class="text-[10px] text-zinc-500 hover:text-white uppercase tracking-widest transition-colors flex items-center gap-1 mx-auto"><span class="w-3 h-3 rotate-0"><Fragment set:html={ICON.back} /></span> Back</button>
                </div>

                <div id="step4" class="triage-step w-full text-center hidden opacity-0 transition-all duration-300">
                    <p class="text-xl text-white font-bold mb-6">Is the issue Heating, Hot Water, or Both?</p>
                    <div class="flex flex-wrap justify-center gap-3 mb-6">
                        <button onclick="triage('step5')" class="px-5 py-3 bg-zinc-800 border border-zinc-700 text-zinc-300 font-bold uppercase rounded hover:border-ember hover:text-ember transition-all text-xs">Heating Only</button>
                        <button onclick="triage('resBook')" class="px-5 py-3 bg-zinc-800 border border-zinc-700 text-zinc-300 font-bold uppercase rounded hover:border-ember hover:text-ember transition-all text-xs">Hot Water Only</button>
                        <button onclick="triage('resBook')" class="px-5 py-3 bg-zinc-800 border border-zinc-700 text-zinc-300 font-bold uppercase rounded hover:border-ember hover:text-ember transition-all text-xs">Both</button>
                    </div>
                    <button onclick="goBack()" class="text-[10px] text-zinc-500 hover:text-white uppercase tracking-widest transition-colors flex items-center gap-1 mx-auto"><span class="w-3 h-3 rotate-0"><Fragment set:html={ICON.back} /></span> Back</button>
                </div>

                <div id="step5" class="triage-step w-full text-center hidden opacity-0 transition-all duration-300">
                    <p class="text-xl text-white font-bold mb-6">Have you checked thermostat batteries and settings?</p>
                    <div class="flex justify-center gap-4 mb-6">
                        <button onclick="triage('resThermostat')" class="px-8 py-3 bg-zinc-800 border border-zinc-700 text-zinc-300 font-bold uppercase rounded hover:border-ember hover:text-ember transition-all">Yes, they are fine</button>
                        <button onclick="triage('resBattery')" class="px-8 py-3 bg-zinc-800 border border-zinc-700 text-zinc-300 font-bold uppercase rounded hover:border-white transition-all">No, let me check</button>
                    </div>
                    <button onclick="goBack()" class="text-[10px] text-zinc-500 hover:text-white uppercase tracking-widest transition-colors flex items-center gap-1 mx-auto"><span class="w-3 h-3 rotate-0"><Fragment set:html={ICON.back} /></span> Back</button>
                </div>

                <div id="resEmergency" class="triage-step w-full text-center hidden opacity-0 transition-all duration-300">
                    <p class="text-red-500 font-black uppercase tracking-widest mb-4">EMERGENCY ACTION</p>
                    <p class="text-zinc-400 mb-6 max-w-md mx-auto">Do not use electrical switches. Ventilate if safe, leave immediately, and contact the gas emergency line.</p>
                    <div class="flex flex-col items-center gap-6">
                        <a href={`tel:${TEL}`} class="inline-block bg-red-600 text-white font-bold px-8 py-3 rounded uppercase tracking-widest hover:bg-red-500 shadow-lg shadow-red-600/30 transition-colors">Call Now</a>
                        <button onclick="goBack()" class="text-[10px] text-zinc-500 hover:text-white uppercase tracking-widest transition-colors flex items-center gap-1"><span class="w-3 h-3 rotate-0"><Fragment set:html={ICON.back} /></span> Back</button>
                    </div>
                </div>

                <div id="resBook" class="triage-step w-full text-center hidden opacity-0 transition-all duration-300">
                    <p class="text-ember font-black uppercase tracking-widest mb-4">Professional Repair Needed</p>
                    <p class="text-zinc-400 mb-6 max-w-md mx-auto">Likely a component failure (fan, pump, or diverter valve). Book a diagnostic visit for a safe resolution.</p>
                    <div class="flex flex-col items-center gap-6">
                        <a href={`mailto:${EMAIL}`} class="inline-block border border-ember text-ember font-bold px-8 py-3 rounded uppercase tracking-widest hover:bg-ember hover:text-black shadow-[0_0_20px_-5px_rgba(246,161,26,0.4)] transition-all">Book Diagnostic</a>
                        <button onclick="goBack()" class="text-[10px] text-zinc-500 hover:text-white uppercase tracking-widest transition-colors flex items-center gap-1"><span class="w-3 h-3 rotate-0"><Fragment set:html={ICON.back} /></span> Back</button>
                    </div>
                </div>

                <div id="resPressure" class="triage-step w-full text-center hidden opacity-0 transition-all duration-300">
                    <p class="text-blue-400 font-black uppercase tracking-widest mb-4">Likely Low Pressure</p>
                    <p class="text-zinc-400 mb-6 max-w-md mx-auto">Check your pressure gauge. If it is below 1.0 bar, the system needs topping up to fire correctly.</p>
                    <div class="flex flex-col items-center gap-6">
                        <a href={`tel:${TEL}`} class="inline-block bg-white text-black font-bold px-8 py-3 rounded uppercase tracking-widest hover:bg-zinc-200 transition-colors">Call for Guidance</a>
                        <button onclick="goBack()" class="text-[10px] text-zinc-500 hover:text-white uppercase tracking-widest transition-colors flex items-center gap-1"><span class="w-3 h-3 rotate-0"><Fragment set:html={ICON.back} /></span> Back</button>
                    </div>
                </div>

                <div id="resThermostat" class="triage-step w-full text-center hidden opacity-0 transition-all duration-300">
                    <p class="text-emerald-400 font-black uppercase tracking-widest mb-4">Check Zone Control</p>
                    <p class="text-zinc-400 mb-6 max-w-md mx-auto">If the boiler is on but there is no heat, a zone valve or pump may be stuck. We can diagnose this quickly.</p>
                    <div class="flex flex-col items-center gap-6">
                        <a href={`tel:${TEL}`} class="inline-block border border-emerald-500 text-emerald-500 font-bold px-8 py-3 rounded uppercase tracking-widest hover:bg-emerald-500 hover:text-black transition-all">Request Help</a>
                        <button onclick="goBack()" class="text-[10px] text-zinc-500 hover:text-white uppercase tracking-widest transition-colors flex items-center gap-1"><span class="w-3 h-3 rotate-0"><Fragment set:html={ICON.back} /></span> Back</button>
                    </div>
                </div>

                <div id="resBattery" class="triage-step w-full text-center hidden opacity-0 transition-all duration-300">
                    <p class="text-zinc-300 font-black uppercase tracking-widest mb-4">Check Controls First</p>
                    <p class="text-zinc-400 mb-6 max-w-md mx-auto">Many "faults" are just dead batteries or a clock that reset after a power cut. Check these before booking.</p>
                    <div class="flex flex-col items-center gap-6">
                        <button onclick="resetTriage()" class="inline-block bg-zinc-700 text-white font-bold px-8 py-3 rounded uppercase tracking-widest hover:bg-zinc-600 transition-colors">Start Over</button>
                        <button onclick="goBack()" class="text-[10px] text-zinc-500 hover:text-white uppercase tracking-widest transition-colors flex items-center gap-1"><span class="w-3 h-3 rotate-0"><Fragment set:html={ICON.back} /></span> Back</button>
                    </div>
                </div>
            </div>
        </div>
      </div>

      <div class="section-label">Documentation</div>
      
      <div id="certContainer" class="p-8 border-l-[3px] border-l-[#f6a11a] mb-12">
        <div class="flex justify-between items-start mb-8 pb-4 border-b border-white/10">
            <div>
                <h3 class="text-white font-black uppercase text-xl tracking-tight">Safety Check Record</h3>
                <span class="text-xs text-zinc-500 uppercase tracking-widest">Commissioning and test log V.04</span>
            </div>
            <div class="text-right hidden sm:block">
                <span class="block text-emerald-500 font-black uppercase border border-emerald-500/30 px-2 py-1 rounded bg-emerald-500/10 text-xs">Passed</span>
            </div>
        </div>
        
        <svg class="w-full h-auto max-w-md mx-auto" viewBox="0 0 400 180" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="0" y1="40" x2="400" y2="40" stroke="#333" stroke-dasharray="4 4" />
            <line x1="0" y1="80" x2="400" y2="80" stroke="#333" stroke-dasharray="4 4" />
            <line x1="0" y1="120" x2="400" y2="120" stroke="#333" stroke-dasharray="4 4" />
            
            <text x="10" y="28" stroke="none" fill="#a1a1aa" font-family="sans-serif" font-size="10" font-weight="normal" style="text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.8;">Flue flow test</text>
            <text x="10" y="68" stroke="none" fill="#a1a1aa" font-family="sans-serif" font-size="10" font-weight="normal" style="text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.8;">Spillage check</text>
            <text x="10" y="108" stroke="none" fill="#a1a1aa" font-family="sans-serif" font-size="10" font-weight="normal" style="text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.8;">Combustion reading</text>
            
            <path d="M350 20 l10 10 l20 -20" stroke="#10b981" stroke-width="4" fill="none" class="cert-seq d-1" />
            <path d="M350 60 l10 10 l20 -20" stroke="#10b981" stroke-width="4" fill="none" class="cert-seq d-2" />
            <path d="M350 100 l10 10 l20 -20" stroke="#10b981" stroke-width="4" fill="none" class="cert-seq d-3" />
            
            <line x1="10" y1="160" x2="200" y2="160" stroke="#444" />
            <text x="10" y="175" stroke="none" fill="#52525b" font-family="sans-serif" font-size="8" font-weight="normal" style="text-transform: uppercase; opacity: 0.7;">Engineer signature</text>
            <path d="M20 150 c10 -10, 20 10, 30 0 s 20 -10, 30 0 s 20 -10, 30 0" stroke="#f6a11a" stroke-width="2" fill="none" class="sig-seq d-4" />
        </svg>
      </div>

      <section class="booking-compact shadow-[0_0_50px_-10px_rgba(246,161,26,0.15)] border border-[#f6a11a]/20 bg-gradient-to-br from-[#f6a11a]/8 via-white/0 to-transparent">
        <div class="booking-text">
          <strong class="text-white">Want a visit scheduled?</strong><br>
          Email is fastest. Include your address, boiler make and model, and a short fault description. If it is intermittent, tell us when it happens.
        </div>
        <div class="contact">
          <a class="btn primary shadow-[0_4px_20px_-4px_rgba(246,161,26,0.5)] hover:shadow-[0_8px_30px_-4px_rgba(246,161,26,0.8)] hover:scale-[1.02] transition-transform" href={`tel:${TEL}`}>Call {PHONE}</a>
          <a class="btn hover:border-[#f6a11a]/50 hover:bg-[#f6a11a]/10 hover:text-white transition-colors" href={`mailto:${EMAIL}`}>Email Service</a>
        </div>
      </section>

      <footer>
        © {YEAR} {BRAND}. Certified gas and heating work, documented for safety and compliance.
      </footer>

    </main>

    <script is:inline>
        // --- Emergency Toggle Logic ---
        const toggle = document.getElementById('emergencyToggle');
        const body = document.body;
        const closeBtn = document.getElementById('closeEmergency');
        const dot = toggle.nextElementSibling.nextElementSibling;

        function setEmergency(active) {
            if(active) {
                body.classList.add('emergency-mode');
                dot.style.transform = 'translateX(100%)';
                dot.style.backgroundColor = '#ff4d4d';
                toggle.checked = true;
            } else {
                body.classList.remove('emergency-mode');
                dot.style.transform = 'translateX(0)';
                dot.style.backgroundColor = 'white';
                toggle.checked = false;
            }
        }

        toggle.addEventListener('change', (e) => {
            setEmergency(e.target.checked);
        });

        closeBtn.addEventListener('click', () => {
            setEmergency(false);
        });

        // --- BTU Calculator Logic ---
        const inL = document.getElementById('inL');
        const inW = document.getElementById('inW');
        const inH = document.getElementById('inH');
        const dispL = document.getElementById('dispL');
        const dispW = document.getElementById('dispW');
        const dispH = document.getElementById('dispH');
        const outBTU = document.getElementById('outBTU');
        const outWatts = document.getElementById('outWatts');

        function calcBTU() {
            const l = parseFloat(inL.value);
            const w = parseFloat(inW.value);
            const h = parseFloat(inH.value);
            
            dispL.innerText = l + 'm';
            dispW.innerText = w + 'm';
            dispH.innerText = h + 'm';

            const vol = l * w * h;
            const btu = Math.round(vol * 150);
            const watts = Math.round(btu / 3.412);

            outBTU.innerText = btu.toLocaleString() + ' BTU';
            outWatts.innerText = watts.toLocaleString() + ' Watts';
        }
        
        [inL, inW, inH].forEach(el => el.addEventListener('input', calcBTU));
        calcBTU(); // Init

        // --- Boiler Selector Logic ---
        const bathBtns = document.querySelectorAll('.bath-btn');
        const cards = {
            1: document.getElementById('resCombi'),
            2: document.getElementById('resSystem'),
            3: document.getElementById('resRegular')
        };

        bathBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                bathBtns.forEach(b => {
                    b.classList.remove('border-ember', 'text-ember', 'bg-ember/10');
                    b.classList.add('border-white/10', 'text-zinc-400', 'bg-white/5');
                });
                Object.values(cards).forEach(c => {
                    c.classList.remove('opacity-100', 'border-ember', 'bg-ember/20', 'shadow-[0_0_20px_rgba(246,161,26,0.3)]');
                    c.classList.add('opacity-40', 'border-white/5', 'bg-black/20');
                });

                btn.classList.remove('border-white/10', 'text-zinc-400', 'bg-white/5');
                btn.classList.add('border-ember', 'text-ember', 'bg-ember/10');

                const val = parseInt(btn.dataset.val);
                const target = val >= 3 ? cards[3] : cards[val];
                
                target.classList.remove('opacity-40', 'border-white/5', 'bg-black/20');
                target.classList.add('opacity-100', 'border-ember', 'bg-ember/20', 'shadow-[0_0_20px_rgba(246,161,26,0.3)]');
            });
        });

        // --- Triage Logic ---
        window.triageHistory = [];

        window.triage = function(nextStepId, isBack = false) {
            const steps = document.querySelectorAll('.triage-step');
            const currentStep = Array.from(steps).find(s => !s.classList.contains('hidden'));
            const target = document.getElementById(nextStepId);
            
            if (!target) return;

            if (currentStep && !isBack) {
                window.triageHistory.push(currentStep.id);
            }

            // Hide with transition
            steps.forEach(el => {
                if (!el.classList.contains('hidden')) {
                    el.classList.add('opacity-0');
                    el.style.transform = isBack ? 'scale(1.05)' : 'scale(0.95)';
                    setTimeout(() => {
                        if (el !== target) el.classList.add('hidden');
                    }, 300);
                }
            });

            // Show target
            setTimeout(() => {
                target.classList.remove('hidden');
                
                // Use offsetWidth to force layout before removing opacity
                void target.offsetWidth; 
                
                target.classList.remove('opacity-0');
                target.style.transform = 'scale(1)';
            }, 305);
        };

        window.goBack = function() {
            if (window.triageHistory.length > 0) {
                window.triage(window.triageHistory.pop(), true);
            }
        };

        window.resetTriage = function() {
            window.triageHistory = [];
            document.querySelectorAll('.triage-step').forEach(el => {
                el.classList.add('hidden', 'opacity-0');
                el.style.transform = 'scale(0.95)';
            });
            const s1 = document.getElementById('step1');
            if (s1) {
                s1.classList.remove('hidden');
                void s1.offsetWidth;
                s1.classList.remove('opacity-0');
                s1.style.transform = 'scale(1)';
            }
        };

        document.getElementById('resetTriage').addEventListener('click', resetTriage);

    </script>
  </body>
</html>
